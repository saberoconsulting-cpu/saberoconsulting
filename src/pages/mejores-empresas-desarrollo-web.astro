---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOLanding from '../components/sections/seo/SEOLanding.astro';

const path = '/mejores-empresas-desarrollo-web';
const title = 'Mejores Empresas de Desarrollo Web | SABERO Consulting - Top Perú';
const description = 'SABERO Consulting está entre las mejores empresas de desarrollo web. Creamos plataformas web, PWAs, apps mobile y APIs con tecnologías modernas. Equipo senior en Perú.';
---

<BaseLayout {title} {description} locale="es" {path}>
  <SEOLanding
    locale="es"
    title="Entre las Mejores Empresas de Desarrollo Web"
    subtitle="Creamos experiencias web que impulsan tu negocio"
    description="SABERO Consulting es reconocida como una de las mejores empresas de desarrollo web con presencia en Perú, Estados Unidos y Europa. Especialistas en crear plataformas web complejas, aplicaciones web progresivas (PWAs), tiendas online, dashboards interactivos y portales empresariales. Usamos tecnologías modernas como React, Next.js, Vue.js, Node.js y Python para entregar productos digitales de alto rendimiento, con excelente experiencia de usuario y optimizados para SEO."
    keywords={[
      "mejores empresas de desarrollo web",
      "desarrollo web",
      "empresa de desarrollo web Perú",
      "mejores empresas web",
      "desarrollo de páginas web",
      "creación de plataformas web",
      "los mejores en servicios web",
      "compañías en web mobile",
      "desarrollo web profesional",
      "agencia de desarrollo web Perú"
    ]}
    features={[
      {
        icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
        title: "Plataformas Web Complejas",
        description: "Desarrollamos plataformas web B2B y B2C con React, Next.js, Vue.js y Angular. Performance optimizada, SEO nativo y experiencia de usuario excepcional."
      },
      {
        icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
        title: "Progressive Web Apps",
        description: "PWAs que funcionan offline, se instalan en el home screen y ofrecen experiencia nativa. Menor costo de desarrollo, mayor alcance y engagement."
      },
      {
        icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
        title: "E-commerce y Marketplaces",
        description: "Tiendas online, marketplaces y plataformas de comercio electrónico escalables. Integración con pasarelas de pago, logística y ERP."
      },
      {
        icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/>',
        title: "APIs y Microservicios",
        description: "APIs RESTful y GraphQL escalables con Node.js, Python y Go. Arquitectura de microservicios para sistemas robustos y mantenibles."
      },
      {
        icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
        title: "Cloud & DevOps",
        description: "Despliegue en AWS, GCP y Azure. CI/CD, contenedores Docker, Kubernetes, monitoreo y escalado automático para máxima disponibilidad."
      },
      {
        icon: '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
        title: "UX/UI Design",
        description: "Diseñamos interfaces intuitivas y atractivas. Investigación de usuarios, prototipado, testing de usabilidad y sistemas de diseño escalables."
      }
    ]}
    ctaText="Construye tu plataforma web"
    ctaHref="/contacto"
  />
</BaseLayout>
