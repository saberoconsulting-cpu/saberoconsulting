---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CasosExitoCTA from '../../components/sections/casos/CasosExitoCTA.astro';
import CasosTitulo from '../../components/sections/casos/CasosTitulo.astro';
import CasosGrid from '../../components/sections/casos/CasosGrid.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'Casos e impacto - SABERO Consulting',
    description: 'Conoce como transformamos retos de negocio en productos, plataformas y operaciones digitales medibles.',
  },
  en: {
    title: 'Cases & Impact - SABERO Consulting',
    description: 'See how we transform business challenges into measurable digital products, platforms and operations.',
  },
  pt: {
    title: 'Casos e impacto - SABERO Consulting',
    description: 'Veja como transformamos desafios de negocios em produtos, plataformas e operacoes digitais viaveis.',
  },
  fr: {
    title: 'Cas et impact - SABERO Consulting',
    description: 'Decouvrez comment nous transformons les defis commerciaux en produits, plateformes et operations numeriques mesurables.',
  },
};

const pageMeta = (meta[locale as string] || meta.es);
const path = '/casos';
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} {path}>
  <CasosExitoCTA locale={locale} />
  <CasosTitulo locale={locale} />
  <CasosGrid />
</BaseLayout>
