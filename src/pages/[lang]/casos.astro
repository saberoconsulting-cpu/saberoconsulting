---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCasosData } from '../../data/casos/index';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const data = getCasosData(locale as SupportedLocale);

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'Casos e impacto',
    description: 'Conoce como transformamos retos de negocio en productos, plataformas y operaciones digitales medibles.',
  },
  en: {
    title: 'Cases & Impact',
    description: 'See how we transform business challenges into measurable digital products, platforms and operations.',
  },
  pt: {
    title: 'Casos e impacto',
    description: 'Veja como transformamos desafios de negocios em produtos, plataformas e operacoes digitais viaveis.',
  },
  fr: {
    title: 'Cas et impact',
    description: 'Decouvrez comment nous transformons les defis commerciaux en produits, plateformes et operations numeriques mesurables.',
  },
};

const pageMeta = (meta[locale as string] || meta.es);
const path = '/casos';
const isEs = locale === 'es';

const langText: Record<string, { all: string; filter: string; cta: string }> = {
  es: { all: 'Todas las industrias', filter: 'Filtrar por', cta: 'Conversemos sobre tu proyecto' },
  en: { all: 'All industries', filter: 'Filter by', cta: 'Let\'s talk about your project' },
  pt: { all: 'Todas as industrias', filter: 'Filtrar por', cta: 'Vamos conversar sobre seu projeto' },
  fr: { all: 'Toutes les industries', filter: 'Filtrer par', cta: 'Parlons de votre projet' },
};
const ui = langText[locale as string] || langText.es;

const industries = [...new Set(data.destacados.map((c) => c.industria))];
---

<BaseLayout title={`${pageMeta.title}`} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <section class="casos-hero">
    <div class="casos-hero-bg-layer"></div>
    <div class="casos-data-stream" aria-hidden="true">
      <span>010011 101001 110100 001011</span>
      <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="casos-cloud" aria-hidden="true">
      <img src="/images/imagen3.png" alt="" />
    </div>
    <div class="casos-scanlines" aria-hidden="true"></div>
    <div class="casos-orbs" aria-hidden="true">
      {data.destacados.slice(0, 6).map((c, i) => (
        <div class={`casos-orb casos-orb-${i + 1}`}><span>{c.impacto}</span></div>
      ))}
    </div>
    <div class="container">
      <div class="casos-hero-content">
        <div class="casos-hero-badge-row">
          <span class="casos-hero-badge">{locale === 'es' ? 'Portafolio' : locale === 'en' ? 'Portfolio' : locale === 'pt' ? 'Portfolio' : 'Portfolio'}</span>
          <span class="casos-hero-badge-outline">{locale === 'es' ? 'Resultados' : locale === 'en' ? 'Results' : locale === 'pt' ? 'Resultados' : 'Résultats'}</span>
        </div>
        <h1 class="casos-hero-title">
          <span class="casos-hero-title-line">{locale === 'es' ? 'Casos e' : locale === 'en' ? 'Cases &' : locale === 'pt' ? 'Casos e' : 'Cas et'}</span>
          <span class="casos-hero-title-line casos-hero-title-accent">{locale === 'es' ? 'Impacto' : locale === 'en' ? 'Impact' : locale === 'pt' ? 'Impacto' : 'Impact'}</span>
        </h1>
        <p class="casos-hero-desc">{pageMeta.description}</p>
        <div class="casos-hero-cta-row">
          <a href="#casos" class="casos-hero-cta">
            <span>{locale === 'es' ? 'Ver proyectos' : locale === 'en' ? 'View projects' : locale === 'pt' ? 'Ver projetos' : 'Voir projets'}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <span class="casos-hero-counter">
            <span class="casos-hero-counter-num">{data.destacados.length}</span>
            <span class="casos-hero-counter-label">{locale === 'es' ? 'proyectos entregados' : locale === 'en' ? 'projects delivered' : locale === 'pt' ? 'projetos entregues' : 'projets livrés'}</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="casos-grid-section" id="casos">
    <div class="container">
      <div class="casos-grid">
        {data.destacados.map((c) => (
          <article class="caso-card">
            <div class="caso-card-image" style={`background-image: url(${c.imagen})`}>
              <div class="caso-card-overlay"></div>
              <div class="caso-card-industry">{c.industria}</div>
            </div>
            <div class="caso-card-body">
              <h3 class="caso-card-title">{c.nombre}</h3>
              <p class="caso-card-desc">{c.solucion}</p>
              <div class="caso-card-impact">
                <span class="caso-impact-label">{locale === 'es' ? 'Impacto' : locale === 'en' ? 'Impact' : locale === 'pt' ? 'Impacto' : 'Impact'}</span>
                <span class="caso-impact-value">{c.impacto}</span>
              </div>
              <div class="caso-card-tags">
                {c.tags.map((tag) => <span class="caso-tag">{tag}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="casos-cta">
    <div class="casos-cta-bg" aria-hidden="true">
      <img src="/images/imagen.png" alt="" loading="lazy" />
    </div>
    <div class="casos-cta-overlay"></div>
    <div class="container">
      <div class="casos-cta-content">
        <h2 class="casos-cta-title">{ui.cta}</h2>
        <a href={isEs ? '/contacto' : `/${locale}/contacto`} class="casos-cta-btn">
          {locale === 'es' ? 'Contactanos' : locale === 'en' ? 'Contact us' : locale === 'pt' ? 'Fale conosco' : 'Contactez-nous'}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .casos-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #060d1a;
  }

  .casos-hero-bg-layer {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 100% 60% at 50% 20%, rgba(0,102,255,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 90%, rgba(255,0,100,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 60%, rgba(0,200,255,0.04) 0%, transparent 50%),
      linear-gradient(180deg, #060d1a 0%, #0a1628 50%, #060d1a 100%);
    pointer-events: none;
    z-index: 0;
  }

  .casos-data-stream {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    font-family: 'Courier New', monospace;
  }

  .casos-data-stream > span:first-child {
    position: absolute;
    top: 8%;
    left: 5%;
    font-size: 0.65rem;
    color: rgba(0,102,255,0.06);
    writing-mode: vertical-lr;
    letter-spacing: 8px;
    animation: data-fall 12s linear infinite;
  }

  .casos-data-stream span:nth-child(n+2) {
    position: absolute;
    width: 2px;
    height: 60px;
    background: linear-gradient(180deg, transparent, rgba(0,200,255,0.15), transparent);
    animation: data-rain 8s linear infinite;
    top: -60px;
  }
  .casos-data-stream span:nth-child(2) { left: 12%; animation-duration: 7s; animation-delay: 0s; height: 40px; }
  .casos-data-stream span:nth-child(3) { left: 25%; animation-duration: 11s; animation-delay: 2s; height: 80px; }
  .casos-data-stream span:nth-child(4) { left: 38%; animation-duration: 9s; animation-delay: 1s; height: 50px; }
  .casos-data-stream span:nth-child(5) { left: 55%; animation-duration: 13s; animation-delay: 3s; height: 70px; }
  .casos-data-stream span:nth-child(6) { left: 68%; animation-duration: 8s; animation-delay: 0.5s; height: 45px; }
  .casos-data-stream span:nth-child(7) { left: 75%; animation-duration: 10s; animation-delay: 4s; height: 90px; }
  .casos-data-stream span:nth-child(8) { left: 82%; animation-duration: 6s; animation-delay: 1.5s; height: 35px; }
  .casos-data-stream span:nth-child(9) { left: 90%; animation-duration: 12s; animation-delay: 2.5s; height: 65px; }
  .casos-data-stream span:nth-child(10) { left: 45%; animation-duration: 14s; animation-delay: 3.5s; height: 55px; }
  .casos-data-stream span:nth-child(11) { left: 60%; animation-duration: 9.5s; animation-delay: 0.8s; height: 75px; }
  .casos-data-stream span:nth-child(12) { left: 8%; animation-duration: 11.5s; animation-delay: 1.2s; height: 42px; }
  .casos-data-stream span:nth-child(13) { left: 32%; animation-duration: 7.5s; animation-delay: 4.5s; height: 88px; }
  .casos-data-stream span:nth-child(14) { left: 50%; animation-duration: 10.5s; animation-delay: 2.2s; height: 38px; }
  .casos-data-stream span:nth-child(15) { left: 95%; animation-duration: 8.5s; animation-delay: 0.3s; height: 62px; }

  @keyframes data-fall {
    0% { transform: translateY(-100%); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  @keyframes data-rain {
    0% { transform: translateY(-60px); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 0.8; }
    100% { transform: translateY(calc(92vh + 60px)); opacity: 0; }
  }

  .casos-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,200,255,0.015) 2px, rgba(0,200,255,0.015) 4px);
    pointer-events: none;
    z-index: 1;
  }

  .casos-cloud {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 60%;
    height: 70%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.3) 20%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.8) 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.3) 20%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.8) 100%);
  }

  .casos-cloud img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.08;
    filter: grayscale(1) brightness(0.6) contrast(1.3);
    animation: cloud-drift 20s ease-in-out infinite alternate;
  }

  @keyframes cloud-drift {
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.1) translate(-20px, -10px); }
  }

  .casos-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .casos-orb {
    position: absolute;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: 900;
    color: var(--color-white);
    backdrop-filter: blur(12px);
    animation: orb-float 12s ease-in-out infinite;
  }

  .casos-orb span { position: relative; z-index: 1; }
  .casos-orb-1 { top: 15%; left: 65%; width: 120px; height: 120px; background: radial-gradient(circle, rgba(0,102,255,0.2) 0%, rgba(0,102,255,0.05) 60%, transparent 100%); border: 1px solid rgba(0,102,255,0.15); animation-delay: 0s; font-size: 1.4rem; }
  .casos-orb-2 { top: 60%; left: 75%; width: 90px; height: 90px; background: radial-gradient(circle, rgba(255,0,100,0.15) 0%, rgba(255,0,100,0.03) 60%, transparent 100%); border: 1px solid rgba(255,0,100,0.1); animation-delay: -2s; font-size: 1.1rem; }
  .casos-orb-3 { top: 30%; right: 10%; width: 80px; height: 80px; background: radial-gradient(circle, rgba(0,200,255,0.18) 0%, rgba(0,200,255,0.04) 60%, transparent 100%); border: 1px solid rgba(0,200,255,0.12); animation-delay: -4s; font-size: 1rem; }
  .casos-orb-4 { top: 70%; left: 60%; width: 70px; height: 70px; background: radial-gradient(circle, rgba(255,200,0,0.12) 0%, rgba(255,200,0,0.03) 60%, transparent 100%); border: 1px solid rgba(255,200,0,0.08); animation-delay: -6s; font-size: 0.95rem; }
  .casos-orb-5 { top: 10%; left: 80%; width: 85px; height: 85px; background: radial-gradient(circle, rgba(0,255,150,0.14) 0%, rgba(0,255,150,0.03) 60%, transparent 100%); border: 1px solid rgba(0,255,150,0.1); animation-delay: -8s; font-size: 1rem; }
  .casos-orb-6 { top: 45%; left: 88%; width: 75px; height: 75px; background: radial-gradient(circle, rgba(150,50,255,0.15) 0%, rgba(150,50,255,0.03) 60%, transparent 100%); border: 1px solid rgba(150,50,255,0.1); animation-delay: -10s; font-size: 0.9rem; }

  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(15px, -20px) scale(1.05); }
    50% { transform: translate(-10px, 10px) scale(0.95); }
    75% { transform: translate(20px, -5px) scale(1.02); }
  }

  .casos-hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--header-height);
    max-width: 700px;
  }

  .casos-hero-badge-row {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .casos-hero-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-electric-blue);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(0,102,255,0.3);
    border-radius: var(--radius-full);
    background: rgba(0,102,255,0.08);
    backdrop-filter: blur(8px);
  }

  .casos-hero-badge-outline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-gray-400);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-full);
    animation: badge-pulse 3s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .casos-hero-title {
    margin-bottom: var(--space-6);
  }

  .casos-hero-title-line {
    display: block;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-white);
  }

  .casos-hero-title-accent {
    background: linear-gradient(135deg, #0066ff 0%, #00c8ff 50%, #ff0064 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    display: inline-block;
    animation: title-glow 4s ease-in-out infinite;
  }

  @keyframes title-glow {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.3); }
  }

  .casos-hero-desc {
    font-size: clamp(var(--text-base), 1.3vw, var(--text-lg));
    color: var(--color-gray-300);
    max-width: 620px;
    line-height: 1.8;
    margin-bottom: var(--space-10);
    position: relative;
    padding-left: var(--space-5);
    border-left: 2px solid rgba(0,102,255,0.2);
  }

  .casos-hero-cta-row {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .casos-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, var(--color-electric-blue), #ff0064);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 25px rgba(0,102,255,0.3);
    animation: cta-pulse 3s ease-in-out infinite;
  }

  @keyframes cta-pulse {
    0%, 100% { box-shadow: 0 4px 25px rgba(0,102,255,0.3); }
    50% { box-shadow: 0 4px 40px rgba(255,0,100,0.4); }
  }

  .casos-hero-cta:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 8px 40px rgba(255,0,100,0.5); }
  .casos-hero-cta svg { transition: transform 0.3s ease; }
  .casos-hero-cta:hover svg { transform: translateX(4px); }

  .casos-hero-counter {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .casos-hero-counter-num {
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-electric-blue);
    line-height: 1;
    animation: counter-bounce 2s ease-in-out infinite;
  }

  @keyframes counter-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }

  .casos-hero-counter-label {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    font-weight: 500;
  }

  .casos-grid-section {
    padding: var(--space-20) 0;
    background-color: var(--bg-secondary);
  }

  .casos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .caso-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .caso-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0,102,255,0.2);
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  }

  .caso-card-image {
    position: relative;
    height: 200px;
    background-size: cover;
    background-position: center;
  }

  .caso-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(10,22,40,0.8) 100%);
  }

  .caso-card-industry {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-electric-blue);
    background: rgba(0,102,255,0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
  }

  .caso-card-body {
    padding: var(--space-5);
  }

  .caso-card-title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-3);
    color: var(--color-white);
  }

  .caso-card-desc {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .caso-card-impact {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding: var(--space-3);
    background: rgba(0,102,255,0.05);
    border: 1px solid rgba(0,102,255,0.1);
    border-radius: var(--radius-md);
  }

  .caso-impact-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-electric-blue);
  }

  .caso-impact-value {
    font-size: var(--text-base);
    font-weight: 800;
    color: var(--color-white);
  }

  .caso-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .caso-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-gray-400);
    padding: var(--space-1) var(--space-2);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-sm);
  }

  .casos-cta {
    position: relative;
    padding: var(--space-20) 0;
    text-align: center;
    overflow: hidden;
  }

  .casos-cta-bg {
    position: absolute;
    inset: 0;
  }

  .casos-cta-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.5) contrast(1.1);
  }

  .casos-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.7) 100%);
  }

  .casos-cta-content {
    position: relative;
    z-index: 1;
  }

  .casos-cta-title {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    margin-bottom: var(--space-8);
    color: var(--color-white);
  }

  .casos-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, var(--color-electric-blue), var(--color-electric-blue-hover));
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,102,255,0.3);
  }

  .casos-cta-btn:hover {
