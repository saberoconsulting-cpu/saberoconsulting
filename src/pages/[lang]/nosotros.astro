---
// ============================================
// SABERO Consulting - Nosotros Page (i18n)
// ============================================
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NosotrosHero from '../../components/sections/nosotros/NosotrosHero.astro';
import NosotrosStats from '../../components/sections/nosotros/NosotrosStats.astro';
import NosotrosStory from '../../components/sections/nosotros/NosotrosStory.astro';
import NosotrosMissionVision from '../../components/sections/nosotros/NosotrosMissionVision.astro';
import NosotrosValues from '../../components/sections/nosotros/NosotrosValues.astro';
import NosotrosTeam from '../../components/sections/nosotros/NosotrosTeam.astro';
import NosotrosApproach from '../../components/sections/nosotros/NosotrosApproach.astro';
import NosotrosCTA from '../../components/sections/nosotros/NosotrosCTA.astro';
export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'Nosotros',
    description: 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.',
  },
  en: {
    title: 'About us',
    description: 'SABERO Consulting is a software factory born in Peru, focused on building digital products and platforms for organizations with growth ambitions in America and Europe.',
  },
  pt: {
    title: 'Nos',
    description: 'A SABERO Consulting e uma fabrica de software nascida no Peru, focada em construir produtos e plataformas digitais para organizacoes com visao de crescimento na America e Europa.',
  },
  fr: {
    title: 'Nous',
    description: 'SABERO Consulting est une fabrique de logiciels nee au Perou, axee sur la construction de produits et plateformes numeriques pour les organisations ayant une vision de croissance en Amerique et en Europe.',
  },
};

const pageMeta = (meta[locale as string] || meta.es);
const path = '/nosotros';
---

<BaseLayout title={`SABERO Consulting - ${pageMeta.title}`} description={pageMeta.description} locale={locale as SupportedLocale} {path}>
  <NosotrosHero locale={locale} />
  <NosotrosStats locale={locale} />
  <NosotrosStory locale={locale} />
  <NosotrosMissionVision locale={locale} />
  <NosotrosValues locale={locale} />
  <NosotrosTeam locale={locale} />
  <NosotrosApproach locale={locale} />
  <NosotrosCTA locale={locale} />
</BaseLayout>
