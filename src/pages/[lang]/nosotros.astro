---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const content: Record<string, { title: string; description: string; heroL1: string; heroL2: string; mision: string; vision: string; stats: { number: string; label: string }[]; values: { title: string; desc: string }[]; approach: string[]; milestones: { year: string; title: string; desc: string }[]; team: { name: string; role: string; image: string; desc: string }[] }> = {
  es: {
    title: 'Nosotros',
    description: 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.',
    heroL1: 'Ingenieria de producto',
    heroL2: 'con ADN latinoamericano',
    mision: 'Convertir el talento latinoamericano en el motor de innovacion digital global. Disenamos, desarrollamos y evolucionamos plataformas que resuelven problemas reales de negocio, con la misma calidad, compromiso y excelencia que cualquier hub tecnologico del mundo.',
    vision: 'Ser el partner de referencia para empresas que buscan escalar sus productos digitales desde America hacia el mundo, reconociendo que el talento y la cercania cultural son ventajas competitivas invencibles.',
    stats: [
      { number: '2018', label: 'Fundacion' },
      { number: '+40', label: 'Profesionales' },
      { number: '+30', label: 'Proyectos entregados' },
      { number: '3', label: 'Continentes' },
    ],
    values: [
      { title: 'Excelencia tecnica', desc: 'Seleccionamos la tecnologia correcta para cada problema, sin modas ni sobreingenieria. Codigo limpio, arquitectura solida, decisiones con criterio.' },
      { title: 'Diseno orientado a negocio', desc: 'Cada decision tecnica responde a un objetivo de negocio medible. No construimos por construir: construimos para generar impacto real.' },
      { title: 'Relaciones de largo plazo', desc: 'Buscamos ser partners, no proveedores. Construimos relaciones que evolucionan con el tiempo, basadas en confianza y resultados.' },
      { title: 'Cercania cultural', desc: 'Nuestra ubicacion en Peru nos da ventaja de costo, talento y zona horaria. Operamos para America y Europa con comprension cultural unica.' },
    ],
    approach: [
      'Descubrimiento y estrategia: entendemos el negocio, el usuario y el contexto antes de escribir una linea de codigo.',
      'Arquitectura y diseno: definimos la columna vertebral tecnica del producto para que sea escalable, mantenible y segura.',
      'Desarrollo agil: trabajamos en ciclos cortos con equipos integrados, transparencia total y entregas continuas.',
      'Evolucion y mejora continua: medimos, aprendemos y evolucionamos el producto con cada iteracion.',
    ],
    milestones: [
      { year: '2018', title: 'Fundación', desc: 'Nacimos en Lima con la convicción de que el talento latinoamericano puede competir al más alto nivel global.' },
      { year: '2020', title: 'Crecimiento', desc: 'Proyectos más complejos, clientes en toda América. Plataformas que procesan pagos, conectan personas y automatizan operaciones.' },
      { year: '2022', title: 'Expansión global', desc: 'Llegamos a Europa, consolidando presencia en 3 continentes. Cada proyecto es una relación de largo plazo.' },
      { year: '2024', title: 'Presente', desc: '+40 profesionales, +30 proyectos, 3 continentes. Seguimos creciendo con la misma convicción.' },
    ],
    team: [
      { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
      { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
      { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4D03AQFDaf9Q-7vfog/profile-displayphoto-scale_400_400/B4DZrN63d8G8Ag-/0/1764391356417?e=1783555200&v=beta&t=hFOZJbv6QFSbBWbGVj6Zgn-fHNjnX9LTWlGzsc6uKac', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
    ],
  },
  en: {
    title: 'About us',
    description: 'SABERO Consulting is a software factory born in Peru, focused on building digital products and platforms for organizations with growth ambitions in America and Europe.',
    heroL1: 'Product engineering',
    heroL2: 'with Latin American DNA',
    mision: 'To turn Latin American talent into the engine of global digital innovation. We design, develop and evolve platforms that solve real business problems with the same quality, commitment and excellence as any world-class tech hub.',
    vision: 'To be the go-to partner for companies looking to scale their digital products from the Americas to the world.',
    stats: [
      { number: '2018', label: 'Founded' },
      { number: '+40', label: 'Professionals' },
      { number: '+30', label: 'Projects delivered' },
      { number: '3', label: 'Continents' },
    ],
    values: [
      { title: 'Technical excellence', desc: 'We select the right technology for each problem, without trends or overengineering. Clean code, solid architecture, decisions with criteria.' },
      { title: 'Business-driven design', desc: 'Every technical decision responds to a measurable business objective. We build to generate real impact.' },
      { title: 'Long-term relationships', desc: 'We seek to be partners, not vendors. Relationships that evolve over time, built on trust and results.' },
      { title: 'Cultural proximity', desc: 'Our location in Peru gives us cost, talent and timezone advantages. We operate for the Americas and Europe with unique cultural understanding.' },
    ],
    approach: [
      'Discovery and strategy: we understand the business, user and context before writing a line of code.',
      'Architecture and design: we define the technical backbone for scalability, maintainability and security.',
      'Agile development: short cycles, integrated teams, total transparency and continuous delivery.',
      'Continuous evolution: we measure, learn and evolve the product with each iteration.',
    ],
    milestones: [
      { year: '2018', title: 'Founded', desc: 'Born in Lima with the conviction that Latin American talent can compete at the highest global level.' },
      { year: '2020', title: 'Growth', desc: 'More complex projects, clients across the Americas. Platforms that process payments, connect people and automate operations.' },
      { year: '2022', title: 'Global expansion', desc: 'We reached Europe, consolidating presence across 3 continents. Every project is a long-term relationship.' },
      { year: '2024', title: 'Present', desc: '+40 professionals, +30 projects, 3 continents. Still growing with the same conviction.' },
    ],
    team: [
      { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
      { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
      { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4D03AQFDaf9Q-7vfog/profile-displayphoto-scale_400_400/B4DZrN63d8G8Ag-/0/1764391356417?e=1783555200&v=beta&t=hFOZJbv6QFSbBWbGVj6Zgn-fHNjnX9LTWlGzsc6uKac', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
    ],
  },
  pt: {
    title: 'Nos',
    description: 'A SABERO Consulting e uma fabrica de software nascida no Peru, focada em construir produtos e plataformas digitais para organizacoes com visao de crescimento na America e Europa.',
    heroL1: 'Engenharia de produto',
    heroL2: 'com DNA latino-americano',
    mision: 'Transformar o talento latino-americano no motor da inovacao digital global. Projetamos, desenvolvemos e evoluimos plataformas que resolvem problemas reais de negocios.',
    vision: 'Ser o parceiro de referencia para empresas que buscam escalar seus produtos digitais desde a America para o mundo.',
    stats: [
      { number: '2018', label: 'Fundacao' },
      { number: '+40', label: 'Profissionais' },
      { number: '+30', label: 'Projetos entregues' },
      { number: '3', label: 'Continentes' },
    ],
    values: [
      { title: 'Excelencia tecnica', desc: 'Selecionamos a tecnologia certa para cada problema, sem modismos. Codigo limpo, arquitetura solida, decisoes com criterio.' },
      { title: 'Design orientado a negocios', desc: 'Cada decisao tecnica responde a um objetivo mensuravel de negocio. Construimos para gerar impacto real.' },
      { title: 'Relacoes de longo prazo', desc: 'Somos parceiros, nao fornecedores. Relacoes que evoluem com o tempo, baseadas em confianca e resultados.' },
      { title: 'Proximidade cultural', desc: 'Nossa localizacao no Peru nos da vantagem de custo, talento e fuso horario. Operamos para America e Europa.' },
    ],
    approach: [
      'Descoberta e estrategia: entendemos o negocio antes de escrever codigo.',
      'Arquitetura e design: definimos a base tecnica para escalabilidade, manutencao e seguranca.',
      'Desenvolvimento agil: ciclos curtos, equipes integradas, transparencia total e entregas continuas.',
      'Evolucao continua: medimos, aprendemos e evoluimos o produto a cada iteracao.',
    ],
    milestones: [
      { year: '2018', title: 'Fundação', desc: 'Nascemos em Lima com a convicção de que o talento latino-americano pode competir no mais alto nível global.' },
      { year: '2020', title: 'Crescimento', desc: 'Projetos mais complexos, clientes em toda a América. Plataformas que processam pagamentos, conectam pessoas e automatizam operações.' },
      { year: '2022', title: 'Expansão global', desc: 'Chegamos à Europa, consolidando presença em 3 continentes. Cada projeto é uma relação de longo prazo.' },
      { year: '2024', title: 'Presente', desc: '+40 profissionais, +30 projetos, 3 continentes. Continuamos crescendo com a mesma convicção.' },
    ],
    team: [
      { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
      { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
      { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4D03AQFDaf9Q-7vfog/profile-displayphoto-scale_400_400/B4DZrN63d8G8Ag-/0/1764391356417?e=1783555200&v=beta&t=hFOZJbv6QFSbBWbGVj6Zgn-fHNjnX9LTWlGzsc6uKac', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
    ],
  },
  fr: {
    title: 'Nous',
    description: 'SABERO Consulting est une fabrique de logiciels nee au Perou, axee sur la construction de produits et plateformes numeriques pour les organisations ayant une vision de croissance en Amerique et en Europe.',
    heroL1: 'Ingenierie de produit',
    heroL2: 'avec ADN latino-americain',
    mision: 'Faire du talent latino-americain le moteur de l\'innovation numerique mondiale. Nous concevons, developpons et faisons evoluer des plateformes qui resolvent de veritables problemes commerciaux.',
    vision: 'Etre le partenaire de reference pour les entreprises qui cherchent a passer a l\'echelle leurs produits numeriques depuis l\'Amerique vers le monde.',
    stats: [
      { number: '2018', label: 'Fondee' },
      { number: '+40', label: 'Professionnels' },
      { number: '+30', label: 'Projets livrees' },
      { number: '3', label: 'Continents' },
    ],
    values: [
      { title: 'Excellence technique', desc: 'La bonne technologie pour chaque probleme. Code propre, architecture solide, decisions eclairees.' },
      { title: 'Design oriente metier', desc: 'Chaque decision technique repond a un objectif metier mesurable. Nous construisons pour generer un impact reel.' },
      { title: 'Relations a long terme', desc: 'Partenaires, pas fournisseurs. Des relations qui evoluent, basees sur la confiance et les resultats.' },
      { title: 'Proximite culturelle', desc: 'Notre localisation au Perou nous offre des avantages de cout, de talent et de fuseau horaire.' },
    ],
    approach: [
      'Decouverte et strategie: comprendre le metier avant d\'ecrire du code.',
      'Architecture et conception: definir la colonne vertebrale technique pour l\'evolutivite et la securite.',
      'Developpement agile: cycles courts, equipes integrees, transparence totale et livraisons continues.',
      'Evolution continue: mesurer, apprendre et faire evoluer le produit a chaque iteration.',
    ],
    milestones: [
      { year: '2018', title: 'Fondation', desc: 'Nés à Lima avec la conviction que le talent latino-américain peut concourir au plus haut niveau mondial.' },
      { year: '2020', title: 'Croissance', desc: 'Projets plus complexes, clients dans toute l\'Amérique. Plateformes qui traitent des paiements, connectent des personnes et automatisent des opérations.' },
      { year: '2022', title: 'Expansion globale', desc: 'Nous avons atteint l\'Europe, consolidant notre présence sur 3 continents. Chaque projet est une relation à long terme.' },
      { year: '2024', title: 'Présent', desc: '+40 professionnels, +30 projets, 3 continents. Nous continuons de grandir avec la même conviction.' },
    ],
    team: [
      { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
      { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
      { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4D03AQFDaf9Q-7vfog/profile-displayphoto-scale_400_400/B4DZrN63d8G8Ag-/0/1764391356417?e=1783555200&v=beta&t=hFOZJbv6QFSbBWbGVj6Zgn-fHNjnX9LTWlGzsc6uKac', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
    ],
  },
};

const pageMeta = (content[locale as string] || content.es);
const path = '/nosotros';
const isEs = locale === 'es';

const ui: Record<string, { storyLabel: string; storyTitle: string; valuesLabel: string; valuesTitle: string; approachLabel: string; approachTitle: string; cta: string; ctaSub: string; purpose: string; culture: string; quote: string; capabilities: string; teamLabel: string; teamTitle: string }> = {
  es: { storyLabel: 'Nuestra historia', storyTitle: 'De Lima para el mundo', valuesLabel: 'Nuestra cultura', valuesTitle: 'Valores que nos definen', approachLabel: 'Nuestra metodología', approachTitle: 'Cómo trabajamos', cta: 'Conversemos', ctaSub: 'Conversa con nuestro equipo y descubre cómo podemos impulsar tu próximo proyecto.', purpose: 'Nuestro propósito', culture: 'Nuestra cultura', quote: 'El talento latinoamericano puede competir al más alto nivel global.', capabilities: 'Ver capacidades', teamLabel: 'Fundadores', teamTitle: 'Fundadores' },
  en: { storyLabel: 'Our story', storyTitle: 'From Lima to the world', valuesLabel: 'Our culture', valuesTitle: 'Values that define us', approachLabel: 'Our methodology', approachTitle: 'How we work', cta: "Let's talk", ctaSub: 'Talk to our team and discover how we can power your next project.', purpose: 'Our purpose', culture: 'Our culture', quote: 'Latin American talent can compete at the highest global level.', capabilities: 'View capabilities', teamLabel: 'Founders', teamTitle: 'Founders' },
  pt: { storyLabel: 'Nossa história', storyTitle: 'De Lima para o mundo', valuesLabel: 'Nossa cultura', valuesTitle: 'Valores que nos definem', approachLabel: 'Nossa metodologia', approachTitle: 'Como trabalhamos', cta: 'Vamos conversar', ctaSub: 'Converse com nossa equipe e descubra como podemos impulsionar seu próximo projeto.', purpose: 'Nosso propósito', culture: 'Nossa cultura', quote: 'O talento latino-americano pode competir no mais alto nível global.', capabilities: 'Ver capacidades', teamLabel: 'Fundadores', teamTitle: 'Fundadores' },
  fr: { storyLabel: 'Notre histoire', storyTitle: 'De Lima au monde', valuesLabel: 'Notre culture', valuesTitle: 'Nos valeurs', approachLabel: 'Notre méthodologie', approachTitle: 'Comment nous travaillons', cta: 'Parlons-en', ctaSub: 'Parlez à notre équipe et découvrez comment nous pouvons propulser votre prochain projet.', purpose: 'Notre objectif', culture: 'Notre culture', quote: 'Le talent latino-américain peut concourir au plus haut niveau mondial.', capabilities: 'Voir nos capacités', teamLabel: 'Fondateurs', teamTitle: 'Fondateurs' },
};
const labels = ui[locale as string] || ui.es;
const heroTitle = pageMeta.heroL1;
const heroAccent = pageMeta.heroL2;
---

<BaseLayout title={`SABERO Consulting - ${pageMeta.title}`} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <!-- HERO -->
  <section class="ns-hero">
    <div class="ns-hero-inner">
      <div class="ns-hero-col ns-hero-col--text">
        <span class="ns-hero-overline">SABERO CONSULTING</span>
        <h1 class="ns-hero-heading">
          {heroTitle}
          <span class="ns-hero-accent">{heroAccent}</span>
        </h1>
        <p class="ns-hero-desc">{pageMeta.description}</p>
        <div class="ns-hero-actions">
          <a href={isEs ? '/contacto' : `/${locale}/contacto`} class="ns-hero-btn ns-hero-btn--primary">
            {labels.cta}
          </a>
          <a href="#historia" class="ns-hero-btn ns-hero-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            {labels.storyLabel}
          </a>
        </div>
      </div>
      <div class="ns-hero-col ns-hero-col--visual">
        <div class="ns-hero-blob ns-hero-blob--a"></div>
        <div class="ns-hero-blob ns-hero-blob--b"></div>
        <svg width="0" height="0" style="position:absolute" aria-hidden="true">
          <defs>
            <clipPath id="ns-blob-clip" clipPathUnits="objectBoundingBox">
              <path d="M0.5,0.04 C0.78,0.02 0.98,0.16 0.98,0.42 C0.98,0.6 0.93,0.7 0.96,0.86 C0.99,1.0 0.86,1.0 0.74,0.98 C0.5,1.02 0.3,1.0 0.16,0.94 C0.02,0.88 0.0,0.7 0.02,0.5 C0.04,0.28 0.02,0.1 0.22,0.04 C0.32,0.0 0.4,0.06 0.5,0.04 Z" />
            </clipPath>
          </defs>
        </svg>
        <div class="ns-hero-image-wrap">
          <div class="ns-hero-image-clip">
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=900&q=80" alt="" loading="eager" />
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--top">
          <div class="ns-hero-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="ns-hero-card-text">
            <span class="ns-hero-card-title">Sprint #24</span>
            <span class="ns-hero-card-sub">Deploy exitoso</span>
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--bottom">
          <div class="ns-hero-card-dot"></div>
          <div class="ns-hero-card-lines">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="ns-hero-pill">+30 proyectos</div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="ns-stats" data-reveal>
    <div class="container">
      <div class="ns-stats-grid">
        {pageMeta.stats.map((s) => (
          <div class="ns-stat">
            <span class="ns-stat-num">{s.number}</span>
            <span class="ns-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STORY -->
  <section class="ns-story" id="historia" data-reveal>
    <div class="container">
      <div class="ns-story-header">
        <div class="ns-story-tag">{labels.storyLabel}</div>
        <h2 class="ns-story-title">{labels.storyTitle}</h2>
      </div>
      <div class="ns-story-body">
        <div class="ns-story-timeline">
          <div class="ns-story-line"></div>
          {pageMeta.milestones.map((m: { year: string; title: string; desc: string }, i: number) => (
            <div class="ns-story-milestone" data-img={i}>
              <div class="ns-story-milestone-dot"></div>
              <div class="ns-story-milestone-year">{m.year}</div>
              <h3 class="ns-story-milestone-title">{m.title}</h3>
              <p class="ns-story-milestone-desc">{m.desc}</p>
            </div>
          ))}
          <div class="ns-story-quote">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p>{labels.quote}</p>
          </div>
        </div>
        <div class="ns-story-visual">
          <div class="ns-story-img-frame">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
            <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
