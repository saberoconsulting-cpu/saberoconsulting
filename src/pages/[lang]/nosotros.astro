---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNosotrosData } from '../../data/nosotros/index';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const data = getNosotrosData(locale as SupportedLocale);

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'Nosotros',
    description: 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.',
  },
  en: {
    title: 'About us',
    description: 'SABERO Consulting is a software factory born in Peru, focused on building digital products and platforms for organizations with growth ambitions in America and Europe.',
  },
  pt: {
    title: 'Nos',
    description: 'A SABERO Consulting e uma fabrica de software nascida no Peru, focada em construir produtos e plataformas digitais para organizacoes com visao de crescimento na America e Europa.',
  },
  fr: {
    title: 'Nous',
    description: 'SABERO Consulting est une fabrique de logiciels nee au Perou, axee sur la construction de produits et plateformes numeriques pour les organisations ayant une vision de croissance en Amerique et en Europe.',
  },
};

const pageMeta = (meta[locale as string] || meta.es);
const path = '/nosotros';
const isEs = locale === 'es';

const ui: Record<string, { storyLabel: string; storyTitle: string; valuesLabel: string; valuesTitle: string; approachLabel: string; approachTitle: string; cta: string; ctaSub: string; purpose: string; culture: string; quote: string; capabilities: string; teamLabel: string; teamTitle: string }> = {
  es: { storyLabel: 'Nuestra historia', storyTitle: 'De Lima para el mundo', valuesLabel: 'Nuestra cultura', valuesTitle: 'Valores que nos definen', approachLabel: 'Nuestra metodología', approachTitle: 'Cómo trabajamos', cta: 'Conversemos', ctaSub: 'Conversa con nuestro equipo y descubre cómo podemos impulsar tu próximo proyecto.', purpose: 'Nuestro propósito', culture: 'Nuestra cultura', quote: 'El talento latinoamericano puede competir al más alto nivel global.', capabilities: 'Ver capacidades', teamLabel: 'Fundadores', teamTitle: 'Fundadores' },
  en: { storyLabel: 'Our story', storyTitle: 'From Lima to the world', valuesLabel: 'Our culture', valuesTitle: 'Values that define us', approachLabel: 'Our methodology', approachTitle: 'How we work', cta: "Let's talk", ctaSub: 'Talk to our team and discover how we can power your next project.', purpose: 'Our purpose', culture: 'Our culture', quote: 'Latin American talent can compete at the highest global level.', capabilities: 'View capabilities', teamLabel: 'Founders', teamTitle: 'Founders' },
  pt: { storyLabel: 'Nossa história', storyTitle: 'De Lima para o mundo', valuesLabel: 'Nossa cultura', valuesTitle: 'Valores que nos definem', approachLabel: 'Nossa metodologia', approachTitle: 'Como trabalhamos', cta: 'Vamos conversar', ctaSub: 'Converse com nossa equipe e descubra como podemos impulsionar seu próximo projeto.', purpose: 'Nosso propósito', culture: 'Nossa cultura', quote: 'O talento latino-americano pode competir no mais alto nível global.', capabilities: 'Ver capacidades', teamLabel: 'Fundadores', teamTitle: 'Fundadores' },
  fr: { storyLabel: 'Notre histoire', storyTitle: 'De Lima au monde', valuesLabel: 'Notre culture', valuesTitle: 'Nos valeurs', approachLabel: 'Notre méthodologie', approachTitle: 'Comment nous travaillons', cta: 'Parlons-en', ctaSub: 'Parlez à notre équipe et découvrez comment nous pouvons propulser votre prochain projet.', purpose: 'Notre objectif', culture: 'Notre culture', quote: 'Le talent latino-américain peut concourir au plus haut niveau mondial.', capabilities: 'Voir nos capacités', teamLabel: 'Fondateurs', teamTitle: 'Fondateurs' },
};
const labels = ui[locale as string] || ui.es;
const heroTitle = data.intro.titulo;
const heroAccent = data.intro.microcopy;
---

<BaseLayout title={`SABERO Consulting - ${pageMeta.title}`} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <!-- HERO -->
  <section class="ns-hero">
    <div class="ns-hero-inner">
      <div class="ns-hero-col ns-hero-col--text">
        <span class="ns-hero-overline">SABERO CONSULTING</span>
        <h1 class="ns-hero-heading">
          {heroTitle}
          <span class="ns-hero-accent">{heroAccent}</span>
        </h1>
        <p class="ns-hero-desc">{pageMeta.description}</p>
        <div class="ns-hero-actions">
          <a href={isEs ? '/contacto' : `/${locale}/contacto`} class="ns-hero-btn ns-hero-btn--primary">
            {labels.cta}
          </a>
          <a href="#historia" class="ns-hero-btn ns-hero-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            {labels.storyLabel}
          </a>
        </div>
      </div>
      <div class="ns-hero-col ns-hero-col--visual">
        <div class="ns-hero-blob ns-hero-blob--a"></div>
        <div class="ns-hero-blob ns-hero-blob--b"></div>
        <svg width="0" height="0" style="position:absolute" aria-hidden="true">
          <defs>
            <clipPath id="ns-blob-clip" clipPathUnits="objectBoundingBox">
              <path d="M0.5,0.04 C0.78,0.02 0.98,0.16 0.98,0.42 C0.98,0.6 0.93,0.7 0.96,0.86 C0.99,1.0 0.86,1.0 0.74,0.98 C0.5,1.02 0.3,1.0 0.16,0.94 C0.02,0.88 0.0,0.7 0.02,0.5 C0.04,0.28 0.02,0.1 0.22,0.04 C0.32,0.0 0.4,0.06 0.5,0.04 Z" />
            </clipPath>
          </defs>
        </svg>
        <div class="ns-hero-image-wrap">
          <div class="ns-hero-image-clip">
            <img src="/images/nosotros-hero.jpg" alt="" loading="eager" />
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--top">
          <div class="ns-hero-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="ns-hero-card-text">
            <span class="ns-hero-card-title">Sprint #24</span>
            <span class="ns-hero-card-sub">Deploy exitoso</span>
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--bottom">
          <div class="ns-hero-card-dot"></div>
          <div class="ns-hero-card-lines">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="ns-hero-pill">+30 proyectos</div>
      </div>
    </div>
  </section>

  <!-- STORY / IDENTIDAD -->
  <section class="ns-story" id="historia" data-reveal>
    <div class="container">
      <div class="ns-story-header">
        <div class="ns-story-tag">{labels.storyLabel}</div>
        <h2 class="ns-story-title">{labels.storyTitle}</h2>
      </div>
      <div class="ns-story-body">
        <div class="ns-story-timeline">
          <div class="ns-story-line"></div>
          {data.identidad.map((item, i) => (
            <div class="ns-story-milestone" data-img={i}>
              <div class="ns-story-milestone-dot"></div>
              <div class="ns-story-milestone-year">{item.titulo}</div>
              <h3 class="ns-story-milestone-title">{item.titulo}</h3>
              <p class="ns-story-milestone-desc">{item.contenido}</p>
            </div>
          ))}
          <div class="ns-story-quote">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p>{labels.quote}</p>
          </div>
        </div>
        <div class="ns-story-visual">
          <div class="ns-story-img-frame">
            <img src="/images/nosotros-1.jpg" alt="" loading="lazy" />
            <img src="/images/nosotros-2.jpg" alt="" loading="lazy" />
            <img src="/images/nosotros-3.jpg" alt="" loading="lazy" />
            <img src="/images/nosotros-4.jpg" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION / VISION from intro -->
  <section class="ns-mv" id="mision-vision" data-reveal>
    <div class="container">
      <div class="ns-mv-header">
        <div class="ns-mv-tag">{labels.purpose}</div>
        <h2 class="ns-mv-title">Mission & Vision</h2>
      </div>
      <div class="ns-mv-grid">
        <div class="ns-mv-card">
          <div class="ns-mv-accent"></div>
          <div class="ns-mv-body">
            <h3 class="ns-mv-cardtitle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              {locale === 'es' ? 'Misión' : locale === 'en' ? 'Mission' : locale === 'pt' ? 'Missão' : 'Mission'}
            </h3>
            <p>{data.intro.texto}</p>
          </div>
        </div>
        <div class="ns-mv-card ns-mv-card--dark">
          <div class="ns-mv-accent"></div>
          <div class="ns-mv-body">
            <h3 class="ns-mv-cardtitle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              {locale === 'es' ? 'Visión' : locale === 'en' ? 'Vision' : locale === 'pt' ? 'Visão' : 'Vision'}
            </h3>
            <p>{data.identidad.length > 1 ? data.identidad[1].contenido : data.intro.texto}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES / CULTURA -->
  <section class="ns-vals" id="valores" data-reveal>
    <div class="container">
      <div class="ns-vals-header">
        <div class="ns-vals-tag">{labels.culture}</div>
        <h2 class="ns-vals-title">{labels.valuesTitle}</h2>
        <p class="ns-vals-sub">{locale === 'es' ? 'Principios que guían cada decisión, cada línea de código y cada relación con nuestros clientes.' : locale === 'en' ? 'Principles that guide every decision, every line of code, and every relationship with our clients.' : locale === 'pt' ? 'Princípios que guiam cada decisão, cada linha de código e cada relação com nossos clientes.' : 'Principes qui guident chaque décision, chaque ligne de code et chaque relation avec nos clients.'}</p>
      </div>
      <div class="ns-vals-grid">
        {data.cultura.map((v, i) => (
          <article class="ns-val">
            <span class="ns-val-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="ns-val-bar"></div>
            <div class="ns-val-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                {i === 0 && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                {i === 1 && <><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></>}
                {i === 2 && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
              </svg>
            </div>
            <div class="ns-val-body">
              <h3 class="ns-val-title">{v.titulo}</h3>
              <p class="ns-val-desc">{v.contenido}</p>
              {v.items && v.items.length > 0 && (
                <ul class="ns-val-items">
                  {v.items.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH / ENFOQUE -->
  <section class="ns-app" id="enfoque" data-reveal>
    <div class="container">
      <div class="ns-app-header">
        <div class="ns-app-tag">{labels.approachLabel}</div>
        <h2 class="ns-app-title">{labels.approachTitle}</h2>
      </div>
      <div class="ns-app-steps">
        {data.enfoque.map((step, i) => (
          <div class="ns-app-step" data-idx={i + 1}>
            <div class="ns-app-step-top">
              <div class="ns-app-circle">{i + 1}</div>
              {i < data.enfoque.length - 1 && <div class="ns-app-connector"></div>}
            </div>
            <p class="ns-app-text">{step.contenido}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ns-cta" data-reveal>
    <div class="ns-cta-glow"></div>
    <div class="container">
      <h2 class="ns-cta-title">{locale === 'es' ? 'Construyamos algo grande juntos' : locale === 'en' ? "Let's build something great together" : locale === 'pt' ? 'Vamos construir algo grande juntos' : 'Construisons quelque chose de grand ensemble'}</h2>
      <p class="ns-cta-p">{labels.ctaSub}</p>
      <div class="ns-cta-actions">
        <a href={isEs ? '/contacto' : `/${locale}/contacto`} class="ns-cta-btn">
          {labels.cta}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href={isEs ? '/#oferta' : `/${locale}/#oferta`} class="ns-cta-btn ns-cta-btn--b">
          {labels.capabilities}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
<noscript><style>.js [data-reveal]{opacity:1!important;transform:none!important}.js [data-reveal] *{opacity:1!important;transform:none!important}</style></noscript>
<script>
  document.documentElement.classList.add('js');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
</script>

<style is:global>
  /* ----- HERO ----- */
  .ns-hero {
    padding: 14px 0 0;
    background: var(--color-off-white);
    position: relative;
    overflow: hidden;
  }
  .ns-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6) 64px;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .ns-hero-col--text {
    display: flex;
    flex-direction: column;
  }
  .ns-hero-overline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    margin-bottom: 18px;
  }
  .ns-hero-heading {
    font-family: var(--font-primary);
    font-size: clamp(2.4rem, 4.8vw, 4rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-gray-900);
    margin: 0 0 22px;
  }
  .ns-hero-accent {
    color: var(--color-gray-900);
    display: block;
  }
  .ns-hero-desc {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-gray-500);
    max-width: 480px;
    margin: 0 0 36px;
  }
  .ns-hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
  }
  .ns-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-primary);
    text-decoration: none;
    line-height: 1;
    transition: all var(--transition-base);
  }
  .ns-hero-btn--primary {
    padding: 17px 34px;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 16px rgba(0, 102, 255, 0.3);
  }
  .ns-hero-btn--primary:hover {
    background: var(--color-electric-blue-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 102, 255, 0.38);
  }
  .ns-hero-btn--ghost {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-600);
  }
  .ns-hero-btn--ghost svg {
    color: var(--color-electric-blue);
  }
  .ns-hero-btn--ghost:hover {
    color: var(--color-electric-blue);
  }

  .ns-hero-col--visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 460px;
  }
  .ns-hero-blob {
    position: absolute;
    border-radius: 45% 55% 60% 40% / 50% 40% 60% 50%;
    filter: blur(2px);
    animation: ns-blob 14s ease-in-out infinite alternate;
  }
  .ns-hero-blob--a {
    width: 78%;
    height: 78%;
    top: 4%;
    left: 2%;
    background: linear-gradient(135deg, var(--color-electric-blue) 0%, var(--color-electric-blue-light) 100%);
    opacity: 0.9;
    z-index: 0;
  }
  .ns-hero-blob--b {
    width: 46%;
    height: 46%;
    bottom: 2%;
    right: 6%;
    background: linear-gradient(135deg, var(--color-red) 0%, rgba(230, 57, 70, 0.25) 100%);
    opacity: 0.85;
    z-index: 0;
    animation-delay: -4s;
  }
  @keyframes ns-blob {
    0% { border-radius: 45% 55% 60% 40% / 50% 40% 60% 50%; transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { border-radius: 55% 45% 40% 60% / 40% 55% 45% 60%; transform: translate(8px, -10px) scale(1.04) rotate(3deg); }
    100% { border-radius: 40% 60% 50% 50% / 60% 40% 50% 50%; transform: translate(-6px, 6px) scale(0.97) rotate(-2deg); }
  }
  .ns-hero-image-wrap {
    position: relative;
    z-index: 1;
    width: 74%;
    aspect-ratio: 3 / 4;
  }
  .ns-hero-image-clip {
    width: 100%;
    height: 100%;
    clip-path: url(#ns-blob-clip);
    filter: drop-shadow(0 30px 50px rgba(10, 22, 40, 0.22));
    animation: ns-image-breathe 14s ease-in-out infinite alternate;
  }
  .ns-hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-mask-image: radial-gradient(ellipse 78% 80% at 50% 48%, #000 62%, transparent 100%);
    mask-image: radial-gradient(ellipse 78% 80% at 50% 48%, #000 62%, transparent 100%);
  }
  @keyframes ns-image-breathe {
    0% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.02) rotate(0.6deg); }
    100% { transform: scale(0.99) rotate(-0.5deg); }
  }
  .ns-hero-card {
    position: absolute;
    z-index: 2;
    background: var(--bg-elevated, var(--color-white));
    border: 1px solid var(--border-color, var(--color-gray-100));
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ns-hero-card--top {
    top: 8%;
    right: -4%;
    padding: 14px 18px;
  }
  .ns-hero-card-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-electric-blue-light);
    color: var(--color-electric-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ns-hero-card-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ns-hero-card-title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-gray-900);
  }
  .ns-hero-card-sub {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-gray-400);
  }
  .ns-hero-card--bottom {
    bottom: 6%;
    left: -6%;
    padding: 16px 20px;
  }
  .ns-hero-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-red);
    flex-shrink: 0;
  }
  .ns-hero-card-lines {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .ns-hero-card-lines span {
    display: block;
    height: 4px;
    border-radius: 2px;
    background: var(--color-gray-100);
  }
  .ns-hero-card-lines span:nth-child(1) { width: 56px; }
  .ns-hero-card-lines span:nth-child(2) { width: 38px; }
  .ns-hero-card-lines span:nth-child(3) { width: 46px; }
  .ns-hero-pill {
    position: absolute;
    top: 2%;
    left: 0%;
    z-index: 2;
    background: var(--color-deep-blue);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.3px;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    box-shadow: 0 8px 20px rgba(10, 22, 40, 0.25);
  }

  @media (max-width: 900px) {
    .ns-hero { padding: 110px 0 0; }
    .ns-hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .ns-hero-col--visual { min-height: 380px; }
    .ns-hero-image-wrap { width: 60%; }
    .ns-hero-pill { left: 2%; }
  }
  @media (max-width: 640px) {
    .ns-hero { padding: 96px 0 0; }
    .ns-hero-heading { font-size: 2rem; }
    .ns-hero-col--visual { min-height: 320px; }
    .ns-hero-image-wrap { width: 70%; }
    .ns-hero-card--top { right: 0; }
    .ns-hero-card--bottom { left: 0; }
  }

  /* ----- STORY ----- */
  .ns-story {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }
  .ns-story-header {
    text-align: center;
    margin-bottom: 36px;
  }
  .ns-story-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }
  .ns-story-header .ns-story-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .ns-story-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Timeline */
  .ns-story-timeline {
    position: relative;
    padding-left: 40px;
  }
  .ns-story-line {
    position: absolute;
    left: 15px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, var(--color-electric-blue), var(--color-electric-blue-light) 60%, transparent);
    border-radius: 1px;
  }
  .ns-story-milestone {
    position: relative;
    padding-bottom: 20px;
  }
  .ns-story-milestone:last-of-type {
    padding-bottom: 0;
  }
  .ns-story-milestone-dot {
    position: absolute;
    left: -40px;
    top: 4px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-white);
    border: 2.5px solid var(--color-electric-blue);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
    box-shadow: 0 0 0 0 rgba(0, 102, 255, 0.15);
  }
  .ns-story-milestone-dot::after {
    content: '';
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-electric-blue);
  }
  .ns-story-milestone:hover .ns-story-milestone-dot {
    box-shadow: 0 0 0 6px rgba(0, 102, 255, 0.15);
    transform: scale(1.08);
  }
  .ns-story-milestone-year {
    font-size: var(--text-xs);
    font-weight: 800;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 2px;
  }
  .ns-story-milestone-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-deep-blue);
    margin: 0 0 6px;
  }
  .ns-story-milestone-desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: 1.7;
    margin: 0;
  }

  /* Quote */
  .ns-story-quote {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-electric-blue-light);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-electric-blue);
  }
  .ns-story-quote svg {
    color: var(--color-electric-blue);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .ns-story-quote p {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-deep-blue);
    margin: 0;
    font-style: italic;
  }

  /* Image */
  .ns-story-visual {
    position: relative;
    top: 8px;
    display: flex;
    justify-content: center;
  }
  .ns-story-img-frame {
    position: relative;
    z-index: 1;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    aspect-ratio: 4 / 5;
    max-width: 360px;
  }
  .ns-story-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.45s ease, transform 0.5s ease;
  }
  .ns-story-img-frame img:first-child {
    position: relative;
    opacity: 1;
  }
  .ns-story-img-frame:hover img {
    transform: scale(1.04);
  }

  /* Carousel: show image matching hovered milestone */
  .ns-story-body:not(:has(.ns-story-milestone:hover)) .ns-story-img