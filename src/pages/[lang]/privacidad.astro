---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: { title: 'Politica de privacidad - SABERO Consulting', description: 'Politica de privacidad y tratamiento de datos personales de SABERO Consulting.' },
  en: { title: 'Privacy Policy - SABERO Consulting', description: 'Privacy policy and personal data processing of SABERO Consulting.' },
  pt: { title: 'Politica de privacidade - SABERO Consulting', description: 'Politica de privacidade e tratamento de dados pessoais da SABERO Consulting.' },
  fr: { title: 'Politique de confidentialite - SABERO Consulting', description: 'Politique de confidentialite et traitement des donnees personnelles de SABERO Consulting.' },
};

const pageMeta = meta[locale as string] || meta.es;
const path = '/privacidad';
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <section class="page-header section">
    <div class="container">
      <h1>{locale === 'es' ? 'Politica de privacidad' : locale === 'en' ? 'Privacy Policy' : locale === 'pt' ? 'Politica de privacidade' : 'Politique de confidentialite'}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container content-page">
      <p class="text-tertiary">{locale === 'es' ? 'Proximamente: politica de privacidad completa.' : locale === 'en' ? 'Coming soon: complete privacy policy.' : locale === 'pt' ? 'Em breve: politica de privacidade completa.' : 'Prochainement: politique de confidentialite complete.'}</p>
    </div>
  </section>
</BaseLayout>
