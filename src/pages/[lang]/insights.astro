---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getInsightsData } from '../../data/insights';
import InsightsHero from '../../components/sections/insights/InsightsHero.astro';
import InsightsCTA from '../../components/sections/insights/InsightsCTA.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: { title: 'Insights - SABERO Consulting', description: 'Contenidos para lideres de negocio y equipos que buscan entender producto digital, automatizacion, escalabilidad y evolucion tecnologica.' },
  en: { title: 'Insights - SABERO Consulting', description: 'Content for business leaders and teams looking to understand digital product, automation, scalability and technology evolution.' },
  pt: { title: 'Insights - SABERO Consulting', description: 'Conteudo para lideres de negocios e equipes que buscam entender produto digital, automacao, escalabilidade e evolucao tecnologica.' },
  fr: { title: 'Insights - SABERO Consulting', description: 'Contenus pour les dirigeants et les equipes qui cherchent a comprendre le produit numerique, l\'automatisation, l\'evolutivite et l\'evolution technologique.' },
};

const pageMeta = meta[locale as string] || meta.es;
const path = `/${locale}/insights`;
const data = getInsightsData(locale as string);

const sections: Record<string, { id: string; label: string; type: string }[]> = {
  es: [
    { id: 'articles', label: 'Articulos', type: 'article' },
    { id: 'guides', label: 'Guias', type: 'guide' },
    { id: 'trends', label: 'Tendencias', type: 'trend' },
    { id: 'cases', label: 'Casos comentados', type: 'case' },
    { id: 'resources', label: 'Recursos descargables', type: 'resource' },
  ],
  en: [
    { id: 'articles', label: 'Articles', type: 'article' },
    { id: 'guides', label: 'Guides', type: 'guide' },
    { id: 'trends', label: 'Trends', type: 'trend' },
    { id: 'cases', label: 'Case studies', type: 'case' },
    { id: 'resources', label: 'Resources', type: 'resource' },
  ],
  pt: [
    { id: 'articles', label: 'Artigos', type: 'article' },
    { id: 'guides', label: 'Guias', type: 'guide' },
    { id: 'trends', label: 'Tendencias', type: 'trend' },
    { id: 'cases', label: 'Casos comentados', type: 'case' },
    { id: 'resources', label: 'Recursos', type: 'resource' },
  ],
  fr: [
    { id: 'articles', label: 'Articles', type: 'article' },
    { id: 'guides', label: 'Guides', type: 'guide' },
    { id: 'trends', label: 'Tendances', type: 'trend' },
    { id: 'cases', label: 'Etudes de cas', type: 'case' },
    { id: 'resources', label: 'Ressources', type: 'resource' },
  ],
};

const labels: Record<string, { problem: string; approach: string; lesson: string; recommendation: string }> = {
  es: { problem: 'Problema', approach: 'Enfoque', lesson: 'Aprendizaje', recommendation: 'Recomendacion' },
  en: { problem: 'Problem', approach: 'Approach', lesson: 'Lesson', recommendation: 'Recommendation' },
  pt: { problem: 'Problema', approach: 'Abordagem', lesson: 'Aprendizado', recommendation: 'Recomendacao' },
  fr: { problem: 'Probleme', approach: 'Approche', lesson: 'Lecon', recommendation: 'Recommandation' },
};

const currentSections = sections[locale as string] || sections.es;
const currentLabels = labels[locale as string] || labels.es;

const articles = data.articles;
const guides = data.featured.filter((i) => i.type === 'guide');
const trends = data.trends;
const cases = data.cases;
const resources = data.resources;
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <InsightsHero data={data.hero} locale={locale} />

  <section class="insights-tabs section" aria-label="Content sections">
    <div class="container">
      <nav class="tabs-nav" role="tablist" aria-label="Content categories">
        {currentSections.map((sec) => (
          <button
            class="tab-btn"
            role="tab"
            aria-selected={sec.id === 'articles'}
            aria-controls={`panel-${sec.id}`}
            data-tab={sec.id}
          >
            {sec.label}
          </button>
        ))}
      </nav>

      <div class="tabs-content">
        <!-- Articles -->
        <div class="tab-panel active" id="panel-articles" role="tabpanel" data-panel="articles">
          <div class="articles-grid">
            {articles.map((article) => (
              <article class="content-card">
                <span class="card-badge">{article.category}</span>
                <h3 class="card-title">{article.title}</h3>
                <p class="card-summary">{article.summary}</p>
                <div class="card-footer">
                  <span class="card-readtime">{article.readTime}</span>
                  <a href={article.href || '#'} class="card-cta" target={article.href?.startsWith('http') ? '_blank' : undefined} rel={article.href?.startsWith('http') ? 'noopener noreferrer' : undefined}>{article.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Guides -->
        <div class="tab-panel" id="panel-guides" role="tabpanel" data-panel="guides">
          <div class="articles-grid">
            {guides.map((guide) => (
              <article class="content-card">
                <span class="card-badge">{guide.category}</span>
                <h3 class="card-title">{guide.title}</h3>
                <p class="card-summary">{guide.summary}</p>
                <div class="card-footer">
                  <span class="card-readtime">{guide.readTime}</span>
                  <a href="#" class="card-cta">{guide.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Trends -->
        <div class="tab-panel" id="panel-trends" role="tabpanel" data-panel="trends">
          <div class="trends-grid">
            {trends.map((trend) => (
              <article class="trend-card">
                <h3 class="trend-title">{trend.title}</h3>
                <p class="trend-summary">{trend.summary}</p>
                <p class="trend-impact">{trend.impact}</p>
              </article>
            ))}
          </div>
        </div>

        <!-- Cases -->
        <div class="tab-panel" id="panel-cases" role="tabpanel" data-panel="cases">
          <div class="cases-list">
            {cases.map((c) => (
              <article class="case-card">
                <h3 class="case-title">{c.title}</h3>
                <div class="case-details">
                  <div class="case-block">
                    <span class="case-label">{currentLabels.problem}</span>
                    <p class="case-text">{c.problem}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{currentLabels.approach}</span>
                    <p class="case-text">{c.approach}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{currentLabels.lesson}</span>
                    <p class="case-text">{c.lesson}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{currentLabels.recommendation}</span>
                    <p class="case-text case-recommendation">{c.recommendation}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Resources -->
        <div class="tab-panel" id="panel-resources" role="tabpanel" data-panel="resources">
          <div class="resources-grid">
            {resources.map((resource) => (
              <article class="resource-card">
                <div class="resource-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                  </svg>
                </div>
                <h3 class="resource-title">{resource.title}</h3>
                <p class="resource-summary">{resource.summary}</p>
                <div class="resource-footer">
                  <span class="resource-format">{resource.format}</span>
                  <a href={resource.href || '#'} class="resource-cta" target={resource.href?.startsWith('http') ? '_blank' : undefined} rel={resource.href?.startsWith('http') ? 'noopener noreferrer' : undefined}>{resource.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <InsightsCTA data={data.cta} locale={locale} />
</BaseLayout>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function () {
    var tabs = document.querySelectorAll('[data-tab]');
    var panels = document.querySelectorAll('[data-panel]');

    function activateTab(tabId) {
      for (var i = 0; i < tabs.length; i++) {
        var t = tabs[i];
        var isActive = t.getAttribute('data-tab') === tabId;
        if (isActive) {
          t.classList.add('active');
          t.setAttribute('aria-selected', 'true');
        } else {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        }
      }
      for (var j = 0; j < panels.length; j++) {
        var p = panels[j];
        if (p.getAttribute('data-panel') === tabId) {
          p.classList.add('active');
        } else {
          p.classList.remove('active');
        }
      }
    }

    for (var k = 0; k < tabs.length; k++) {
      tabs[k].addEventListener('click', function () {
        var tabId = this.getAttribute('data-tab');
        if (tabId) {
          activateTab(tabId);
        }
      });
    }
  });
</script>

<style>
  .insights-tabs {
    background-color: var(--color-white);
    padding: 48px 0 80px;
  }

  .tabs-nav {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 40px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tab-btn {
    padding: 12px 24px;
    border: none;
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-tertiary);
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all var(--transition-base);
    font-family: var(--font-primary);
  }

  .tab-btn:hover {
    color: var(--color-electric-blue);
  }

  .tab-btn.active {
    color: var(--color-deep-blue);
    border-bottom-color: var(--color-electric-blue);
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .content-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .content-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-red) 0%, var(--color-deep-blue) 50%, var(--color-electric-blue) 100%);
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .content-card:hover::before {
    opacity: 1;
  }

  .content-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-gray-200);
  }

  .card-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-electric-blue);
    background: rgba(0, 102, 255, 0.06);
    padding: 3px 10px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
    align-self: flex-start;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
  }

  .card-readtime {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .card-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-electric-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .card-cta:hover {
    color: var(--color-red);
  }

  .trends-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .trend-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .trend-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-red) 0%, var(--color-deep-blue) 50%, var(--color-electric-blue) 100%);
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .trend-card:hover::before {
    opacity: 1;
  }

  .trend-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .trend-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .trend-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .trend-impact {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-electric-blue);
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
  }

  .cases-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .case-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    transition: box-shadow var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .case-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-red) 0%, var(--color-deep-blue) 50%, var(--color-electric-blue) 100%);
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .case-card:hover::before {
    opacity: 1;
  }

  .case-card:hover {
    box-shadow: var(--shadow-md);
  }

  .case-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-color);
  }

  .case-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .case-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .case-block:last-child {
    grid-column: 1 / -1;
  }

  .case-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-red);
  }

  .case-text {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .case-recommendation {
    color: var(--color-electric-blue);
    font-weight: 500;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .resource-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .resource-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-red) 0%, var(--color-deep-blue) 50%, var(--color-electric-blue) 100%);
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .resource-card:hover::before {
    opacity: 1;
  }

  .resource-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-gray-200);
  }

  .resource-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 102, 255, 0.06);
    border-radius: var(--radius-md);
    color: var(--color-electric-blue);
    margin-bottom: 16px;
  }

  .resource-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .resource-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .resource-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
  }

  .resource-format {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .resource-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-electric-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .resource-cta:hover {
    color: var(--color-red);
  }

  @media (max-width: 900px) {
    .articles-grid,
    .trends-grid,
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .case-details {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .insights-tabs {
      padding: 32px 0 48px;
    }

    .articles-grid,
    .trends-grid,
    .resources-grid {
      grid-template-columns: 1fr;
    }

    .case-card {
      padding: 24px 20px;
    }

    .tabs-nav {
      gap: 0;
    }

    .tab-btn {
      padding: 10px 16px;
      font-size: var(--text-xs);
    }
  }
</style>
