---
// Root route - Spanish default locale
import BaseLayout from '../layouts/BaseLayout.astro';

const path = '/careers';
const description = 'Sumate a un equipo que construye productos digitales con foco en ingenieria, negocio y evolucion continua.';
const perks = [
  { title: 'Trabajo remoto', desc: 'Operamos 100% remoto desde cualquier lugar de America Latina.', icon: '🌎' },
  { title: 'Horario flexible', desc: 'Organiza tu dia con autonomia y foco en resultados.', icon: '⏰' },
  { title: 'Crecimiento profesional', desc: 'Plan de carrera, certificaciones y presupuesto de aprendizaje.', icon: '📈' },
  { title: 'Equipo multicultural', desc: 'Trabaja con profesionales de Peru, Latam y Europa.', icon: '🤝' },
  { title: 'Proyectos desafiantes', desc: 'Productos reales con escala regional e internacional.', icon: '🚀' },
  { title: 'Clima colaborativo', desc: 'Cultura abierta, feedback constante y sin burocracia.', icon: '💡' },
];
const teams = ['Engineering', 'Product', 'UX/UI', 'QA', 'DevOps', 'Business & Growth'];
const values = [
  { title: 'Excelencia sin ego', desc: 'Buscamos la mejor solucion, no tener la razon.' },
  { title: 'Propiedad y autonomia', desc: 'Cada persona es duena de su trabajo y sus decisiones.' },
  { title: 'Aprendizaje continuo', desc: 'La tecnologia cambia, nosotros tambien.' },
  { title: 'Impacto primero', desc: 'Medimos exito por resultados de negocio, no por lineas de codigo.' },
];
---

<BaseLayout title="Careers - SABERO Consulting" {description} locale="es" {path}>
  <section class="careers-hero">
    <div class="careers-hero-bg-layer"></div>
    <div class="careers-stars" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="careers-galaxy" aria-hidden="true">
      <div class="careers-talent-core"></div>
      <div class="careers-orbit careers-orbit-1">
        <div class="careers-orbit-body"><span>Engineering</span></div>
      </div>
      <div class="careers-orbit careers-orbit-2">
        <div class="careers-orbit-body"><span>Product</span></div>
      </div>
      <div class="careers-orbit careers-orbit-3">
        <div class="careers-orbit-body"><span>UX/UI</span></div>
      </div>
      <div class="careers-orbit careers-orbit-4">
        <div class="careers-orbit-body"><span>QA</span></div>
      </div>
      <div class="careers-orbit careers-orbit-5">
        <div class="careers-orbit-body"><span>DevOps</span></div>
      </div>
      <div class="careers-orbit careers-orbit-6">
        <div class="careers-orbit-body"><span>Business</span></div>
      </div>
    </div>
    <div class="careers-drifting" aria-hidden="true">
      <div class="careers-drift-tag">🌎 Remoto</div>
      <div class="careers-drift-tag">⏰ Flexible</div>
      <div class="careers-drift-tag">📈 Crecimiento</div>
      <div class="careers-drift-tag">🤝 Multicultural</div>
      <div class="careers-drift-tag">🚀 Desafíos</div>
      <div class="careers-drift-tag">💡 Colaboración</div>
    </div>
    <div class="container">
      <div class="careers-hero-content">
        <div class="careers-hero-badge-row">
          <span class="careers-hero-badge">Talento</span>
          <span class="careers-hero-badge-orbit">Únete</span>
        </div>
        <h1 class="careers-hero-title">
          <span class="careers-hero-title-line">Trabaja con</span>
          <span class="careers-hero-title-line careers-hero-title-accent">nosotros</span>
        </h1>
        <p class="careers-hero-desc">{description}</p>
        <div class="careers-hero-cta-row">
          <a href="#perks" class="careers-hero-cta">
            <span>Ver beneficios</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#cultura" class="careers-hero-link">
            Conoce la cultura
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="careers-perks" id="perks"><div class="container">
    <h2 class="careers-section-title">Beneficios</h2>
    <div class="careers-perks-grid">{perks.map((p) => (
      <article class="careers-perk-card"><span class="careers-perk-icon">{p.icon}</span><h3 class="careers-perk-title">{p.title}</h3><p class="careers-perk-desc">{p.desc}</p></article>
    ))}</div>
  </div></section>
  <section class="careers-values" id="cultura"><div class="container">
    <h2 class="careers-section-title">Cultura y valores</h2>
    <div class="careers-values-grid">{values.map((v, i) => (
      <div class="careers-value-card"><span class="careers-value-num">0{i + 1}</span><h3 class="careers-value-title">{v.title}</h3><p class="careers-value-desc">{v.desc}</p></div>
    ))}</div>
  </div></section>
  <section class="careers-teams"><div class="container">
    <h2 class="careers-section-title">Equipos</h2>
    <div class="careers-teams-grid">{teams.map((t) => <div class="careers-team-chip">{t}</div>)}</div>
  </div></section>
  <section class="careers-cta">
    <div class="careers-cta-bg" aria-hidden="true"><img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1920&q=80" alt="" loading="lazy" /></div>
    <div class="careers-cta-overlay"></div>
    <div class="container">
      <div class="careers-cta-content">
        <p class="careers-no-vacancies">No hay vacantes activas en este momento. Siguenos en LinkedIn para futuras oportunidades.</p>
        <a href="https://www.linkedin.com/in/saberoconsulting-sabero-844767418" target="_blank" rel="noopener noreferrer" class="careers-cta-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn SABERO
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .careers-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #060d1a;
  }

  .careers-hero-bg-layer {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 30%, rgba(0,102,255,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 20% 80%, rgba(230,57,70,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .careers-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .careers-stars span {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    animation: star-twinkle 4s ease-in-out infinite;
  }

  .careers-stars span:nth-child(1) { top: 8%; left: 3%; animation-delay: 0s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(2) { top: 15%; left: 12%; animation-delay: -0.3s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(3) { top: 22%; left: 7%; animation-delay: -0.8s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(4) { top: 32%; left: 15%; animation-delay: -1.2s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(5) { top: 42%; left: 2%; animation-delay: -0.5s; width: 3px; height: 3px; }
  .careers-stars span:nth-child(6) { top: 50%; left: 10%; animation-delay: -1.8s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(7) { top: 58%; left: 4%; animation-delay: -0.1s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(8) { top: 65%; left: 14%; animation-delay: -2.5s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(9) { top: 72%; left: 6%; animation-delay: -1.0s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(10) { top: 80%; left: 11%; animation-delay: -0.7s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(11) { top: 5%; left: 25%; animation-delay: -2.0s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(12) { top: 12%; left: 35%; animation-delay: -1.5s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(13) { top: 20%; left: 28%; animation-delay: -0.2s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(14) { top: 28%; left: 40%; animation-delay: -3.0s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(15) { top: 38%; left: 22%; animation-delay: -1.3s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(16) { top: 48%; left: 32%; animation-delay: -0.9s; width: 3px; height: 3px; }
  .careers-stars span:nth-child(17) { top: 55%; left: 25%; animation-delay: -2.2s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(18) { top: 62%; left: 38%; animation-delay: -1.7s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(19) { top: 70%; left: 20%; animation-delay: -0.4s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(20) { top: 78%; left: 30%; animation-delay: -2.8s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(21) { top: 88%; left: 35%; animation-delay: -1.1s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(22) { top: 3%; left: 50%; animation-delay: -0.6s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(23) { top: 10%; left: 60%; animation-delay: -2.6s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(24) { top: 18%; left: 45%; animation-delay: -1.9s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(25) { top: 25%; left: 55%; animation-delay: -0.3s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(26) { top: 35%; left: 48%; animation-delay: -3.2s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(27) { top: 45%; left: 58%; animation-delay: -1.4s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(28) { top: 52%; left: 42%; animation-delay: -0.8s; width: 3px; height: 3px; }
  .careers-stars span:nth-child(29) { top: 60%; left: 52%; animation-delay: -2.4s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(30) { top: 68%; left: 45%; animation-delay: -1.6s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(31) { top: 75%; left: 55%; animation-delay: -0.1s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(32) { top: 85%; left: 48%; animation-delay: -2.9s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(33) { top: 7%; left: 75%; animation-delay: -1.0s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(34) { top: 14%; left: 85%; animation-delay: -0.5s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(35) { top: 24%; left: 70%; animation-delay: -2.1s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(36) { top: 30%; left: 80%; animation-delay: -3.5s; width: 2px; height: 2px; }
  .careers-stars span:nth-child(37) { top: 40%; left: 65%; animation-delay: -1.2s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(38) { top: 48%; left: 75%; animation-delay: -0.7s; width: 3px; height: 3px; }
  .careers-stars span:nth-child(39) { top: 56%; left: 68%; animation-delay: -2.7s; width: 1px; height: 1px; }
  .careers-stars span:nth-child(40) { top: 82%; left: 72%; animation-delay: -1.5s; width: 1px; height: 1px; }

  @keyframes star-twinkle {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.8); }
  }

  .careers-galaxy {
    position: absolute;
    top: 50%;
    right: 6%;
    width: 520px;
    height: 520px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .careers-talent-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 28px;
    height: 28px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(0,102,255,0.7) 0%, rgba(0,102,255,0.15) 50%, transparent 100%);
    border-radius: 50%;
    box-shadow: 0 0 60px rgba(0,102,255,0.4), 0 0 120px rgba(0,102,255,0.15), 0 0 200px rgba(0,102,255,0.05);
    animation: core-pulse 4s ease-in-out infinite;
  }

  @keyframes core-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
    50% { transform: translate(-50%, -50%) scale(1.25); opacity: 1; }
  }

  .careers-orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 1px solid rgba(0,102,255,0.08);
    border-radius: 50%;
    animation: orbit-spin 20s linear infinite;
  }

  .careers-orbit-1 { width: 100px; height: 100px; margin: -50px 0 0 -50px; animation-duration: 12s; }
  .careers-orbit-2 { width: 180px; height: 180px; margin: -90px 0 0 -90px; animation-duration: 18s; }
  .careers-orbit-3 { width: 260px; height: 260px; margin: -130px 0 0 -130px; animation-duration: 24s; }
  .careers-orbit-4 { width: 340px; height: 340px; margin: -170px 0 0 -170px; animation-duration: 30s; }
  .careers-orbit-5 { width: 420px; height: 420px; margin: -210px 0 0 -210px; animation-duration: 36s; }
  .careers-orbit-6 { width: 500px; height: 500px; margin: -250px 0 0 -250px; animation-duration: 42s; }

  @keyframes orbit-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .careers-orbit-body {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
  }

  .careers-orbit-body span {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    padding: 3px 10px;
    background: rgba(10,22,40,0.85);
    border: 1px solid rgba(0,102,255,0.1);
    border-radius: var(--radius-full);
    backdrop-filter: blur(4px);
    letter-spacing: 0.5px;
  }

  .careers-drifting {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .careers-drift-tag {
    position: absolute;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.12);
    padding: 5px 14px;
    border: 1px solid rgba(255,255,255,0.03);
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(4px);
    animation: drift-up 12s ease-in-out infinite;
  }

  .careers-drift-tag:nth-child(1) { top: 70%; left: 55%; animation-delay: 0s; animation-duration: 10s; }
  .careers-drift-tag:nth-child(2) { top: 80%; left: 70%; animation-delay: -2s; animation-duration: 14s; }
  .careers-drift-tag:nth-child(3) { top: 65%; left: 82%; animation-delay: -4s; animation-duration: 12s; }
  .careers-drift-tag:nth-child(4) { top: 85%; left: 45%; animation-delay: -6s; animation-duration: 16s; }
  .careers-drift-tag:nth-child(5) { top: 75%; left: 35%; animation-delay: -8s; animation-duration: 11s; }
  .careers-drift-tag:nth-child(6) { top: 90%; left: 62%; animation-delay: -10s; animation-duration: 13s; }

  @keyframes drift-up {
    0% { transform: translateY(0) rotate(0deg); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-60vh) rotate(-4deg); opacity: 0; }
  }

  .careers-hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--header-height);
    max-width: 700px;
  }

  .careers-hero-badge-row {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .careers-hero-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-electric-blue);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(0,102,255,0.3);
    border-radius: var(--radius-full);
    background: rgba(0,102,255,0.08);
    backdrop-filter: blur(8px);
  }

  .careers-hero-badge-orbit {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(0,200,255,0.5);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(0,200,255,0.1);
    border-radius: var(--radius-full);
    animation: badge-orbit 4s ease-in-out infinite;
  }

  @keyframes badge-orbit {
    0%, 100% { opacity: 0.4; border-color: rgba(0,200,255,0.1); }
    50% { opacity: 1; border-color: rgba(0,200,255,0.3); }
  }

  .careers-hero-title {
    margin-bottom: var(--space-6);
  }

  .careers-hero-title-line {
    display: block;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-white);
    text-shadow: 0 0 40px rgba(0,102,255,0.15), 0 0 80px rgba(0,102,255,0.05);
  }

  .careers-hero-title-accent {
    background: linear-gradient(135deg, #0066ff, #00ccff, #6633ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 30px rgba(0,102,255,0.3));
  }

  .careers-hero-desc {
    font-size: clamp(var(--text-base), 1.3vw, var(--text-lg));
    color: var(--color-gray-300);
    max-width: 620px;
    line-height: 1.8;
    margin-bottom: var(--space-10);
    position: relative;
    padding-left: var(--space-5);
    border-left: 2px solid rgba(0,102,255,0.2);
  }

  .careers-hero-cta-row {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .careers-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, #0066ff, #6633ff);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 25px rgba(0,102,255,0.3);
  }

  .careers-hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(0,102,255,0.5);
  }

  .careers-hero-cta svg { transition: transform 0.3s ease; }
  .careers-hero-cta:hover svg { transform: translateX(4px); }

  .careers-hero-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-400);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .careers-hero-link:hover {
    color: var(--color-electric-blue);
    border-bottom-color: var(--color-electric-blue);
  }

  .careers-hero-link svg { transition: transform 0.3s ease; }
  .careers-hero-link:hover svg { transform: translateY(2px); }

  .careers-perks { padding: var(--space-16) 0; background-color: var(--bg-primary); }
  .careers-section-title { font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-8); color: var(--color-white); }
  .careers-perks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .careers-perk-card { padding: var(--space-6); background: linear-gradient(160deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius-xl); transition: all 0.3s ease; }
