---
// Root route - Spanish default locale
import BaseLayout from '../layouts/BaseLayout.astro';

const path = '/nosotros';
const title = 'Nosotros - SABERO Consulting';
const description = 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.';
const stats = [
  { number: '2018', label: 'Fundación' },
  { number: '+40', label: 'Profesionales' },
  { number: '+30', label: 'Proyectos entregados' },
  { number: '3', label: 'Continentes' },
];
const mision = 'Convertir el talento latinoamericano en el motor de innovación digital global. Diseñamos, desarrollamos y evolucionamos plataformas que resuelven problemas reales de negocio, con la misma calidad, compromiso y excelencia que cualquier hub tecnológico del mundo.';
const vision = 'Ser el partner de referencia para empresas que buscan escalar sus productos digitales desde América hacia el mundo, reconociendo que el talento y la cercanía cultural son ventajas competitivas invencibles.';
const values = [
  { title: 'Excelencia técnica', desc: 'Seleccionamos la tecnología correcta para cada problema, sin modas ni sobreingeniería. Código limpio, arquitectura sólida, decisiones con criterio.' },
  { title: 'Diseño orientado a negocio', desc: 'Cada decisión técnica responde a un objetivo de negocio medible. No construimos por construir: construimos para generar impacto real.' },
  { title: 'Relaciones de largo plazo', desc: 'Buscamos ser partners, no proveedores. Construimos relaciones que evolucionan con el tiempo, basadas en confianza y resultados.' },
  { title: 'Cercanía cultural', desc: 'Nuestra ubicación en Perú nos da ventaja de costo, talento y zona horaria. Operamos para América y Europa con comprensión cultural única.' },
];
const approach = [
  'Descubrimiento y estrategia: entendemos el negocio, el usuario y el contexto antes de escribir una línea de código.',
  'Arquitectura y diseño: definimos la columna vertebral técnica del producto para que sea escalable, mantenible y segura.',
  'Desarrollo ágil: trabajamos en ciclos cortos con equipos integrados, transparencia total y entregas continuas.',
  'Evolución y mejora continua: medimos, aprendemos y evolucionamos el producto con cada iteración.',
];
---

<BaseLayout {title} {description} locale="es" {path}>
  <section class="about-hero">
    <div class="about-hero-bg" aria-hidden="true">
      <div class="about-hero-image"></div>
      <div class="about-hero-gradient"></div>
      <div class="about-hero-grid"></div>
      <div class="about-hero-glitch-line"></div>
      <div class="about-hero-particles">
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    </div>
    <div class="about-hero-content">
      <div class="about-hero-badge-group">
        <span class="about-hero-badge">SABERO</span>
        <span class="about-hero-badge-outline">Est. 2018</span>
      </div>
      <h1 class="about-hero-title">
        <span class="about-hero-title-line">Ingeniería de producto</span>
        <span class="about-hero-title-line about-hero-title-accent">con ADN latinoamericano</span>
      </h1>
      <p class="about-hero-text">{description}</p>
      <div class="about-hero-actions">
        <a href="/contacto/" class="about-hero-cta">
          <span>Conversemos</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#historia" class="about-hero-link">
          Conoce nuestra historia
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <div class="about-hero-scroll">
      <span></span>
    </div>
  </section>

  <section class="about-stats"><div class="container">
    <div class="about-stats-grid">{stats.map((s) => (
      <div class="about-stat-card"><span class="about-stat-number">{s.number}</span><span class="about-stat-label">{s.label}</span></div>
    ))}</div>
  </div></section>

  <section class="about-story" id="historia"><div class="container">
    <div class="about-story-grid">
      <div class="about-story-image">
        <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
        <div class="about-story-image-badge">Lima, Perú</div>
      </div>
      <div class="about-story-text">
        <h2 class="about-section-title">Nuestra historia</h2>
        <p class="about-story-paragraph">Fundada en 2018, SABERO Consulting nació con la convicción de que el talento latinoamericano puede competir al más alto nivel global. Desde Lima, Perú, comenzamos construyendo productos digitales para startups locales que necesitaban escalar. Con los años, nuestros proyectos crecieron en complejidad y alcance: hoy trabajamos con empresas en América y Europa, entregando plataformas que procesan pagos, conectan personas, automatizan operaciones y transforman industrias enteras. No somos una fábrica de software tradicional. Somos un partner de producto que combina ingeniería sólida, diseño estratégico y comprensión profunda del negocio. Cada proyecto es una relación de largo plazo. Cada línea de código responde a un objetivo de negocio medible.</p>
      </div>
    </div>
  </div></section>

  <section class="about-mv" id="mision-vision"><div class="container">
    <div class="about-mv-grid">
      <div class="about-mv-card about-mv-mision">
        <div class="about-mv-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h2 class="about-mv-title">Misión</h2>
        <p class="about-mv-text">{mision}</p>
      </div>
      <div class="about-mv-card about-mv-vision">
        <div class="about-mv-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h2 class="about-mv-title">Visión</h2>
        <p class="about-mv-text">{vision}</p>
      </div>
    </div>
  </div></section>

  <section class="about-values"><div class="container">
    <h2 class="about-section-title">Nuestros valores</h2>
    <div class="about-values-grid">{values.map((v, i) => (
      <article class="about-value-card">
        <div class="about-value-header"><span class="about-value-num">0{i + 1}</span><h3 class="about-value-title">{v.title}</h3></div>
        <p class="about-value-desc">{v.desc}</p>
      </article>
    ))}</div>
  </div></section>

  <section class="about-approach"><div class="container">
    <h2 class="about-section-title">Nuestro enfoque</h2>
    <div class="about-approach-timeline">{approach.map((step, i) => (
      <div class="about-approach-step">
        <div class="about-approach-step-num"><span>{i + 1}</span></div>
        <p class="about-approach-step-text">{step}</p>
      </div>
    ))}</div>
  </div></section>

  <section class="about-cta">
    <div class="about-cta-bg" aria-hidden="true"><img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80" alt="" loading="lazy" /></div>
    <div class="about-cta-overlay"></div>
    <div class="container">
      <div class="about-cta-content">
        <h2 class="about-cta-title">Construyamos algo grande juntos</h2>
        <a href="/contacto/" class="about-cta-btn">
          Conversemos
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--color-deep-blue);
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .about-hero-image {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.25;
    filter: saturate(0.7) contrast(1.1) blur(1px);
    transform: scale(1.05);
    animation: hero-zoom 20s ease-in-out infinite alternate;
  }

  @keyframes hero-zoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1.15); }
  }

  .about-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.5) 40%, transparent 60%),
      linear-gradient(0deg, rgba(10,22,40,0.95) 0%, transparent 40%),
      radial-gradient(ellipse 60% 50% at 60% 40%, rgba(0,102,255,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 70%, rgba(0,102,255,0.06) 0%, transparent 60%);
  }

  .about-hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 70% 70% at 40% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 40% 50%, black 30%, transparent 70%);
  }

  .about-hero-glitch-line {
    position: absolute;
    top: 45%;
    left: -10%;
    width: 30%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric-blue), transparent);
    opacity: 0.15;
    transform: rotate(-15deg);
    animation: glitch-scan 8s ease-in-out infinite;
  }

  @keyframes glitch-scan {
    0%, 100% { transform: rotate(-15deg) translateX(-20%); opacity: 0.1; }
    50% { transform: rotate(-15deg) translateX(80%); opacity: 0.3; }
  }

  .about-hero-particles {
    position: absolute;
    inset: 0;
  }

  .about-hero-particles span {
    position: absolute;
    width: 3px;
    height: 3px;
    background: var(--color-electric-blue);
    border-radius: 50%;
    animation: particle-float 10s infinite ease-in-out;
    opacity: 0;
  }

  .about-hero-particles span:nth-child(1) { top: 15%; left: 10%; animation-delay: 0s; animation-duration: 12s; }
  .about-hero-particles span:nth-child(2) { top: 30%; left: 25%; width: 5px; height: 5px; animation-delay: 1.5s; animation-duration: 14s; opacity: 0.2; }
  .about-hero-particles span:nth-child(3) { top: 50%; left: 8%; animation-delay: 3s; animation-duration: 10s; }
  .about-hero-particles span:nth-child(4) { top: 70%; left: 20%; width: 4px; height: 4px; animation-delay: 0.8s; animation-duration: 16s; opacity: 0.15; }
  .about-hero-particles span:nth-child(5) { top: 85%; left: 5%; animation-delay: 5s; animation-duration: 11s; }
  .about-hero-particles span:nth-child(6) { top: 20%; right: 15%; animation-delay: 2s; animation-duration: 13s; }
  .about-hero-particles span:nth-child(7) { top: 45%; right: 8%; width: 4px; height: 4px; animation-delay: 4s; animation-duration: 15s; opacity: 0.1; }
  .about-hero-particles span:nth-child(8) { top: 65%; right: 20%; animation-delay: 1s; animation-duration: 12s; }
  .about-hero-particles span:nth-child(9) { top: 80%; right: 10%; width: 5px; height: 5px; animation-delay: 3.5s; animation-duration: 14s; opacity: 0.2; }
  .about-hero-particles span:nth-child(10) { top: 10%; right: 5%; animation-delay: 6s; animation-duration: 10s; }

  @keyframes particle-float {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0; }
    20% { opacity: 0.6; }
    50% { transform: translateY(-40px) scale(1.5); opacity: 0.8; }
    80% { opacity: 0.4; }
    100% { transform: translateY(-80px) scale(0.5); opacity: 0; }
  }

  .about-hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    padding-top: var(--header-height);
  }

  .about-hero-badge-group {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .about-hero-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-electric-blue);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(0,102,255,0.3);
    border-radius: var(--radius-full);
    background: rgba(0,102,255,0.08);
    backdrop-filter: blur(8px);
  }

  .about-hero-badge-outline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-gray-400);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-full);
  }

  .about-hero-title {
    margin-bottom: var(--space-6);
  }

  .about-hero-title-line {
    display: block;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-white);
  }

  .about-hero-title-accent {
    background: linear-gradient(135deg, var(--color-electric-blue) 0%, #80b3ff 50%, #b3d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    display: inline-block;
  }

  .about-hero-title-accent::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-electric-blue), transparent);
    border-radius: 2px;
    opacity: 0.3;
  }

  .about-hero-text {
    font-size: clamp(var(--text-base), 1.3vw, var(--text-lg));
    color: var(--color-gray-300);
    max-width: 620px;
    line-height: 1.8;
    margin-bottom: var(--space-10);
  }

  .about-hero-actions {
    display: flex;
    gap: var(--space-5);
    align-items: center;
    flex-wrap: wrap;
  }

  .about-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, var(--color-electric-blue), var(--color-electric-blue-hover));
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 25px rgba(0,102,255,0.3);
  }

  .about-hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 35px rgba(0,102,255,0.5);
  }

  .about-hero-cta svg {
    transition: transform 0.3s ease;
  }

  .about-hero-cta:hover svg {
    transform: translateX(4px);
  }

  .about-hero-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-400);
    text-decoration: none;
    transition: all 0.3s ease;
    padding: var(--space-2) 0;
    border-bottom: 1px solid transparent;
  }

  .about-hero-link:hover {
    color: var(--color-electric-blue);
    border-bottom-color: var(--color-electric-blue);
  }

  .about-hero-link svg {
    transition: transform 0.3s ease;
  }

  .about-hero-link:hover svg {
    transform: translateY(2px);
  }

  .about-hero-scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .about-hero-scroll span {
    display: block;
    width: 20px;
    height: 32px;
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    position: relative;
  }

  .about-hero-scroll span::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 8px;
    background: var(--color-electric-blue);
    border-radius: 2px;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(6px); opacity: 0.4; }
  }

  .about-stats { padding: var(--space-10) 0; background-color: var(--bg-primary); }
  .about-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); padding: var(--space-8); background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius-xl); }
  .about-stat-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); text-align: center; }
  .about-stat-number { font-size: var(--text-5xl); font-weight: 900; color: var(--color-electric-blue); line-height: 1; letter-spacing: -0.04em; }
  .about-stat-label { font-size: var(--text-sm); color: var(--color-gray-400); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
  .about-story { padding: var(--space-20) 0; background-color: var(--bg-secondary); }
  .about-story-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-12); align-items: center; }
  .about-story-image { position: relative; border-radius: var(--radius-xl); overflow: hidden; }
  .about-story-image img { width: 100%; height: 420px; object-fit: cover; display: block; transition: transform 0.8s ease; }
  .about-story-image:hover img { transform: scale(1.03); }
  .about-story-image-badge { position: absolute; bottom: var(--space-4); left: var(--space-4); font-size: var(--text-xs); font-weight: 700; color: var(--color-white); background: rgba(10,22,40,0.7); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); backdrop-filter: blur(8px); }
  .about-section-title { font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-6); color: var(--color-white); }
  .about-story-paragraph { font-size: var(--text-base); color: var(--color-gray-300); line-height: 1.9; margin-bottom: 0; }
  .about-values { padding: var(--space-20) 0; background-color: var(--bg-primary); }
  .about-values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  .about-value-card { padding: var(--space-6); background: linear-gradient(160deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius-xl); transition: all 0.3s ease; }
  .about-value-card:hover { border-color: rgba(0,102,255,0.15); transform: translateY(-3px); }
  .about-value-header { display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-4); }
  .about-value-num { font-size: var(--text-3xl); font-weight: 900; color: rgba(0,102,255,0.1); line-height: 1; }
  .about-value-title { font-size: var(--text-lg); font-weight: 700; color: var(--color-white); margin-bottom: 0; }
  .about-value-desc { font-size: var(--text-sm); color: var(--color-gray-400); line-height: 1.7; margin-bottom: 0; }
  .about-approach { padding: var(--space-20) 0; background-color: var(--bg-secondary); }
  .about-approach-timeline { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); position: relative; }
  .about-approach-timeline::before { content: ''; position: absolute; top: 28px; left: calc(12.5% + 24px); right: calc(12.5% + 24px); height: 2px; background: linear-gradient(90deg, var(--color-electric-blue), rgba(0,102,255,0.1)); border-radius: 1px; }
  .about-approach-step { text-align: center; position: relative; }
  .about-approach-step-num { width: 56px; height: 56px; margin: 0 auto var(--space-5); display: flex; align-items: center; justify-content: center; font-size: var(--text-lg); font-weight: 800; color: var(--color-electric-blue); background: rgba(0,102,255,0.1); border: 2px solid rgba(0,102,255,0.2); border-radius: 50%; position: relative; z-index: 1; transition: all 0.3s ease; }
  .about-approach-step:hover .about-approach-step-num { background: rgba(0,102,255,0.2); border-color: var(--color-electric-blue); transform: scale(1.1); }
  .about-approach-step-text { font-size: var(--text-sm); color: var(--color-gray-300); line-height: 1.7; margin-bottom: 0; }
  .about-cta { position: relative; padding: var(--space-20) 0; text-align: center; overflow: hidden; }
  .about-cta-bg { position: absolute; inset: 0; }
  .about-cta-bg img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.5) contrast(1.1); }
  .about-cta-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.7) 100%); }
  .about-cta-content { position: relative; z-index: 1; }
  .about-cta-title { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 800; margin-bottom: var(--space-8); color: var(--color-white); }
  .about-cta-btn { display: inline-flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-8); font-size: var(--text-base); font-weight: 600; color: var(--color-white); background: linear-gradient(135deg, var(--color-electric-blue), var(--color-electric-blue-hover)); border-radius: var(--radius-full); text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 20px rgba(0,102,255,0.3); }
  .about-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,102,255,0.4); }
