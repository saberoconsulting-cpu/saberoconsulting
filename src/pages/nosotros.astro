---
import BaseLayout from '../layouts/BaseLayout.astro';

const path = '/nosotros';
const title = 'Nosotros - SABERO Consulting';
const description = 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.';
const stats = [
  { number: '2018', label: 'Fundación' },
  { number: '+40', label: 'Profesionales' },
  { number: '+30', label: 'Proyectos entregados' },
  { number: '3', label: 'Continentes' },
];
const mision = 'Convertir el talento latinoamericano en el motor de innovación digital global. Diseñamos, desarrollamos y evolucionamos plataformas que resuelven problemas reales de negocio, con la misma calidad, compromiso y excelencia que cualquier hub tecnológico del mundo.';
const vision = 'Ser el partner de referencia para empresas que buscan escalar sus productos digitales desde América hacia el mundo, reconociendo que el talento y la cercanía cultural son ventajas competitivas invencibles.';
const values = [
  { title: 'Excelencia técnica', desc: 'Seleccionamos la tecnología correcta para cada problema, sin modas ni sobreingeniería. Código limpio, arquitectura sólida, decisiones con criterio.' },
  { title: 'Diseño orientado a negocio', desc: 'Cada decisión técnica responde a un objetivo de negocio medible. No construimos por construir: construimos para generar impacto real.' },
  { title: 'Relaciones de largo plazo', desc: 'Buscamos ser partners, no proveedores. Construimos relaciones que evolucionan con el tiempo, basadas en confianza y resultados.' },
  { title: 'Cercanía cultural', desc: 'Nuestra ubicación en Perú nos da ventaja de costo, talento y zona horaria. Operamos para América y Europa con comprensión cultural única.' },
];
const milestones = [
  { year: '2018', title: 'Fundación', desc: 'Nacimos en Lima con la convicción de que el talento latinoamericano puede competir al más alto nivel global.' },
  { year: '2020', title: 'Crecimiento', desc: 'Proyectos más complejos, clientes en toda América. Plataformas que procesan pagos, conectan personas y automatizan operaciones.' },
  { year: '2022', title: 'Expansión global', desc: 'Llegamos a Europa, consolidando presencia en 3 continentes. Cada proyecto es una relación de largo plazo.' },
  { year: '2024', title: 'Presente', desc: '+40 profesionales, +30 proyectos, 3 continentes. Seguimos creciendo con la misma convicción.' },
];
const approach = [
  'Descubrimiento y estrategia: entendemos el negocio, el usuario y el contexto antes de escribir una línea de código.',
  'Arquitectura y diseño: definimos la columna vertebral técnica del producto para que sea escalable, mantenible y segura.',
  'Desarrollo ágil: trabajamos en ciclos cortos con equipos integrados, transparencia total y entregas continuas.',
  'Evolución y mejora continua: medimos, aprendemos y evolucionamos el producto con cada iteración.',
];
const team = [
  { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
  { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
  { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4D03AQFDaf9Q-7vfog/profile-displayphoto-scale_400_400/B4DZrN63d8G8Ag-/0/1764391356417?e=1783555200&v=beta&t=hFOZJbv6QFSbBWbGVj6Zgn-fHNjnX9LTWlGzsc6uKac', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
];
---

<BaseLayout {title} {description} locale="es" {path}>
  <!-- HERO -->
  <section class="ns-hero">
    <div class="ns-hero-inner">
      <div class="ns-hero-col ns-hero-col--text">
        <span class="ns-hero-overline">SABERO CONSULTING</span>
        <h1 class="ns-hero-heading">
          Ingeniería de producto
          <span class="ns-hero-accent">con ADN latinoamericano</span>
        </h1>
        <p class="ns-hero-desc">{description}</p>
        <div class="ns-hero-actions">
          <a href="/contacto/" class="ns-hero-btn ns-hero-btn--primary">
            Conversemos
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#historia" class="ns-hero-btn ns-hero-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Nuestra historia
          </a>
        </div>
      </div>
      <div class="ns-hero-col ns-hero-col--visual">
        <div class="ns-hero-blob ns-hero-blob--a"></div>
        <div class="ns-hero-blob ns-hero-blob--b"></div>
        <svg width="0" height="0" style="position:absolute" aria-hidden="true">
          <defs>
            <clipPath id="ns-blob-clip" clipPathUnits="objectBoundingBox">
              <path d="M0.5,0.04 C0.78,0.02 0.98,0.16 0.98,0.42 C0.98,0.6 0.93,0.7 0.96,0.86 C0.99,1.0 0.86,1.0 0.74,0.98 C0.5,1.02 0.3,1.0 0.16,0.94 C0.02,0.88 0.0,0.7 0.02,0.5 C0.04,0.28 0.02,0.1 0.22,0.04 C0.32,0.0 0.4,0.06 0.5,0.04 Z" />
            </clipPath>
          </defs>
        </svg>
        <div class="ns-hero-image-wrap">
          <div class="ns-hero-image-clip">
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=900&q=80" alt="Equipo SABERO Consulting" loading="eager" />
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--top">
          <div class="ns-hero-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="ns-hero-card-text">
            <span class="ns-hero-card-title">Sprint #24</span>
            <span class="ns-hero-card-sub">Deploy exitoso</span>
          </div>
        </div>
        <div class="ns-hero-card ns-hero-card--bottom">
          <div class="ns-hero-card-dot"></div>
          <div class="ns-hero-card-lines">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="ns-hero-pill">+30 proyectos</div>
      </div>
    </div>
  </section>

  <script>
    document.documentElement.classList.add('js');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
  </script>

  <!-- STATS -->
  <section class="ns-stats" id="stats" data-reveal>
    <div class="container">
      <div class="ns-stats-grid">
        {stats.map((s) => (
          <div class="ns-stat">
            <span class="ns-stat-num">{s.number}</span>
            <span class="ns-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-story" id="historia" data-reveal>
    <div class="container">
      <div class="ns-story-header">
        <div class="ns-story-tag">Nuestra historia</div>
        <h2 class="ns-story-title">De Lima para el mundo</h2>
      </div>
      <div class="ns-story-body">
        <div class="ns-story-timeline">
          <div class="ns-story-line"></div>
          {milestones.map((m, i) => (
            <div class="ns-story-milestone" data-img={i}>
              <div class="ns-story-milestone-dot"></div>
              <div class="ns-story-milestone-year">{m.year}</div>
              <h3 class="ns-story-milestone-title">{m.title}</h3>
              <p class="ns-story-milestone-desc">{m.desc}</p>
            </div>
          ))}
          <div class="ns-story-quote">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p>El talento latinoamericano puede competir al más alto nivel global.</p>
          </div>
        </div>
        <div class="ns-story-visual">
          <div class="ns-story-img-frame">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
            <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
            <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION / VISION -->
  <section class="ns-mv" id="mision-vision" data-reveal>
    <div class="container">
      <div class="ns-mv-header">
        <div class="ns-mv-tag">Nuestro propósito</div>
        <h2 class="ns-mv-title">Misión y visión</h2>
      </div>
      <div class="ns-mv-grid">
        <div class="ns-mv-card">
          <div class="ns-mv-accent"></div>
          <div class="ns-mv-body">
            <h3 class="ns-mv-cardtitle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              Misión
            </h3>
            <p>{mision}</p>
          </div>
        </div>
        <div class="ns-mv-card ns-mv-card--dark">
          <div class="ns-mv-accent"></div>
          <div class="ns-mv-body">
            <h3 class="ns-mv-cardtitle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              Visión
            </h3>
            <p>{vision}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="ns-vals" id="valores" data-reveal>
    <div class="container">
      <div class="ns-vals-header">
        <div class="ns-vals-tag">Nuestra cultura</div>
        <h2 class="ns-vals-title">Valores que nos definen</h2>
        <p class="ns-vals-sub">Cuatro pilares que guían cada decisión, cada línea de código y cada relación con nuestros clientes.</p>
      </div>
      <div class="ns-vals-grid">
        {values.map((v, i) => (
          <article class="ns-val">
            <span class="ns-val-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="ns-val-bar"></div>
            <div class="ns-val-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                {i === 0 && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                {i === 1 && <><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></>}
                {i === 2 && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                {i === 3 && <><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
              </svg>
            </div>
            <div class="ns-val-body">
              <h3 class="ns-val-title">{v.title}</h3>
              <p class="ns-val-desc">{v.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="ns-team" id="equipo" data-reveal>
    <div class="container">
      <div class="ns-team-header">
        <div class="ns-team-tag">Nuestro equipo</div>
        <h2 class="ns-team-title">Fundadores</h2>
      </div>
      <div class="ns-team-grid">
        {team.map((m) => (
          <a href={m.linkedin || '#'} target="_blank" rel="noopener noreferrer" class="ns-team-link">
            <article class="ns-team-card">
              <div class="ns-team-imgwrap">
                <img src={m.image} alt={m.name} loading="lazy" />
              </div>
              <h3 class="ns-team-name">{m.name}</h3>
              <span class="ns-team-role">{m.role}</span>
              <p class="ns-team-desc">{m.desc}</p>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="ns-app" id="enfoque" data-reveal>
    <div class="container">
      <div class="ns-app-header">
        <div class="ns-app-tag">Nuestra metodología</div>
        <h2 class="ns-app-title">Cómo trabajamos</h2>
      </div>
      <div class="ns-app-steps">
        {approach.map((step, i) => (
          <div class="ns-app-step" data-idx={i + 1}>
            <div class="ns-app-step-top">
              <div class="ns-app-circle">{i + 1}</div>
              {i < approach.length - 1 && <div class="ns-app-connector"></div>}
            </div>
            <p class="ns-app-text">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ns-cta reveal">
    <div class="ns-cta-glow"></div>
    <div class="container">
      <h2 class="ns-cta-title">Construyamos algo grande juntos</h2>
      <p class="ns-cta-p">Conversa con nuestro equipo y descubre cómo podemos impulsar tu próximo proyecto.</p>
      <div class="ns-cta-actions">
        <a href="/contacto/" class="ns-cta-btn">
          Conversemos
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/#oferta" class="ns-cta-btn ns-cta-btn--b">
          Ver capacidades
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
<noscript><style>.js [data-reveal]{opacity:1!important;transform:none!important}.js [data-reveal] *{opacity:1!important;transform:none!important}</style></noscript>

<style is:global>
  /* ----- HERO ----- */
  .ns-hero {
    padding: 14px 0 0;
    background: var(--color-off-white);
    position: relative;
    overflow: hidden;
  }
  .ns-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6) 64px;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .ns-hero-col--text {
    display: flex;
    flex-direction: column;
  }
  .ns-hero-overline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    margin-bottom: 18px;
  }
  .ns-hero-heading {
    font-family: var(--font-primary);
    font-size: clamp(2.4rem, 4.8vw, 4rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-gray-900);
    margin: 0 0 22px;
  }
  .ns-hero-accent {
    color: var(--color-gray-900);
    display: block;
  }
  .ns-hero-desc {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-gray-500);
    max-width: 480px;
    margin: 0 0 36px;
  }
  .ns-hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
  }
  .ns-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-primary);
    text-decoration: none;
    line-height: 1;
    transition: all var(--transition-base);
  }
  .ns-hero-btn--primary {
    padding: 17px 34px;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 16px rgba(0, 102, 255, 0.3);
  }
  .ns-hero-btn--primary:hover {
    background: var(--color-electric-blue-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 102, 255, 0.38);
  }
  .ns-hero-btn--ghost {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-600);
  }
  .ns-hero-btn--ghost svg {
    color: var(--color-electric-blue);
  }
  .ns-hero-btn--ghost:hover {
    color: var(--color-electric-blue);
  }

  .ns-hero-col--visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 460px;
  }
  .ns-hero-blob {
    position: absolute;
    border-radius: 45% 55% 60% 40% / 50% 40% 60% 50%;
    filter: blur(2px);
    animation: ns-blob 14s ease-in-out infinite alternate;
  }
  .ns-hero-blob--a {
    width: 78%;
    height: 78%;
    top: 4%;
    left: 2%;
    background: linear-gradient(135deg, var(--color-electric-blue) 0%, var(--color-electric-blue-light) 100%);
    opacity: 0.9;
    z-index: 0;
  }
  .ns-hero-blob--b {
    width: 46%;
    height: 46%;
    bottom: 2%;
    right: 6%;
    background: linear-gradient(135deg, var(--color-red) 0%, rgba(230, 57, 70, 0.25) 100%);
    opacity: 0.85;
    z-index: 0;
    animation-delay: -4s;
  }
  @keyframes ns-blob {
    0% { border-radius: 45% 55% 60% 40% / 50% 40% 60% 50%; transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { border-radius: 55% 45% 40% 60% / 40% 55% 45% 60%; transform: translate(8px, -10px) scale(1.04) rotate(3deg); }
    100% { border-radius: 40% 60% 50% 50% / 60% 40% 50% 50%; transform: translate(-6px, 6px) scale(0.97) rotate(-2deg); }
  }
  .ns-hero-image-wrap {
    position: relative;
    z-index: 1;
    width: 74%;
    aspect-ratio: 3 / 4;
  }
  .ns-hero-image-clip {
    width: 100%;
    height: 100%;
    clip-path: url(#ns-blob-clip);
    filter: drop-shadow(0 30px 50px rgba(10, 22, 40, 0.22));
    animation: ns-image-breathe 14s ease-in-out infinite alternate;
  }
  .ns-hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-mask-image: radial-gradient(ellipse 78% 80% at 50% 48%, #000 62%, transparent 100%);
    mask-image: radial-gradient(ellipse 78% 80% at 50% 48%, #000 62%, transparent 100%);
  }
  @keyframes ns-image-breathe {
    0% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.02) rotate(0.6deg); }
    100% { transform: scale(0.99) rotate(-0.5deg); }
  }
  .ns-hero-card {
    position: absolute;
    z-index: 2;
    background: var(--bg-elevated, var(--color-white));
    border: 1px solid var(--border-color, var(--color-gray-100));
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ns-hero-card--top {
    top: 8%;
    right: -4%;
    padding: 14px 18px;
  }
  .ns-hero-card-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-electric-blue-light);
    color: var(--color-electric-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ns-hero-card-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ns-hero-card-title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-gray-900);
  }
  .ns-hero-card-sub {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-gray-400);
  }
  .ns-hero-card--bottom {
    bottom: 6%;
    left: -6%;
    padding: 16px 20px;
  }
  .ns-hero-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-red);
    flex-shrink: 0;
  }
  .ns-hero-card-lines {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .ns-hero-card-lines span {
    display: block;
    height: 4px;
    border-radius: 2px;
    background: var(--color-gray-100);
  }
  .ns-hero-card-lines span:nth-child(1) { width: 56px; }
  .ns-hero-card-lines span:nth-child(2) { width: 38px; }
  .ns-hero-card-lines span:nth-child(3) { width: 46px; }
  .ns-hero-pill {
    position: absolute;
