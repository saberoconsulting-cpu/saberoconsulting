---
// ============================================
// SABERO Consulting - Nosotros Page
// ============================================
import BaseLayout from '../layouts/BaseLayout.astro';
import NosotrosHero from '../components/sections/nosotros/NosotrosHero.astro';
import NosotrosStats from '../components/sections/nosotros/NosotrosStats.astro';
import NosotrosStory from '../components/sections/nosotros/NosotrosStory.astro';
import NosotrosMissionVision from '../components/sections/nosotros/NosotrosMissionVision.astro';
import NosotrosValues from '../components/sections/nosotros/NosotrosValues.astro';
import NosotrosTeam from '../components/sections/nosotros/NosotrosTeam.astro';
import NosotrosApproach from '../components/sections/nosotros/NosotrosApproach.astro';
import NosotrosCTA from '../components/sections/nosotros/NosotrosCTA.astro';

const path = '/nosotros';
const title = 'Nosotros - SABERO Consulting';
const description = 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.';
---

<BaseLayout {title} {description} locale="es" {path}>
  <NosotrosHero locale="es" />
  <NosotrosStats locale="es" />
  <NosotrosStory />
  <NosotrosMissionVision />
  <NosotrosValues />
  <NosotrosTeam />
  <NosotrosApproach />
  <NosotrosCTA />
</BaseLayout>

<script>
  document.documentElement.classList.add('js');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
</script>

<noscript><style>.js [data-reveal]{opacity:1!important;transform:none!important}.js [data-reveal] *{opacity:1!important;transform:none!important}</style></noscript>
