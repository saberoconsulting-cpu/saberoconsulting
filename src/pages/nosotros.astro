  /* ----- APPROACH ----- */
  .ns-app {
    padding: 110px 0;
    background: var(--color-white);
    position: relative;
  }
  .ns-app::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric-blue-light), transparent);
  }
  .ns-app-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .ns-app-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }
  .ns-app-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
  }
  .ns-app-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    counter-reset: step;
  }
  .ns-app-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: default;
  }
  .ns-app-step-top {
    display: flex;
    align-items: center;
    width: 100%;
    margin-bottom: 28px;
  }
  .ns-app-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-gray-300);
    background: var(--color-gray-50);
    border: 2px solid var(--color-gray-100);
    flex-shrink: 0;
    transition: all var(--transition-base);
    position: relative;
    z-index: 1;
  }
  .ns-app-connector {
    flex: 1;
    height: 3px;
    background: var(--color-gray-100);
    transition: background var(--transition-base);
    margin: 0 -1px;
    position: relative;
    z-index: 0;
  }
  .ns-app-text {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    line-height: 1.7;
    margin: 0;
    max-width: 240px;
    text-align: center;
    transition: color var(--transition-base);
  }

  /* Use :has() approach */
  .ns-app-steps:has(.ns-app-step:nth-child(1):hover) .ns-app-step:nth-child(1) .ns-app-circle {
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
