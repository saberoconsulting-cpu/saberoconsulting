---
// Root insights route - redirects to Spanish version
import BaseLayout from '../layouts/BaseLayout.astro';
import { getInsightsData } from '../data/insights';
import InsightsHero from '../components/sections/insights/InsightsHero.astro';
import InsightsCTA from '../components/sections/insights/InsightsCTA.astro';
import '../styles/pages/insights.css';

const data = getInsightsData('es');

const sections = [
  { id: 'articles', label: 'Articulos', type: 'article' },
  { id: 'guides', label: 'Guias', type: 'guide' },
  { id: 'trends', label: 'Tendencias', type: 'trend' },
  { id: 'cases', label: 'Casos comentados', type: 'case' },
  { id: 'resources', label: 'Recursos descargables', type: 'resource' },
];

const labels = { problem: 'Problema', approach: 'Enfoque', lesson: 'Aprendizaje', recommendation: 'Recomendacion' };

const articles = data.articles;
const guides = data.featured.filter((i) => i.type === 'guide');
const trends = data.trends;
const cases = data.cases;
const resources = data.resources;
---

<BaseLayout
  title="Insights - SABERO Consulting"
  description="Contenidos para lideres de negocio y equipos que buscan entender producto digital, automatizacion, escalabilidad y evolucion tecnologica."
  locale="es"
  path="/insights"
>
  <InsightsHero data={data.hero} locale="es" />

  <section class="insights-tabs section" aria-label="Secciones de contenido">
    <div class="container">
      <nav class="tabs-nav" role="tablist" aria-label="Categorias de contenido">
        {sections.map((sec) => (
          <button type="button"
            class="tab-btn"
            role="tab"
            aria-selected={sec.id === 'articles'}
            aria-controls={`panel-${sec.id}`}
            data-tab={sec.id}
          >
            {sec.label}
          </button>
        ))}
      </nav>

      <div class="tabs-content">
        <!-- Articulos -->
        <div class="tab-panel active" id="panel-articles" role="tabpanel" data-panel="articles">
          <div class="articles-grid">
            {articles.map((article) => (
              <article class="content-card">
                <span class="card-badge">{article.category}</span>
                <h3 class="card-title">{article.title}</h3>
                <p class="card-summary">{article.summary}</p>
                <div class="card-footer">
                  <span class="card-readtime">{article.readTime}</span>
                  <a href={article.href || '#'} class="card-cta" target={article.href?.startsWith('http') ? '_blank' : undefined} rel={article.href?.startsWith('http') ? 'noopener noreferrer' : undefined}>{article.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Guias -->
        <div class="tab-panel" id="panel-guides" role="tabpanel" data-panel="guides">
          <div class="articles-grid">
            {guides.map((guide) => (
              <article class="content-card">
                <span class="card-badge">{guide.category}</span>
                <h3 class="card-title">{guide.title}</h3>
                <p class="card-summary">{guide.summary}</p>
                <div class="card-footer">
                  <span class="card-readtime">{guide.readTime}</span>
                  <a href="#" class="card-cta">{guide.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Tendencias -->
        <div class="tab-panel" id="panel-trends" role="tabpanel" data-panel="trends">
          <div class="trends-grid">
            {trends.map((trend) => (
              <article class="trend-card">
                <h3 class="trend-title">{trend.title}</h3>
                <p class="trend-summary">{trend.summary}</p>
                <p class="trend-impact">{trend.impact}</p>
              </article>
            ))}
          </div>
        </div>

        <!-- Casos comentados -->
        <div class="tab-panel" id="panel-cases" role="tabpanel" data-panel="cases">
          <div class="cases-list">
            {cases.map((c) => (
              <article class="case-card">
                <h3 class="case-title">{c.title}</h3>
                <div class="case-details">
                  <div class="case-block">
                    <span class="case-label">{labels.problem}</span>
                    <p class="case-text">{c.problem}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{labels.approach}</span>
                    <p class="case-text">{c.approach}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{labels.lesson}</span>
                    <p class="case-text">{c.lesson}</p>
                  </div>
                  <div class="case-block">
                    <span class="case-label">{labels.recommendation}</span>
                    <p class="case-text case-recommendation">{c.recommendation}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Recursos descargables -->
        <div class="tab-panel" id="panel-resources" role="tabpanel" data-panel="resources">
          <div class="resources-grid">
            {resources.map((resource) => (
              <article class="resource-card">
                <div class="resource-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                  </svg>
                </div>
                <h3 class="resource-title">{resource.title}</h3>
                <p class="resource-summary">{resource.summary}</p>
                <div class="resource-footer">
                  <span class="resource-format">{resource.format}</span>
                  <a href={resource.href || '#'} class="resource-cta" target={resource.href?.startsWith('http') ? '_blank' : undefined} rel={resource.href?.startsWith('http') ? 'noopener noreferrer' : undefined}>{resource.cta} &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <InsightsCTA data={data.cta} locale="es" />
</BaseLayout>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function () {
    var tabs = document.querySelectorAll('[data-tab]');
    var panels = document.querySelectorAll('[data-panel]');

    function activateTab(tabId) {
      for (var i = 0; i < tabs.length; i++) {
        var t = tabs[i];
        var isActive = t.getAttribute('data-tab') === tabId;
        if (isActive) {
          t.classList.add('active');
          t.setAttribute('aria-selected', 'true');
        } else {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        }
      }
      for (var j = 0; j < panels.length; j++) {
        var p = panels[j];
        if (p.getAttribute('data-panel') === tabId) {
          p.classList.add('active');
        } else {
          p.classList.remove('active');
        }
      }
    }

    for (var k = 0; k < tabs.length; k++) {
      tabs[k].addEventListener('click', function () {
        var tabId = this.getAttribute('data-tab');
        if (tabId) {
          activateTab(tabId);
        }
      });
    }
  });
</script>


