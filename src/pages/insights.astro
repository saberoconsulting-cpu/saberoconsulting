---
// Root route - Spanish default locale
import BaseLayout from '../layouts/BaseLayout.astro';

const path = '/insights';
const title = 'Insights - SABERO Consulting';
const description = 'Contenidos para lideres de negocio y equipos que buscan entender producto digital, automatizacion, escalabilidad y evolucion tecnologica.';
const articles = [
  { title: 'Como validar un MVP sin gastar de mas', category: 'Producto', desc: 'Estrategias para validar tu producto minimo viable con presupuestos ajustados y maximo aprendizaje.', image: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=800&q=80', date: 'Abr 2026' },
  { title: 'Cuando modernizar una plataforma legacy', category: 'Arquitectura', desc: 'Senales de alerta y hojas de ruta para migrar sistemas legacy sin detener operaciones.', image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=800&q=80', date: 'Mar 2026' },
  { title: 'Integraciones de pago sin friccion', category: 'Fintech', desc: 'Como disenar integraciones de pago modulares que escalen con tu negocio.', image: 'https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=800&q=80', date: 'Feb 2026' },
  { title: 'Arquitectura para productos escalables', category: 'Arquitectura', desc: 'Principios de diseno que permiten que tu producto crezca sin reescribirse.', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=800&q=80', date: 'Ene 2026' },
  { title: 'IA aplicada a procesos empresariales', category: 'AI', desc: 'Casos reales de inteligencia artificial aplicada a operaciones empresariales.', image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=800&q=80', date: 'Dic 2025' },
  { title: 'SEO y rendimiento para plataformas', category: 'Performance', desc: 'Optimizacion tecnica para plataformas web que buscan visibilidad y velocidad.', image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80', date: 'Nov 2025' },
];
const topics = [
  { title: 'Producto & Estrategia', icon: '🎯', count: '12 articulos' },
  { title: 'Arquitectura & Escalabilidad', icon: '🏗️', count: '8 articulos' },
  { title: 'Fintech & Pagos', icon: '💳', count: '6 articulos' },
  { title: 'AI & Automatizacion', icon: '🤖', count: '5 articulos' },
  { title: 'Performance & SEO', icon: '⚡', count: '4 articulos' },
  { title: 'Experiencia de usuario', icon: '🎨', count: '7 articulos' },
];
---

<BaseLayout {title} {description} locale="es" {path}>
  <section class="insights-hero">
    <div class="insights-hero-bg-layer"></div>
    <div class="insights-nebula" aria-hidden="true"></div>
    <div class="insights-geo" aria-hidden="true">
      <div class="insights-geo-shape insights-geo-hex"></div>
      <div class="insights-geo-shape insights-geo-circle"></div>
      <div class="insights-geo-shape insights-geo-tri"></div>
      <div class="insights-geo-shape insights-geo-ring"></div>
      <div class="insights-geo-shape insights-geo-dot"></div>
      <div class="insights-geo-shape insights-geo-cross"></div>
    </div>
    <div class="insights-nodes" aria-hidden="true">
      <div class="insights-node insights-node-1"></div>
      <div class="insights-node insights-node-2"></div>
      <div class="insights-node insights-node-3"></div>
      <div class="insights-node insights-node-4"></div>
      <div class="insights-node insights-node-5"></div>
      <div class="insights-node insights-node-6"></div>
      <svg class="insights-node-lines" viewBox="0 0 400 400" preserveAspectRatio="none">
        <line x1="200" y1="50" x2="60" y2="180" stroke="rgba(0,200,255,0.06)" stroke-width="1"/>
        <line x1="200" y1="50" x2="340" y2="180" stroke="rgba(0,200,255,0.06)" stroke-width="1"/>
        <line x1="60" y1="180" x2="200" y2="320" stroke="rgba(0,200,255,0.06)" stroke-width="1"/>
        <line x1="340" y1="180" x2="200" y2="320" stroke="rgba(0,200,255,0.06)" stroke-width="1"/>
        <line x1="60" y1="180" x2="340" y2="180" stroke="rgba(0,200,255,0.04)" stroke-width="1"/>
        <line x1="200" y1="50" x2="200" y2="320" stroke="rgba(0,200,255,0.04)" stroke-width="1"/>
        <circle cx="200" cy="185" r="80" fill="none" stroke="rgba(0,200,255,0.03)" stroke-width="1"/>
      </svg>
    </div>
    <div class="container">
      <div class="insights-hero-content">
        <div class="insights-hero-badge-row">
          <span class="insights-hero-badge">Contenido</span>
          <span class="insights-hero-badge-pulse">Conocimiento</span>
        </div>
        <h1 class="insights-hero-title">
          <span class="insights-hero-title-line">Insights</span>
          <span class="insights-hero-title-sub">para líderes digitales</span>
        </h1>
        <p class="insights-hero-desc">{description}</p>
        <div class="insights-hero-cta-row">
          <a href="#topics" class="insights-hero-cta">
            <span>Explorar temas</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 8h14M8 1l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#articles" class="insights-hero-link">
            Ver artículos
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="insights-topics" id="topics">
    <div class="container">
      <h2 class="insights-section-title">Temas</h2>
      <div class="insights-topics-grid">
        {topics.map((topic) => (
          <article class="insights-topic-card">
            <span class="insights-topic-icon">{topic.icon}</span>
            <h3 class="insights-topic-title">{topic.title}</h3>
            <span class="insights-topic-count">{topic.count}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="insights-featured" id="articles">
    <div class="container">
      <h2 class="insights-section-title">Articulos destacados</h2>
      <div class="insights-grid">
        {articles.map((article) => (
          <article class="insights-card">
            <div class="insights-card-image" style={`background-image: url(${article.image})`}>
              <div class="insights-card-overlay"></div>
              <span class="insights-card-category">{article.category}</span>
            </div>
            <div class="insights-card-body">
              <time class="insights-card-date">{article.date}</time>
              <h3 class="insights-card-title">{article.title}</h3>
              <p class="insights-card-desc">{article.desc}</p>
              <span class="insights-card-link">
                Leer articulo
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M1 6h10M6 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </article>
        ))}
      </div>
      <p class="insights-coming">Proximamente nuevos contenidos</p>
    </div>
  </section>
</BaseLayout>

<style>
  .insights-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #060d1a;
  }

  .insights-hero-bg-layer {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 90% 50% at 30% 30%, rgba(100,0,255,0.1) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 70% 80%, rgba(0,200,255,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 50% 50%, rgba(255,0,150,0.03) 0%, transparent 50%),
      linear-gradient(180deg, #060d1a 0%, #0a1628 30%, #060d1a 100%);
    pointer-events: none;
    z-index: 0;
  }

  .insights-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle 300px at 20% 30%, rgba(100,50,255,0.04) 0%, transparent 100%),
      radial-gradient(circle 400px at 80% 60%, rgba(0,200,255,0.03) 0%, transparent 100%),
      radial-gradient(circle 250px at 50% 80%, rgba(255,0,150,0.02) 0%, transparent 100%);
    animation: nebula-drift 20s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes nebula-drift {
    0% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(20px, -10px) scale(1.05); opacity: 0.8; }
    100% { transform: translate(-10px, 15px) scale(1.02); opacity: 0.6; }
  }

  .insights-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .insights-geo-shape {
    position: absolute;
    animation: geo-spin 20s linear infinite;
  }

  .insights-geo-hex {
    top: 12%;
    left: 8%;
    width: 60px;
    height: 60px;
    background: rgba(100,50,255,0.06);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    border: 1px solid rgba(100,50,255,0.08);
    animation-duration: 25s;
  }

  .insights-geo-circle {
    top: 55%;
    right: 12%;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 1px solid rgba(0,200,255,0.08);
    background: rgba(0,200,255,0.03);
    animation-duration: 18s;
    animation-direction: reverse;
  }

  .insights-geo-tri {
    top: 30%;
    right: 25%;
    width: 50px;
    height: 50px;
    background: rgba(255,0,150,0.04);
    clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    border: 1px solid rgba(255,0,150,0.06);
    animation-duration: 30s;
  }

  .insights-geo-ring {
    bottom: 15%;
    left: 20%;
    width: 100px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,200,0,0.06);
    transform: rotateX(60deg);
    animation: geo-rotate 15s ease-in-out infinite alternate;
  }

  .insights-geo-dot {
    top: 70%;
    left: 10%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(0,200,255,0.08);
    box-shadow: 0 0 20px rgba(0,200,255,0.05);
    animation: dot-pulse 3s ease-in-out infinite;
  }

  .insights-geo-cross {
    bottom: 25%;
    right: 18%;
    width: 40px;
    height: 40px;
    position: relative;
    animation-duration: 22s;
    animation-direction: reverse;
  }

  .insights-geo-cross::before,
  .insights-geo-cross::after {
    content: '';
    position: absolute;
    background: rgba(100,50,255,0.06);
  }
  .insights-geo-cross::before { width: 100%; height: 1px; top: 50%; transform: translateY(-50%); }
  .insights-geo-cross::after { width: 1px; height: 100%; left: 50%; transform: translateX(-50%); }

  @keyframes geo-spin {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  @keyframes geo-rotate {
    0% { transform: rotateX(60deg) rotate(0deg); }
    100% { transform: rotateX(60deg) rotate(360deg); }
  }

  @keyframes dot-pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; box-shadow: 0 0 20px rgba(0,200,255,0.05); }
    50% { transform: scale(1.5); opacity: 0.8; box-shadow: 0 0 40px rgba(0,200,255,0.15); }
  }

  .insights-nodes {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .insights-node-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .insights-node {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: node-glow 4s ease-in-out infinite;
  }

  .insights-node-1 { top: 20%; left: 30%; background: rgba(0,200,255,0.3); box-shadow: 0 0 12px rgba(0,200,255,0.1); animation-delay: 0s; }
  .insights-node-2 { top: 45%; left: 15%; background: rgba(100,50,255,0.3); box-shadow: 0 0 12px rgba(100,50,255,0.1); animation-delay: -1s; }
  .insights-node-3 { top: 50%; left: 50%; background: rgba(255,0,150,0.3); box-shadow: 0 0 12px rgba(255,0,150,0.1); animation-delay: -2s; }
  .insights-node-4 { top: 30%; left: 70%; background: rgba(255,200,0,0.3); box-shadow: 0 0 12px rgba(255,200,0,0.1); animation-delay: -0.5s; }
  .insights-node-5 { top: 70%; left: 40%; background: rgba(0,255,150,0.3); box-shadow: 0 0 12px rgba(0,255,150,0.1); animation-delay: -1.5s; }
  .insights-node-6 { top: 65%; left: 75%; background: rgba(0,200,255,0.3); box-shadow: 0 0 12px rgba(0,200,255,0.1); animation-delay: -3s; }

  @keyframes node-glow {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(2.5); opacity: 1; }
  }

  .insights-hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--header-height);
    max-width: 750px;
  }

  .insights-hero-badge-row {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .insights-hero-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-electric-blue);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(0,102,255,0.3);
    border-radius: var(--radius-full);
    background: rgba(0,102,255,0.08);
    backdrop-filter: blur(8px);
  }

  .insights-hero-badge-pulse {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(200,150,255,0.6);
    padding: var(--space-1) var(--space-4);
    border: 1px solid rgba(200,150,255,0.1);
    border-radius: var(--radius-full);
    animation: badge-breathe 4s ease-in-out infinite;
  }

  @keyframes badge-breathe {
    0%, 100% { opacity: 0.4; border-color: rgba(200,150,255,0.1); }
    50% { opacity: 1; border-color: rgba(200,150,255,0.3); }
  }

  .insights-hero-title {
    margin-bottom: var(--space-6);
  }

  .insights-hero-title-line {
    display: block;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-white);
    text-shadow: 0 0 40px rgba(100,50,255,0.15), 0 0 80px rgba(100,50,255,0.05);
  }

  .insights-hero-title-sub {
    display: block;
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-weight: 300;
    color: rgba(200,150,255,0.4);
    letter-spacing: 6px;
    text-transform: uppercase;
    margin-top: var(--space-4);
  }

  .insights-hero-desc {
    font-size: clamp(var(--text-base), 1.3vw, var(--text-lg));
    color: var(--color-gray-300);
    max-width: 620px;
    line-height: 1.8;
    margin-bottom: var(--space-10);
    position: relative;
    padding-left: var(--space-5);
    border-left: 2px solid rgba(100,50,255,0.2);
  }

  .insights-hero-cta-row {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .insights-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, #6633ff, #0066ff);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 25px rgba(100,50,255,0.3);
  }

  .insights-hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(100,50,255,0.5);
  }

  .insights-hero-cta svg { transition: transform 0.3s ease; }
  .insights-hero-cta:hover svg { transform: translateX(4px); }

  .insights-hero-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-400);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .insights-hero-link:hover {
    color: var(--color-electric-blue);
    border-bottom-color: var(--color-electric-blue);
  }

  .insights-hero-link svg { transition: transform 0.3s ease; }
  .insights-hero-link:hover svg { transform: translateY(2px); }

  @media (max-width: 768px) {
    .insights-hero { min-height: 80vh; }
    .insights-hero-content { padding-top: calc(var(--header-height) + var(--space-8)); }
    .insights-hero-title-line { font-size: clamp(2rem, 10vw, 3.5rem); }
    .insights-hero-title-sub { font-size: clamp(0.9rem, 2vw, 1.3rem); letter-spacing: 4px; }
    .insights-geo-shape { display: none; }
    .insights-nodes { display: none; }
    .insights-hero-desc { padding-left: var(--space-3); }
  }

  @media (max-width: 640px) {
    .insights-hero { min-height: 75vh; }
    .insights-hero-title-sub { display: none; }
  }
  .insights-topics { padding: var(--space-16) 0; background-color: var(--bg-primary); }
  .insights-section-title { font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-8); color: var(--color-white); }
  .insights-topics-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: var(--space-4); }
  .insights-topic-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); padding: var(--space-6) var(--space-4); background: linear-gradient(160deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius-xl); text-align: center; transition: all 0.3s ease; cursor: default; }
  .insights-topic-card:hover { border-color: rgba(0,102,255,0.15); transform: translateY(-3px); }
  .insights-topic-icon { font-size: 2rem; line-height: 1; }
  .insights-topic-title { font-size: var(--text-sm); font-weight: 700; color: var(--color-white); }
  .insights-topic-count { font-size: var(--text-xs); color: var(--color-gray-500); }
  .insights-featured { padding: var(--space-20) 0 var(--space-24); background-color: var(--bg-secondary); }
  .insights-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .insights-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); overflow: hidden; transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1); }
  .insights-card:hover { transform: translateY(-6px); border-color: rgba(0,102,255,0.2); box-shadow: 0 20px 50px rgba(0,0,0,0.2); }
  .insights-card-image { position: relative; height: 180px; background-size: cover; background-position: center; }
  .insights-card-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 30%, rgba(10,22,40,0.8) 100%); }
  .insights-card-category { position: absolute; bottom: var(--space-3); left: var(--space-4); font-size: var(--text-xs); font-weight: 600; color: var(--color-electric-blue); background: rgba(0,102,255,0.12); padding: 2px var(--space-2); border-radius: var(--radius-sm); backdrop-filter: blur(8px); }
  .insights-card-body { padding: var(--space-5); }
  .insights-card-date { font-size: var(--text-xs); color: var(--color-gray-500); margin-bottom: var(--space-2); display: block; }
  .insights-card-title { font-size: var(--text-base); font-weight: 700; color: var(--color-white); margin-bottom: var(--space-3); line-height: 1.3; }
  .insights-card-desc { font-size: var(--text-sm); color: var(--color-gray-400); line-height: 1.7; margin-bottom: var(--space-4); }
  .insights-card-link { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); font-weight: 600; color: var(--color-electric-blue); transition: gap 0.3s ease; }
  .insights-card:hover .insights-card-link { gap: var(--space-3); }
  .insights-card-link svg { transition: transform 0.3s ease; }
  .insights-card:hover .insights-card-link svg { transform: translateX(3px); }
  .insights-coming { text-align: center; margin-top: var(--space-12); font-size: var(--text-sm); color: var(--color-gray-500); }
  @media (max-width: 1100px) { .insights-topics-grid { grid-template-columns: repeat(3, 1fr); } .insights-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .insights-hero { padding: var(--space-16) 0 var(--space-10); } .insights-topics { padding: var(--space-10) 0; } .insights-topics-grid { grid-template-columns: repeat(2, 1fr); } .insights-featured { padding: var(--space-12) 0 var(--space-16); } .insights-grid { grid-template-columns: 1fr; } }
</style>
