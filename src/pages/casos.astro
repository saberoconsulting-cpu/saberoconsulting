---
// Root route - Spanish default locale
import BaseLayout from '../layouts/BaseLayout.astro';
import CasosExitoCTA from '../components/sections/casos/CasosExitoCTA.astro';
import CasosTitulo from '../components/sections/casos/CasosTitulo.astro';
import CasosGrid from '../components/sections/casos/CasosGrid.astro';

const path = '/casos';
const title = 'Casos e impacto - SABERO Consulting';
const description = 'Conoce como transformamos retos de negocio en productos, plataformas y operaciones digitales medibles.';
---

<BaseLayout {title} {description} locale="es" {path}>
  <CasosExitoCTA />
  <CasosTitulo />
  <CasosGrid />
</BaseLayout>
