---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOLanding from '../components/sections/seo/SEOLanding.astro';

const path = '/desarrollo-tecnologico-peru';
const title = 'Desarrollo Tecnológico en Perú y América | SABERO Consulting';
const description = 'SABERO Consulting lidera el desarrollo tecnológico en Perú y América. Innovación en IA, automatización, fábrica de software, cloud y transformación digital para empresas.';
---

<BaseLayout {title} {description} locale="es" {path}>
  <SEOLanding
    locale="es"
    title="Desarrollo Tecnológico en Perú y América"
    subtitle="Innovación y tecnología de clase mundial desde Latinoamérica"
    description="SABERO Consulting es referente en desarrollo tecnológico en Perú y América. Combinamos talento senior, metodologías ágiles y tecnologías de punta para crear productos digitales que transforman empresas. Con presencia en Perú, Estados Unidos y Europa, entregamos soluciones de inteligencia artificial, automatización, fábrica de software, desarrollo web y mobile, y arquitectura cloud. Somos el partner tecnológico que las empresas necesitan para competir en la era digital."
    keywords={[
      "desarrollo tecnológico Perú",
      "desarrollo tecnológico América",
      "innovación tecnológica Perú",
      "empresa de tecnología Perú",
      "desarrollo de tecnología",
      "transformación digital Perú",
      "los mejores en desarrollo tecnológico",
      "tecnología para empresas Perú",
      "innovación digital América Latina",
      "partner tecnológico Perú"
    ]}
    features={[
      {
        icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
        title: "Innovación Tecnológica",
        description: "Investigamos y aplicamos las tecnologías más avanzadas: IA generativa, machine learning, blockchain, IoT y más. Llevamos innovación real a tu negocio."
      },
      {
        icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
        title: "Fábrica de Software",
        description: "Equipos senior multidisciplinarios para escalar tu producto. Desarrollo ágil, entregas iterativas y calidad de clase mundial."
      },
      {
        icon: '<path d="M12 2a10 10 0 0 1 10 10c0 5-4 8-10 8S2 17 2 12 7 2 12 2z"/><path d="M12 6v6l4 2"/>',
        title: "Inteligencia Artificial",
        description: "Machine learning, NLP, visión computacional y automatización cognitiva. Potenciamos tus procesos con IA de última generación."
      },
      {
        icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
        title: "Automatización Inteligente",
        description: "RPA, automatización de procesos y orquestación con IA. Reducimos costos, eliminamos errores y aceleramos tu operación."
      },
      {
        icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
        title: "Presencia Global",
        description: "Operaciones en Perú, Estados Unidos y Europa. Clientes en 5 países. Entregamos tecnología que compite en mercados internacionales."
      },
      {
        icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
        title: "Arquitectura Cloud",
        description: "Arquitecturas cloud-native en AWS, GCP y Azure. Microservicios, serverless, alta disponibilidad y seguridad empresarial."
      }
    ]}
    ctaText="Impulsa tu transformación tecnológica"
    ctaHref="/contacto"
  />
</BaseLayout>
