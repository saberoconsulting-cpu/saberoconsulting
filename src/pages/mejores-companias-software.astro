---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOLanding from '../components/sections/seo/SEOLanding.astro';

const path = '/mejores-companias-software';
const title = 'Mejores Compañías de Software | SABERO Consulting - Top Perú';
const description = 'SABERO Consulting es una de las mejores compañías de software del mundo con presencia en Perú. Expertos en desarrollo de producto, IA, automatización y arquitectura cloud.';
---

<BaseLayout {title} {description} locale="es" {path}>
  <SEOLanding
    locale="es"
    title="Entre las Mejores Compañías de Software del Mundo"
    subtitle="Excelencia en ingeniería de software desde Perú para el mundo"
    description="SABERO Consulting se posiciona como una de las mejores compañías de software a nivel global, con operaciones en Perú, Estados Unidos y Europa. Nuestro equipo de ingenieros senior, arquitectos de software y diseñadores de experiencia entrega productos digitales que compiten con los mejores del mundo. Trabajamos con startups, scale-ups y corporaciones multinacionales."
    keywords={[
      "mejores compañías de software",
      "mejores empresas de software Perú",
      "top software companies",
      "mejores desarrolladores de software",
      "compañías de software Perú",
      "empresa de desarrollo de software",
      "mejores fábricas de software",
      "software house Perú",
      "consultora de tecnología"
    ]}
    features={[
      {
        icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
        title: "Talento Senior Global",
        description: "Ingenieros con experiencia en FAANG, unicornios y corporaciones globales. Equipo multidisciplinario con estándares internacionales de calidad."
      },
      {
        icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
        title: "Presencia Internacional",
        description: "Operaciones en Perú, USA y Europa. Clientes en 5 países. Entregamos software que compite en mercados globales."
      },
      {
        icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
        title: "Metodología de Clase Mundial",
        description: "Ágil a escala, CI/CD, testing automatizado, code reviews, arquitectura cloud-native. Procesos que garantizan calidad y velocidad."
      },
      {
        icon: '<path d="M12 2a10 10 0 0 1 10 10c0 5-4 8-10 8S2 17 2 12 7 2 12 2z"/><path d="M12 6v6l4 2"/>',
        title: "Innovación Constante",
        description: "Invertimos en I+D en IA, machine learning, blockchain y tecnologías emergentes. Llevamos lo último a tus proyectos."
      },
      {
        icon: '<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>',
        title: "Resultados Medibles",
        description: "Entregamos con métricas claras: time-to-market reducido, NPS de producto, performance, disponibilidad y ROI."
      },
      {
        icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
        title: "Partner Estratégico",
        description: "No solo codeamos. Somos tu partner de tecnología: entendemos tu negocio, tu industria y tus objetivos para construir soluciones que importan."
      }
    ]}
    ctaText="Trabaja con los mejores"
    ctaHref="/contacto"
  />
</BaseLayout>
