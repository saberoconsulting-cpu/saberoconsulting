
---
import type { ContactData } from '../../i18n/utils/types';

interface Props {
  data: ContactData;
  locale: string;
}

const { data, locale } = Astro.props;
---

<section class="contact-page" aria-label="Contact form">
  <div class="container">
    <!-- Header editorial -->
    <div class="contact-header">
      <div class="contact-header-text">
        <h1 class="contact-title" id="contact-title">{data.title}</h1>
        <p class="contact-subtitle">{data.subtitle}</p>
      </div>
      <div class="contact-header-contact">
        <a href={`mailto:${data.email}`} class="contact-header-email">{data.email}</a>
        <span class="contact-header-response">{data.responseTime}</span>
      </div>
    </div>

    <!-- Grid: Categories + Form -->
    <div class="contact-main">
      <!-- Categories como tabs editoriales -->
      <div class="contact-categories">
        <span class="contact-categories-label">{data.categoriesTitle}</span>
        <div class="contact-categories-list">
          {data.categories.map((cat) => (
            <label class="contact-cat-item">
              <input type="radio" name="category" value={cat.value} class="contact-cat-input" />
              <span class="contact-cat-label">{cat.label}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrapper">
        <div class="contact-form-led" aria-hidden="true"></div>
        <div class="contact-form-accent" aria-hidden="true"></div>

        <form class="contact-form" action={`https://formsubmit.co/${import.meta.env?.PUBLIC_CONTACT_EMAIL || 'saberoconsulting@gmail.com'}`} method="POST" data-form>
          <input type="hidden" name="_subject" value="Nuevo contacto SABERO Consulting" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_next" value={locale === 'es' ? '/gracias' : `/${locale}/gracias`} />
          <input type="hidden" name="_autoresponse" value="Gracias por contactarnos. Hemos recibido tu mensaje y te responderemos en menos de 24 horas." />
          <input type="hidden" name="_idioma" value={locale} />

          <div class="form-body">
            <div class="form-row">
              <div class="form-field">
                <label for="name" class="form-label">{data.form.name}</label>
                <input type="text" id="name" name="nombre" required class="form-input" placeholder={`Ej: Carlos`} autocomplete="given-name" />
                <span class="form-line"></span>
              </div>
              <div class="form-field">
                <label for="lastName" class="form-label">{data.form.lastName}</label>
                <input type="text" id="lastName" name="apellido" required class="form-input" placeholder={`Ej: García`} autocomplete="family-name" />
                <span class="form-line"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="email" class="form-label">{data.form.email}</label>
                <input type="email" id="email" name="email" required class="form-input" placeholder={`ej: carlos@empresa.com`} autocomplete="email" />
                <span class="form-line"></span>
              </div>
              <div class="form-field">
                <label for="company" class="form-label">{data.form.company}</label>
                <input type="text" id="company" name="empresa" class="form-input" placeholder={`Ej: Mi Empresa S.A.C.`} autocomplete="organization" />
                <span class="form-line"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="country" class="form-label">{data.form.country}</label>
                <input type="text" id="country" name="pais" class="form-input" placeholder={`Ej: Perú`} autocomplete="country-name" />
                <span class="form-line"></span>
              </div>
              <div class="form-field">
                <label for="position" class="form-label">{data.form.position}</label>
                <input type="text" id="position" name="cargo" class="form-input" placeholder={`Ej: CEO`} autocomplete="organization-title" />
                <span class="form-line"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="companySize" class="form-label">{data.form.companySize}</label>
                <div class="form-select-wrap">
                  <select id="companySize" name="tamano_empresa" required class="form-input form-select">
                    <option value="">Seleccionar</option>
                    {data.companySizes.map((size) => (
                      <option value={size.value}>{size.label}</option>
                    ))}
                  </select>
                  <svg class="form-select-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6" /></svg>
                </div>
                <span class="form-line"></span>
              </div>
              <div class="form-field">
                <label for="industry" class="form-label">{data.form.industry}</label>
                <div class="form-select-wrap">
                  <select id="industry" name="industria" class="form-input form-select">
                    <option value="">Seleccionar</option>
                    {data.industries.map((ind) => (
                      <option value={ind.value}>{ind.label}</option>
                    ))}
                  </select>
                  <svg class="form-select-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6" /></svg>
                </div>
                <span class="form-line"></span>
              </div>
            </div>

            <div class="form-field">
              <label for="whatsapp" class="form-label">{data.form.whatsapp}</label>
              <input type="tel" id="whatsapp" name="whatsapp" class="form-input" placeholder={`+51 999 888 777`} autocomplete="tel" />
              <span class="form-line"></span>
            </div>

            <div class="form-field">
              <label for="message" class="form-label">{data.form.message}</label>
              <textarea id="message" name="mensaje" rows="4" required class="form-input form-textarea" placeholder={data.form.message}></textarea>
              <span class="form-line"></span>
            </div>

            <div class="form-checkboxes">
              <label class="form-checkbox">
                <input type="checkbox" name="privacidad" required class="checkbox-input" />
                <span class="checkbox-box">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </span>
                <span class="checkbox-text">{data.form.privacy}</span>
              </label>
              <label class="form-checkbox">
                <input type="checkbox" name="newsletter" class="checkbox-input" />
                <span class="checkbox-box">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </span>
                <span class="checkbox-text">{data.form.newsletter}</span>
              </label>
            </div>
          </div>

          <button type="submit" class="form-btn">
            <span>{data.form.submit}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </form>
      </div>
    </div>

    <!-- Footer badges -->
    <div class="contact-footer">
      <div class="contact-footer-item">
        <div class="contact-footer-dot" style="background: #0B2F7D;"></div>
        <span>Email: <a href={`mailto:${data.email}`}>{data.email}</a></span>
      </div>
      <div class="contact-footer-item">
        <div class="contact-footer-dot" style="background: #E53935;"></div>
        <span>WhatsApp: <a href={`https://wa.me/${data.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener noreferrer">{data.whatsapp}</a></span>
      </div>
      <div class="contact-footer-item">
        <div class="contact-footer-dot" style="background: #2F80FF;"></div>
        <span>{data.responseTime}</span>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLInputElement>('.contact-cat-input').forEach((el) => {
    el.addEventListener('change', () => {
      if (el.checked) {
        const hiddenCat = document.querySelector<HTMLInputElement>('input[name="categoria"]');
        if (hiddenCat) hiddenCat.value = el.value;
      }
    });
  });

  const form = document.querySelector('[data-form]');
  if (form) {
    const hiddenCat = document.createElement('input');
    hiddenCat.type = 'hidden';
    hiddenCat.name = 'categoria';
    hiddenCat.value = '';
    form.appendChild(hiddenCat);

    // --- Elementos a validar ---
    const requiredInputs = form.querySelectorAll<HTMLInputElement>('input[required], textarea[required], select[required]');
    const privacyCheckbox = form.querySelector<HTMLInputElement>('input[name="privacidad"]');
    const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');

    // --- Función para marcar/desmarcar error ---
    function markError(el: Element, valid: boolean) {
      // Buscar el contenedor: .form-field para inputs/selects/textarea, .form-checkbox para checkboxes
      const field = el.closest('.form-field') || el.closest('.form-checkbox');
      if (!field) return;

      if (field.classList.contains('form-checkbox')) {
        field.classList.toggle('form-checkbox--error', !valid);
      } else {
        field.classList.toggle('form-field--error', !valid);
      }
    }

    // --- Validación de email ---
    function isValidEmail(value: string): boolean {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
    }

    // --- Validar un campo individual ---
    function validateField(el: Element): boolean {
      const input = el as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

      // Si es un select, validar que no esté en valor vacío
      if (el.tagName === 'SELECT') {
        const valid = input.value !== '';
        markError(el, valid);
        return valid;
      }

      // Si es un checkbox (solo privacidad)
      if (el.getAttribute('type') === 'checkbox') {
        const valid = (el as HTMLInputElement).checked;
        markError(el, valid);
        return valid;
      }

      // Si es email, validar formato
      if (el.getAttribute('type') === 'email' && input.value.trim() !== '') {
        const valid = isValidEmail(input.value.trim());
        markError(el, valid);
        return valid;
      }

      // Para los demás campos requeridos
      const valid = input.value.trim() !== '';
      markError(el, valid);
      return valid;
    }

    // --- Evento submit ---
    form.addEventListener('submit', (e) => {
      let hasError = false;

      // Validar campos requeridos (input, textarea, select)
      requiredInputs.forEach((el) => {
        if (!validateField(el)) hasError = true;
      });

      // Validar checkbox de privacidad
      if (privacyCheckbox && !privacyCheckbox.checked) {
        markError(privacyCheckbox, false);
        hasError = true;
      }

      // Validar email (aunque no sea required, si tiene contenido debe ser válido)
      if (emailInput && emailInput.value.trim() !== '' && !isValidEmail(emailInput.value.trim())) {
        markError(emailInput, false);
        hasError = true;
      }

      if (hasError) {
        e.preventDefault();
        // Enfocar el primer campo con error
        const firstError = form.querySelector<HTMLElement>('.form-field--error, .form-checkbox--error');
        if (firstError) {
          const focusable = firstError.querySelector<HTMLElement>('input, textarea, select');
          if (focusable) focusable.focus();
        }
      }
    });

    // --- Limpiar errores en tiempo real ---
    form.querySelectorAll<HTMLInputElement>('input, textarea, select').forEach((el) => {
      el.addEventListener('input', () => {
        // Solo validar si tiene la clase de error, para no molestar al usuario mientras escribe
        const field = el.closest('.form-field') || el.closest('.form-checkbox');
        if (field && (field.classList.contains('form-field--error') || field.classList.contains('form-checkbox--error'))) {
          validateField(el);
        }
      });
      el.addEventListener('change', () => {
        validateField(el);
      });
      el.addEventListener('blur', () => {
        // Al perder el foco, si está vacío y es requerido, marcar error
        if (el.hasAttribute('required') || el.getAttribute('type') === 'email') {
          validateField(el);
        }
      });
    });

    // --- Evento change para checkbox de privacidad ---
    if (privacyCheckbox) {
      privacyCheckbox.addEventListener('change', () => {
        markError(privacyCheckbox, privacyCheckbox.checked);
      });
    }
  }
</script>

<style>
  /* ============================================
     CONTACT PAGE — Editorial Premium
     Fondo crema + numeración + acentos azul/rojo
  ============================================ */
  .contact-page {
    background: #FAF9F5;
    padding: 80px 0;
    position: relative;
  }

  /* ===== HEADER EDITORIAL ===== */
  .contact-header {
    text-align: center;
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid #E0D8CC;
  }

  .contact-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: #0B2F7D;
    background: linear-gradient(135deg, #E62325, #1D5BF1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 auto 12px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 720px;
  }

  .contact-subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: #5E6472;
    margin: 0 auto;
    max-width: 560px;
  }

  .contact-header-contact {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .contact-header-email {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #0B2F7D;
    background: linear-gradient(135deg, #E62325, #1D5BF1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
    margin-bottom: 4px;
  }

  .contact-header-email:hover {
    opacity: 0.8;
  }

  .contact-header-response {
    font-size: 0.75rem;
    color: #0B2F7D;
    background: linear-gradient(135deg, #E62325, #1D5BF1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
  }

  /* ===== MAIN GRID ===== */
  .contact-main {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 48px;
    align-items: start;
  }

  /* ===== CATEGORÍAS ===== */
  .contact-categories {
    position: sticky;
    top: 120px;
  }

  .contact-categories-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #7A8290;
    margin-bottom: 20px;
  }

  .contact-categories-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-cat-item {
    cursor: pointer;
    display: block;
  }

  .contact-cat-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .contact-cat-label {
    display: block;
    padding: 10px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #5E6472;
    border-left: 2px solid transparent;
    transition: all 250ms ease;
    border-radius: 0 6px 6px 0;
  }

  .contact-cat-label:hover {
    color: #0A1628;
    background: #F0EDE6;
    border-left-color: #B8C4D4;
  }

  .contact-cat-input:checked + .contact-cat-label {
    color: #0B2F7D;
    font-weight: 700;
    background: #E8F0FF;
    border-left-color: #0B2F7D;
  }

  /* ===== FORM WRAPPER ===== */
  .contact-form-wrapper {
    position: relative;
    background: #FFFFFF;
    border: 1px solid #E0D8CC;
    border-radius: 16px;
    padding: 40px 40px 48px;
    overflow: hidden;
  }

  .contact-form-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #0B2F7D, #E53935, #0B2F7D);
    background-size: 200% 100%;
    animation: contactAccentMove 3s ease-in-out infinite;
  }

  @keyframes contactAccentMove {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .contact-form-led {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(11, 47, 125, 0.03), rgba(229, 57, 53, 0.03), transparent);
    animation: contactLedSweep 5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes contactLedSweep {
    0% { left: -100%; }
    50% { left: 100%; }
    100% { left: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-form-accent {
      animation: none;
    }
    .contact-form-led {
      animation: none;
      display: none;
    }
  }

  /* ===== FORM ===== */
  .contact-form {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .form-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }

  .form-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #3A4050;
  }

  .form-input {
    padding: 12px 0;
    font-size: 0.95rem;
    color: #0A1628;
    background: transparent;
    border: none;
    border-bottom: 1.5px solid #D8D0C4;
    transition: border-color 250ms ease;
    font-family: inherit;
    width: 100%;
    outline: none;
    border-radius: 0;
  }

  .form-input::placeholder {
    color: #B8B0A4;
    font-weight: 400;
  }

  .form-input:hover {
    border-color: #B8B0A4;
  }

  .form-input:focus {
    border-color: #0B2F7D;
  }

  .form-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #0B2F7D;
    transition: width 350ms ease;
  }

  .form-input:focus ~ .form-line {
    width: 100%;
  }

  .form-select-wrap {
    position: relative;
  }

  .form-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    padding-right: 28px;
    cursor: pointer;
    background: transparent;
  }

  .form-select option {
    background: #FFFFFF;
    color: #0A1628;
    padding: 8px 12px;
  }

  .form-select-icon {
    position: absolute;
    right: 0;
    bottom: 14px;
    color: #7A8290;
    pointer-events: none;
    transition: transform 250ms ease;
  }

  .form-input:focus ~ .form-select-icon {
    transform: rotate(180deg);
    color: #0B2F7D;
  }

  .form-textarea {
    resize: vertical;
    min-height: 80px;
    line-height: 1.6;
  }

  /* Error state for form fields */
  .form-field--error .form-label {
    color: #E53935;
  }

  .form-field--error .form-input {
    border-bottom-color: #E53935;
  }

  .form-field--error .form-line {
    background: #E53935;
    width: 100%;
  }

  .form-field--error .form-select-icon {
    color: #E53935;
  }

  /* Checkboxes */
  .form-checkboxes {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 4px;
  }

  .form-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
  }

  .checkbox-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .checkbox-box {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border: 1.5px solid #C8C0B4;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 200ms ease;
    margin-top: 2px;
  }

  .checkbox-box svg {
    opacity: 0;
    transform: scale(0);
    transition: all 200ms ease;
    color: #FFFFFF;
  }

  .checkbox-input:checked + .checkbox-box {
    background: #0B2F7D;
    border-color: #0B2F7D;
  }

  .checkbox-input:checked + .checkbox-box svg {
    opacity: 1;
    transform: scale(1);
  }

  .checkbox-text {
    font-size: 0.82rem;
    color: #5E6472;
    line-height: 1.5;
  }

  /* Error state for checkboxes */
  .form-checkbox--error .checkbox-box {
    border-color: #E53935;
    background: #FFF0F0;
  }

  .form-checkbox--error .checkbox-text {
    color: #E53935;
  }

  .form-checkbox--error .checkbox-input:checked + .checkbox-box {
    background: #E53935;
    border-color: #E53935;
  }

  /* Submit button */
  .form-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 32px;
    padding: 16px 40px;
    font-size: 0.9rem;
    font-weight: 700;
    color: #FFFFFF;
    background: #0B2F7D;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: all 300ms ease;
    font-family: inherit;
    position: relative;
    overflow: hidden;
  }

  .form-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);
    transform: translateX(-100%);
    transition: transform 500ms ease;
  }

  .form-btn:hover::before {
    transform: translateX(100%);
  }

  .form-btn:hover {
    background: #0A2566;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(11, 47, 125, 0.2);
  }

  .form-btn svg {
    transition: transform 300ms ease;
  }

  .form-btn:hover svg {
    transform: translateX(4px);
  }

  /* ===== FOOTER CONTACT ===== */
  .contact-footer {
    display: flex;
    gap: 32px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #E0D8CC;
    flex-wrap: wrap;
  }

  .contact-footer-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: #5E6472;
  }

  .contact-footer-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .contact-footer-item a {
    color: #0B2F7D;
    font-weight: 600;
