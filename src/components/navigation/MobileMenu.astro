---
import type { NavigationData } from '../../i18n/utils/types';
import type { SupportedLocale } from '../../i18n/utils/types';
import { t } from '../../i18n/ui/index';
import { localizeNavHref } from '../../i18n/routes/map';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  navigation: NavigationData;
  currentLocale: SupportedLocale;
  path: string;
  isOpen: boolean;
}

const { navigation, currentLocale, path } = Astro.props;
const megaMenuKeys = Object.keys(navigation.megaMenus || {});
const items = navigation.main || [];
---

<div class="mobile-menu" data-mobile-menu>
  <div class="mobile-menu-overlay" data-close-mobile></div>
  <div class="mobile-menu-panel">
    <div class="mobile-menu-header">
      <span class="mobile-menu-title">{t(currentLocale, 'header.menu')}</span>
      <button class="mobile-close" data-close-mobile aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav">
      <ul class="mobile-nav-list">
        {items.map((item) => {
          const menuKey = megaMenuKeys.find((k) => item.href.includes(k));
          const megaSection = menuKey ? navigation.megaMenus[menuKey] : null;

          return (
            <li class="mobile-nav-item">
              {megaSection ? (
                <details class="mobile-accordion">
                  <summary class="mobile-accordion-trigger">
                    <span>{item.label}</span>
                    <svg class="accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </summary>
                  <div class="mobile-accordion-content">
                    {megaSection.columns.map((col) => (
                      <div class="mobile-col">
                        {col.title && <h4 class="mobile-col-title">{col.title}</h4>}
                        {col.text && <p class="mobile-col-text">{col.text}</p>}
                        {(col.items || []).length > 0 && (
                          <ul class="mobile-col-list">
                            {col.items.map((subItem) => (
                              <li>
                                <a href={localizeNavHref(subItem.href, currentLocale)} class="mobile-sub-link">
                                  {subItem.label}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </div>
                    ))}
                  </div>
                </details>
              ) : (
                <a href={localizeNavHref(item.href, currentLocale)} class="mobile-simple-link">
                  {item.label}
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="mobile-cta">
      <a href={localizeNavHref('/contacto', currentLocale)} class="mobile-contact-btn">
        {t(currentLocale, 'header.cta')}
      </a>
    </div>

    <LanguageSwitcher currentLocale={currentLocale} path={path} variant="mobile" />
  </div>
</div>

<script>
  // This script handles toggling the mobile menu
  const menu = document.querySelector('[data-mobile-menu]');
  const toggleBtn = document.querySelector('[data-toggle-mobile]');

  function openMobile() {
    if (!menu) return;
    menu.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMobile() {
    if (!menu) return;
    menu.classList.remove('open');
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (menu?.classList.contains('open')) {
      closeMobile();
    } else {
      openMobile();
    }
  });

  // Close on overlay click or close button
  menu?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('[data-close-mobile]') || target.classList.contains('mobile-menu-overlay')) {
      closeMobile();
    }
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      closeMobile();
    }
  });

  // Close on astro page navigation
  document.addEventListener('astro:page-load', () => {
    closeMobile();
  });
</script>

<style>
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .mobile-menu-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    background: #fff;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
    overflow-y: auto;
    z-index: 10000;
  }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    border-bottom: 1px solid #eaeef2;
  }

  .mobile-menu-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1a1a2e;
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: #475467;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }

  .mobile-close:hover {
    background: #f5f7fa;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-item {
    border-bottom: 1px solid #eaeef2;
  }

  .mobile-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
    cursor: pointer;
    list-style: none;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .mobile-accordion-trigger::-webkit-details-marker {
    display: none;
  }

  .accordion-icon {
    transition: transform 0.2s ease;
    color: #98a2b3;
    flex-shrink: 0;
  }

  details[open] .accordion-icon {
    transform: rotate(180deg);
  }

  .mobile-accordion-content {
    padding: 0 24px 16px;
  }

  .mobile-col {
    margin-bottom: 16px;
  }

  .mobile-col-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #0066ff;
    margin-bottom: 8px;
  }

  .mobile-col-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #475467;
    margin-bottom: 12px;
  }

  .mobile-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-sub-link {
    display: block;
    padding: 8px 0;
    font-size: 0.875rem;
    color: #475467;
    text-decoration: none;
  }

  .mobile-sub-link:hover {
    color: #0066ff;
  }

  .mobile-simple-link {
    display: block;
    padding: 16px 24px;
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
    text-decoration: none;
  }

  .mobile-simple-link:hover {
    color: #0066ff;
  }

  .mobile-cta {
    padding: 16px 24px;
    border-top: 1px solid #eaeef2;
  }

  .mobile-contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 12px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    border: none;
    border-radius: 9999px;
    background: linear-gradient(135deg, #4da6ff, #0066ff 50%, #0052cc);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 102, 255, 0.2);
  }

  @media (min-width: 1025px) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>
