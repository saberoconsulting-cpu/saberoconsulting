---
import type { NavigationData } from '../../i18n/utils/types';
import type { SupportedLocale } from '../../i18n/utils/types';
import { t } from '../../i18n/ui/index';
import { localizeNavHref } from '../../i18n/routes/map';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  navigation: NavigationData;
  currentLocale: SupportedLocale;
  path: string;
  isOpen: boolean;
  onClose?: string;
}

const { navigation, currentLocale, path, isOpen } = Astro.props;
const megaMenuKeys = Object.keys(navigation.megaMenus);
---

<div class={`mobile-menu ${isOpen ? 'open' : ''}`} aria-hidden={!isOpen}>
  <div class="mobile-menu-overlay" data-close-mobile></div>
  <div class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <div class="mobile-menu-header">
      <span class="mobile-menu-title">{t(currentLocale, 'header.menu')}</span>
      <button class="mobile-close" data-close-mobile aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav" aria-label="Main navigation">
      <ul class="mobile-nav-list">
        {navigation.main.map((item) => {
          const menuKey = megaMenuKeys.find((k) =>
            item.href.includes(k) || item.label.toLowerCase().includes(k)
          );
          const megaSection = menuKey ? navigation.megaMenus[menuKey] : null;

          return (
            <li class="mobile-nav-item">
              <details class="mobile-accordion">
                <summary class="mobile-accordion-trigger">
                  <span>{item.label}</span>
                  <svg class="accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </summary>
                {megaSection && (
                  <div class="mobile-accordion-content">
                    {megaSection.columns.map((col) => (
                      <div class="mobile-col">
                        {col.title && (
                          <h4 class="mobile-col-title">{col.title}</h4>
                        )}
                        {col.text && (
                          <p class="mobile-col-text">{col.text}</p>
                        )}
                        {col.items.length > 0 && (
                          <ul class="mobile-col-list">
                            {col.items.map((subItem) => (
                              <li>
                                <a href={localizeNavHref(subItem.href, currentLocale)} class="mobile-sub-link">
                                  {subItem.label}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </div>
                    ))}
                  </div>
                )}
              </details>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="mobile-cta">
      <a href={localizeNavHref('/contacto', currentLocale)} class="btn btn-primary mobile-contact-btn">
        {t(currentLocale, 'header.cta')}
      </a>
    </div>

    <LanguageSwitcher currentLocale={currentLocale} path={path} variant="mobile" />
  </div>
</div>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const closeTrigger = target.closest('[data-close-mobile]') as HTMLElement | null;
    if (closeTrigger) {
      const menu = closeTrigger.closest('.mobile-menu');
      if (menu) {
        menu.classList.remove('open');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    }
  });

  document.addEventListener('astro:page-load', () => {
    const menu = document.querySelector('.mobile-menu');
    if (menu) {
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1500;
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-menu-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    background-color: var(--bg-primary);
    box-shadow: var(--shadow-xl);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--border-color);
  }

  .mobile-menu-title {
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
  }

  .mobile-close:hover {
    background-color: var(--bg-tertiary);
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
  }

  .mobile-accordion {
    border-bottom: 1px solid var(--border-color);
  }

  .mobile-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
  }

  .mobile-accordion-trigger::-webkit-details-marker {
    display: none;
  }

  .accordion-icon {
    transition: transform var(--transition-base);
    color: var(--text-tertiary);
  }

  details[open] .accordion-icon {
    transform: rotate(180deg);
  }

  .mobile-accordion-content {
    padding: 0 var(--space-6) var(--space-6);
  }

  .mobile-col {
    margin-bottom: var(--space-4);
  }

  .mobile-col-title {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent-color);
    margin-bottom: var(--space-2);
  }

  .mobile-col-text {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-3);
  }

  .mobile-col-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mobile-sub-link {
    display: block;
    padding: var(--space-2) 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
  }

  .mobile-sub-link:hover {
    color: var(--accent-color);
  }

  .mobile-cta {
    padding: var(--space-4) var(--space-6);
  }

  .mobile-contact-btn {
    width: 100%;
  }

  @media (min-width: 1025px) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>
