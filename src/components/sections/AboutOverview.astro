---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  es: {
    title: 'Nosotros',
    subtitle: 'SABERO Consulting es una software factory nacida en Peru, con enfoque en construir productos y plataformas digitales para organizaciones con vision de crecimiento en America y Europa.',
    highlight: 'Construimos relaciones de largo plazo, no solo software.',
    stats: [
      { number: '2018', label: 'Fundacion' },
      { number: '+40', label: 'Profesionales' },
      { number: '+30', label: 'Proyectos entregados' },
      { number: '3', label: 'Continentes' },
    ],
    items: [
      { title: 'Peru como punto de partida', desc: 'Nacimos en Peru con estandar internacional. Ventaja de costo, talento y zona horaria.' },
      { title: 'Enfoque regional', desc: 'Operamos para America y Europa, combinando cercania cultural con capacidad remota.' },
      { title: 'Delivery agil', desc: 'Equipos integrados, ciclos cortos y transparencia total en cada etapa.' },
      { title: 'Excelencia tecnica', desc: 'Tecnologia correcta para cada problema, sin modas ni sobreingenieria.' },
      { title: 'Diseno orientado a negocio', desc: 'Cada decision tecnica responde a un objetivo de negocio medible.' },
    ],
  },
  en: {
    title: 'About us',
    subtitle: 'SABERO Consulting is a software factory born in Peru, focused on building digital products and platforms for organizations with growth ambitions in America and Europe.',
    highlight: 'We build long-term relationships, not just software.',
    stats: [
      { number: '2018', label: 'Founded' },
      { number: '+40', label: 'Professionals' },
      { number: '+30', label: 'Projects delivered' },
      { number: '3', label: 'Continents' },
    ],
    items: [
      { title: 'Peru as starting point', desc: 'Born in Peru with international standards. Cost, talent and timezone advantages.' },
      { title: 'Regional focus', desc: 'We operate for America and Europe, combining cultural proximity with remote delivery.' },
      { title: 'Agile delivery', desc: 'Integrated teams, short cycles and total transparency at every stage.' },
      { title: 'Technical excellence', desc: 'Right technology for each problem, without trends or overengineering.' },
      { title: 'Business-driven design', desc: 'Every technical decision responds to a measurable business objective.' },
    ],
  },
  pt: {
    title: 'Nos',
    subtitle: 'A SABERO Consulting e uma fabrica de software nascida no Peru, focada em construir produtos e plataformas digitais para organizacoes com visao de crescimento na America e Europa.',
    highlight: 'Construimos relacoes de longo prazo, nao apenas software.',
    stats: [
      { number: '2018', label: 'Fundacao' },
      { number: '+40', label: 'Profissionais' },
      { number: '+30', label: 'Projetos entregues' },
      { number: '3', label: 'Continentes' },
    ],
    items: [
      { title: 'Peru como ponto de partida', desc: 'Nascemos no Peru com padrao internacional. Vantagem de custo, talento e fuso.' },
      { title: 'Enfoque regional', desc: 'Operamos para America e Europa, combinando proximidade cultural com entrega remota.' },
      { title: 'Delivery agil', desc: 'Equipes integradas, ciclos curtos e transparencia total.' },
      { title: 'Excelencia tecnica', desc: 'Tecnologia certa para cada problema, sem modismos.' },
      { title: 'Design orientado a negocios', desc: 'Cada decisao tecnica responde a um objetivo mensuravel.' },
    ],
  },
  fr: {
    title: 'Nous',
    subtitle: 'SABERO Consulting est une fabrique de logiciels nee au Perou, axee sur la construction de produits et plateformes numeriques pour les organisations ayant une vision de croissance en Amerique et en Europe.',
    highlight: 'Nous construisons des relations a long terme, pas seulement des logiciels.',
    stats: [
      { number: '2018', label: 'Fondee' },
      { number: '+40', label: 'Professionnels' },
      { number: '+30', label: 'Projets livres' },
      { number: '3', label: 'Continents' },
    ],
    items: [
      { title: 'Perou comme point de depart', desc: 'Nes au Perou avec des standards internationaux.' },
      { title: 'Approche regionale', desc: 'Nous operons pour l\'Amerique et l\'Europe.' },
      { title: 'Livraison agile', desc: 'Equipes integrees, cycles courts et transparence totale.' },
      { title: 'Excellence technique', desc: 'La bonne technologie pour chaque probleme.' },
      { title: 'Design oriente metier', desc: 'Chaque decision technique repond a un objectif metier.' },
    ],
  },
}[locale] || {
  title: 'Nosotros',
  subtitle: '',
  highlight: '',
  stats: [],
  items: [],
};
---

<section class="about" id="nosotros" aria-label={content.title}>
  <div class="container">
    <div class="about-header">
      <h2 class="about-title">{content.title}</h2>
      <p class="about-subtitle">{content.subtitle}</p>
      <p class="about-highlight">{content.highlight}</p>
    </div>

    <div class="about-stats">
      {content.stats.map((stat) => (
        <div class="about-stat">
          <span class="about-stat-number">{stat.number}</span>
          <span class="about-stat-label">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="about-divider">
      <span></span>
    </div>

    <div class="about-grid">
      <div class="about-image-frame">
        <div class="about-image" style="background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80')"></div>
        <div class="about-image-overlay"></div>
        <div class="about-image-badge">SABERO</div>
      </div>
      <div class="about-values">
        {content.items.map((item, i) => (
          <article class="about-value">
            <div class="about-value-num">0{i + 1}</div>
            <div class="about-value-content">
              <h3 class="about-value-title">{item.title}</h3>
              <p class="about-value-desc">{item.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding: var(--space-24) 0;
    background-color: var(--bg-primary);
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 102, 255, 0.04) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .about-header {
    margin-bottom: var(--space-14);
    max-width: 640px;
  }

  .about-title {
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 800;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .about-subtitle {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .about-highlight {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-electric-blue);
    margin-bottom: 0;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-16);
    padding: var(--space-8);
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-xl);
  }

  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
  }

  .about-stat-number {
    font-size: var(--text-4xl);
    font-weight: 900;
    color: var(--color-electric-blue);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .about-stat-label {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .about-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-16);
  }

  .about-divider span {
    display: block;
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-electric-blue), transparent);
    border-radius: 2px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .about-image-frame {
    position: relative;
    height: 500px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .about-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .about-image-frame:hover .about-image {
    transform: scale(1.04);
  }

  .about-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 22, 40, 0.6) 0%,
      transparent 50%,
      rgba(10, 22, 40, 0.2) 100%
    );
  }

  .about-image-badge {
    position: absolute;
    bottom: var(--space-8);
    left: var(--space-8);
    font-size: var(--text-4xl);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.08);
    letter-spacing: 8px;
    line-height: 1;
  }

  .about-values {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-value {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    cursor: default;
  }

  .about-value:hover {
    background: rgba(255,255,255,0.02);
  }

  .about-value-num {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-electric-blue);
    font-family: var(--font-mono, monospace);
    min-width: 32px;
    padding-top: 2px;
  }

  .about-value-content {
    flex: 1;
  }

  .about-value-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: var(--space-2);
  }

  .about-value-desc {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    line-height: 1.7;
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .about-image-frame {
      height: 360px;
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: var(--space-16) 0;
    }

    .about-stats {
      grid-template-columns: repeat(2, 1fr);
      padding: var(--space-6);
      gap: var(--space-6);
    }

    .about-stat-number {
      font-size: var(--text-3xl);
    }

    .about-image-frame {
      height: 280px;
    }
  }

  @media (max-width: 480px) {
    .about-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }
</style>
