---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  es: {
    title: 'Industrias',
    subtitle: 'Cada industria tiene procesos, metricas y retos distintos. Adaptamos producto, arquitectura y experiencia segun tu contexto.',
    industries: [
      { title: 'PropTech', desc: 'Plataformas inmobiliarias, portales de propiedades, soluciones de matching y gestion de activos.', image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80' },
      { title: 'Fintech y pagos', desc: 'Procesamiento de pagos, integraciones financieras, wallets y soluciones de banking.', image: 'https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=800&q=80' },
      { title: 'Marketplaces y plataformas', desc: 'Portales B2B y B2C, plataformas multi-vendedor, sistemas de matching y booking.', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Educacion y EdTech', desc: 'Plataformas de aprendizaje, campus virtuales, sistemas de gestion educativa.', image: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&w=800&q=80' },
      { title: 'Logistica y operaciones', desc: 'Sistemas de tracking, gestion de flotas, optimizacion de rutas y WMS.', image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Soluciones internas empresariales', desc: 'Intranets, ERPs a medida, dashboards de gestion y automatizacion interna.', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80' },
    ],
  },
  en: {
    title: 'Industries',
    subtitle: 'Each industry has distinct processes, metrics and challenges. We adapt product, architecture and experience to your context.',
    industries: [
      { title: 'PropTech', desc: 'Real estate platforms, property portals, matching solutions and asset management.', image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80' },
      { title: 'Fintech & payments', desc: 'Payment processing, financial integrations, wallets and banking solutions.', image: 'https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=800&q=80' },
      { title: 'Marketplaces & platforms', desc: 'B2B and B2C portals, multi-vendor platforms, matching and booking systems.', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Education & EdTech', desc: 'Learning platforms, virtual campuses, educational management systems.', image: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&w=800&q=80' },
      { title: 'Logistics & operations', desc: 'Tracking systems, fleet management, route optimization and WMS.', image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Enterprise internal solutions', desc: 'Intranets, custom ERPs, management dashboards and internal automation.', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80' },
    ],
  },
  pt: {
    title: 'Industrias',
    subtitle: 'Cada industria tem processos, metricas e desafios distintos. Adaptamos produto, arquitetura e experiencia ao seu contexto.',
    industries: [
      { title: 'PropTech', desc: 'Plataformas imobiliarias, portais de propriedades, solucoes de matching e gestao de ativos.', image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80' },
      { title: 'Fintech e pagamentos', desc: 'Processamento de pagamentos, integracoes financeiras, wallets e solucoes bancarias.', image: 'https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=800&q=80' },
      { title: 'Marketplaces e plataformas', desc: 'Portais B2B e B2C, plataformas multi-vendedor, sistemas de matching e booking.', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Educacao e EdTech', desc: 'Plataformas de aprendizado, campus virtuais, sistemas de gestao educacional.', image: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&w=800&q=80' },
      { title: 'Logistica e operacoes', desc: 'Sistemas de tracking, gestao de frotas, otimizacao de rotas e WMS.', image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Solucoes internas empresariais', desc: 'Intranets, ERPs sob medida, dashboards de gestao e automacao interna.', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80' },
    ],
  },
  fr: {
    title: 'Industries',
    subtitle: 'Chaque industrie a des processus, des metriques et des defis distincts. Nous adaptons le produit, l\'architecture et l\'experience a votre contexte.',
    industries: [
      { title: 'PropTech', desc: 'Plateformes immobilieres, portails de proprietes, solutions de matching et gestion d\'actifs.', image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80' },
      { title: 'Fintech et paiements', desc: 'Traitement des paiements, integrations financieres, wallets et solutions bancaires.', image: 'https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=800&q=80' },
      { title: 'Marketplaces et plateformes', desc: 'Portails B2B et B2C, plateformes multi-vendeurs, systemes de matching et booking.', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Education et EdTech', desc: 'Plateformes d\'apprentissage, campus virtuels, systemes de gestion educative.', image: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&w=800&q=80' },
      { title: 'Logistique et operations', desc: 'Systemes de tracking, gestion de flotte, optimisation d\'itineraire et WMS.', image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80' },
      { title: 'Solutions internes entreprises', desc: 'Intranets, ERP sur mesure, tableaux de bord et automatisation interne.', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80' },
    ],
  },
}[locale] || {
  title: 'Industrias',
  subtitle: '',
  industries: [],
};
---

<section class="industries" id="industrias" aria-label={content.title}>
  <div class="container">
    <div class="industries-header">
      <h2 class="industries-title">{content.title}</h2>
      <p class="industries-subtitle">{content.subtitle}</p>
    </div>
    <div class="industries-grid">
      {content.industries.map((ind) => (
        <article class="industry-card">
          <div class="industry-card-bg" style={`background-image: url(${ind.image})`}></div>
          <div class="industry-card-overlay"></div>
          <div class="industry-card-content">
            <div class="industry-card-tag">{ind.title}</div>
            <p class="industry-card-desc">{ind.desc}</p>
          </div>
          <div class="industry-card-border"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .industries {
    position: relative;
    padding: var(--space-24) 0;
    background-color: var(--bg-secondary);
    overflow: hidden;
  }

  .industries-header {
    margin-bottom: var(--space-12);
  }

  .industries-title {
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 800;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .industries-subtitle {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    max-width: 600px;
    line-height: 1.7;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .industry-card {
    position: relative;
    height: 340px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: default;
    isolation: isolate;
  }

  .industry-card:nth-child(2) {
    transform: translateY(30px);
  }

  .industry-card:nth-child(5) {
    transform: translateY(30px);
  }

  .industry-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .industry-card:hover .industry-card-bg {
    transform: scale(1.08);
  }

  .industry-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 22, 40, 0.15) 0%,
      rgba(10, 22, 40, 0.85) 60%,
      rgba(10, 22, 40, 0.95) 100%
    );
    z-index: 1;
    transition: all 0.5s ease;
  }

  .industry-card:hover .industry-card-overlay {
    background: linear-gradient(
      180deg,
      rgba(10, 22, 40, 0.1) 0%,
      rgba(10, 22, 40, 0.75) 50%,
      rgba(10, 22, 40, 0.95) 100%
    );
  }

  .industry-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-8);
    z-index: 2;
  }

  .industry-card-tag {
    display: inline-block;
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: var(--space-3);
    position: relative;
    padding-bottom: var(--space-2);
  }

  .industry-card-tag::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 32px;
    height: 3px;
    background: var(--color-electric-blue);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .industry-card:hover .industry-card-tag::after {
    width: 60px;
  }

  .industry-card-desc {
    font-size: var(--text-sm);
    color: var(--color-gray-300);
    line-height: 1.7;
    margin-bottom: 0;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.5s ease;
  }

  .industry-card:hover .industry-card-desc {
    max-height: 120px;
    opacity: 1;
    margin-top: var(--space-3);
  }

  .industry-card-border {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-xl);
    z-index: 3;
    pointer-events: none;
    transition: border-color 0.4s ease;
  }

  .industry-card:hover .industry-card-border {
    border-color: rgba(0, 102, 255, 0.2);
  }

  @media (max-width: 1024px) {
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .industry-card:nth-child(2),
    .industry-card:nth-child(5) {
      transform: translateY(0);
    }

    .industry-card:nth-child(3) {
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .industries {
      padding: var(--space-16) 0;
    }

    .industries-grid {
      grid-template-columns: 1fr;
    }

    .industry-card {
      height: 280px;
    }

    .industry-card-desc {
      max-height: 120px;
      opacity: 1;
      margin-top: var(--space-3);
    }
  }
</style>
