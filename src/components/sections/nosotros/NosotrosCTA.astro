---
// ============================================
// SABERO Consulting - Nosotros CTA
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const content: Record<string, { title: string; subtitle: string; cta: string }> = {
  es: {
    title: '¿Listo para construir tu próximo producto digital?',
    subtitle: 'Conversemos sin compromiso. Te responderemos en menos de 24 horas.',
    cta: 'Contáctanos',
  },
  en: {
    title: 'Ready to build your next digital product?',
    subtitle: "Let's talk without commitment. We'll respond within 24 hours.",
    cta: 'Contact us',
  },
  pt: {
    title: 'Pronto para construir seu próximo produto digital?',
    subtitle: 'Vamos conversar sem compromisso. Responderemos em até 24 horas.',
    cta: 'Fale conosco',
  },
  fr: {
    title: 'Prêt à construire votre prochain produit numérique?',
    subtitle: 'Parlons-en sans engagement. Nous répondrons en moins de 24 heures.',
    cta: 'Contactez-nous',
  },
};

const c = content[locale] || content.es;
---

<section class="nosotros-cta" aria-label="Call to action">
  <div class="container">
    <div class="nosotros-cta-content">
      <h2 class="nosotros-cta-title">{c.title}</h2>
      <p class="nosotros-cta-subtitle">{c.subtitle}</p>
      <a href={locale === 'es' ? '/contacto/' : `/${locale}/contacto/`} class="nosotros-cta-button">
        <span>{c.cta}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .nosotros-cta {
    padding: 80px 0;
    text-align: center;
    background: linear-gradient(135deg, #0a1628, #1a2a4a);
  }
  .nosotros-cta-title {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 16px;
  }
  .nosotros-cta-subtitle {
    color: #94a3b8;
    margin-bottom: 32px;
  }
  .nosotros-cta-button {
    display: inline-flex;
    padding: 16px 40px;
    background: #0066ff;
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
  }
</style>
