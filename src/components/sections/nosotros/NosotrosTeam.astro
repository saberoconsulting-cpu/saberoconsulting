---
// ============================================
// SABERO Consulting - Nosotros Team
// Layout: Izquierda 3 fundadores (columna) | Derecha foto equipo
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const team = [
  { name: 'Roberto Carlos López', role: 'CEO & Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQHxQwKjH95FnQ/profile-displayphoto-scale_400_400/B4EZmtVHEMIwAg-/0/1759549622234?e=1783555200&v=beta&t=fqj5e4RFTLMBWXRNSQMWq14MlUTlYldfeAryFLS1wGo', desc: 'Lidera la visión y estrategia de SABERO Consulting.', linkedin: '#' },
  { name: 'Rodrigo Salva Saccatoma', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D5603AQExVk7shj_rRw/profile-displayphoto-shrink_800_800/B56ZRwhk4RHsAc-/0/1737054637971?e=1783555200&v=beta&t=2dmpEO_oAC13oNsD2Lgoeob6CC0LQz0GJ5ayufGmY4E', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
  { name: 'Betuel Arones Silva', role: 'Co-Fundador', image: 'https://media.licdn.com/dms/image/v2/D4E03AQEJzU59nrLXlg/profile-displayphoto-scale_400_400/B4EZ72Hue7JEAk-/0/1782245685862?e=1784160000&v=beta&t=83y-JPHC_OLTxV9Zi_Hp1L-YF-A_jKvGqHIZ0RfSTuA', desc: 'Apoyo en la operación y desarrollo de proyectos.', linkedin: '#' },
];

const content: Record<string, { tag: string; title: string; teamTitle: string; teamDesc: string }> = {
  es: {
    tag: 'Nuestro equipo',
    title: 'Conoce a los fundadores',
    teamTitle: '+40 profesionales',
    teamDesc: 'Distribuidos en 3 continentes, trabajando como un solo equipo.',
  },
  en: {
    tag: 'Our team',
    title: 'Meet the founders',
    teamTitle: '+40 professionals',
    teamDesc: 'Spread across 3 continents, working as one team.',
  },
  pt: {
    tag: 'Nossa equipe',
    title: 'Conheça os fundadores',
    teamTitle: '+40 profissionais',
    teamDesc: 'Distribuídos em 3 continentes, trabalhando como um só time.',
  },
  fr: {
    tag: 'Notre équipe',
    title: 'Rencontrez les fondateurs',
    teamTitle: '+40 professionnels',
    teamDesc: 'Répartis sur 3 continents, travaillant comme une seule équipe.',
  },
};

const c = content[locale] || content.es;
---

<section class="ns-team" id="equipo" data-reveal>
  <div class="container">
    <div class="ns-team-header">
      <div class="ns-team-tag">{c.tag}</div>
      <h2 class="ns-team-title">{c.title}</h2>
    </div>
    <div class="ns-team-layout">
      <div class="ns-team-founders">
        {team.map((m) => (
          <a href={m.linkedin || '#'} target="_blank" rel="noopener noreferrer" class="ns-team-link">
            <article class="ns-team-card">
              <div class="ns-team-avatar">
                <img src={m.image} alt={m.name} width="80" height="80" loading="lazy" />
              </div>
              <div class="ns-team-info">
                <h3>{m.name}</h3>
                <span class="ns-team-role">{m.role}</span>
                <p>{m.desc}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
      <div class="ns-team-visual">
        <div class="ns-team-visual-card">
          <div class="ns-team-visual-bg" style="background-image: url('https://i.ibb.co/zhGnJC8C/Chat-GPT-Image-23-jun-2026-01-10-42-p-m.png');"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ns-team {
    padding: 60px 0;
    background: var(--color-off-white);
    position: relative;
  }

  .ns-team-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .ns-team-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }

  .ns-team-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .ns-team-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .ns-team-founders {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ns-team-link {
    text-decoration: none;
    display: block;
  }

  .ns-team-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: 20px;
    box-shadow: 0 12px 24px rgba(16, 52, 102, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ns-team-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(16, 52, 102, 0.08);
  }

  .ns-team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid var(--color-electric-blue-light);
  }

  .ns-team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ns-team-info h3 {
    margin: 0 0 4px;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-deep-blue);
  }

  .ns-team-role {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 3px 10px;
    border-radius: var(--radius-full);
    margin-bottom: 8px;
  }

  .ns-team-info p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-gray-500);
    line-height: 1.5;
  }

  .ns-team-visual-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ns-team-visual-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }

  @media (max-width: 800px) {
    .ns-team-layout {
      grid-template-columns: 1fr;
    }

    .ns-team-card {
      padding: 16px;
    }

    .ns-team-avatar {
      width: 64px;
      height: 64px;
    }

    .ns-team-visual-card {
      min-height: 240px;
    }
  }
</style>
