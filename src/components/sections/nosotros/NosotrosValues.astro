---
// ============================================
// SABERO Consulting - Nosotros Values
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const content: Record<string, { tag: string; title: string; sub: string; values: { title: string; desc: string }[] }> = {
  es: {
    tag: 'Nuestros valores',
    title: 'Cómo trabajamos',
    sub: 'Principios que guían cada decisión, cada línea de código y cada relación con nuestros clientes.',
    values: [
      { title: 'Calidad sin concesiones', desc: 'Cada línea de código, cada interacción, cada detalle importa. No entregamos nada que no nos enorgullezca.' },
      { title: 'Cercanía real', desc: 'No somos una agencia anónima. Trabajamos codo a codo con cada cliente, como una extensión natural de su equipo.' },
      { title: 'Talento sin fronteras', desc: 'Creemos en el potencial de Latinoamérica. Apostamos por el talento local con estándares globales.' },
      { title: 'Impacto medible', desc: 'No se trata de tecnología por tecnología. Cada solución debe traducirse en resultados concretos para el negocio.' },
    ],
  },
  en: {
    tag: 'Our values',
    title: 'How we work',
    sub: 'Principles that guide every decision, every line of code and every relationship with our clients.',
    values: [
      { title: 'Quality without compromise', desc: 'Every line of code, every interaction, every detail matters. We don\'t deliver anything we\'re not proud of.' },
      { title: 'Real closeness', desc: 'We are not an anonymous agency. We work side by side with each client, as a natural extension of their team.' },
      { title: 'Talent without borders', desc: 'We believe in the potential of Latin America. We bet on local talent with global standards.' },
      { title: 'Measurable impact', desc: 'It\'s not about technology for technology\'s sake. Every solution must translate into concrete business results.' },
    ],
  },
  pt: {
    tag: 'Nossos valores',
    title: 'Como trabalhamos',
    sub: 'Princípios que guiam cada decisão, cada linha de código e cada relação com nossos clientes.',
    values: [
      { title: 'Qualidade sem concessões', desc: 'Cada linha de código, cada interação, cada detalhe importa. Não entregamos nada do que não nos orgulhamos.' },
      { title: 'Proximidade real', desc: 'Não somos uma agência anônima. Trabalhamos lado a lado com cada cliente, como uma extensão natural de sua equipe.' },
      { title: 'Talento sem fronteiras', desc: 'Acreditamos no potencial da América Latina. Apostamos no talento local com padrões globais.' },
      { title: 'Impacto mensurável', desc: 'Não se trata de tecnologia por tecnologia. Cada solução deve se traduzir em resultados concretos para o negócio.' },
    ],
  },
  fr: {
    tag: 'Nos valeurs',
    title: 'Comment nous travaillons',
    sub: 'Des principes qui guident chaque décision, chaque ligne de code et chaque relation avec nos clients.',
    values: [
      { title: 'Qualité sans compromis', desc: 'Chaque ligne de code, chaque interaction, chaque détail compte. Nous ne livrons rien dont nous ne sommes pas fiers.' },
      { title: 'Proximité réelle', desc: 'Nous ne sommes pas une agence anonyme. Nous travaillons main dans la main avec chaque client, comme une extension naturelle de son équipe.' },
      { title: 'Talents sans frontières', desc: 'Nous croyons au potentiel de l\'Amérique latine. Nous misons sur les talents locaux avec des standards mondiaux.' },
      { title: 'Impact mesurable', desc: 'Il ne s\'agit pas de technologie pour la technologie. Chaque solution doit se traduire par des résultats concrets pour l\'entreprise.' },
    ],
  },
};

const c = content[locale] || content.es;
---

<section class="ns-vals" id="valores" data-reveal>
  <div class="container">
    <div class="ns-vals-header">
      <div class="ns-vals-tag">{c.tag}</div>
      <h2 class="ns-vals-title">{c.title}</h2>
      <p class="ns-vals-sub">{c.sub}</p>
    </div>
    <div class="ns-vals-grid">
      {c.values.map((v) => (
        <article class="ns-val">
          <h3 class="ns-val-title">{v.title}</h3>
          <p class="ns-val-desc">{v.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ns-vals {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }

  .ns-vals-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .ns-vals-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }

  .ns-vals-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .ns-vals-sub {
    max-width: 560px;
    margin: 0 auto;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  .ns-vals-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .ns-val {
    background: var(--color-off-white);
    border-radius: var(--radius-xl);
    padding: 28px;
    border-left: 4px solid var(--color-electric-blue);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ns-val:nth-child(2),
  .ns-val:nth-child(4) {
    border-left-color: #dc2626;
  }

  .ns-val:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(16, 52, 102, 0.06);
  }

  .ns-val-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-deep-blue);
    margin: 0 0 10px;
  }

  .ns-val-desc {
    margin: 0;
    line-height: 1.7;
    color: var(--color-gray-600);
  }

  @media (max-width: 700px) {
    .ns-vals-grid {
      grid-template-columns: 1fr;
    }

    .ns-val {
      padding: 24px;
    }
  }
</style>
