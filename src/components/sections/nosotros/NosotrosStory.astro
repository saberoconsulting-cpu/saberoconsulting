const c = content[locale] || content.es;
---

<section class="ns-story" id="historia" data-reveal>
  <div class="container">
    <div class="ns-story-header">
      <div class="ns-story-tag">{c.tag}</div>
      <h2 class="ns-story-title">{c.title}</h2>
    </div>
    <div class="ns-story-body">
      <div class="ns-story-gear-panel">
        <div class="ns-story-gear" style="--gear-rotation:0deg;">
          <div class="ns-story-gear-ring"></div>
          <div class="ns-story-gear-axis"></div>
          <div class="ns-story-gear-core">SABERO</div>
          <div class="ns-story-gear-launch">
            <button type="button" aria-label={c.launchLabel}>{c.launchLabel}</button>
          </div>

          {c.milestones.map((step, i) => (
            <button type="button" class={`ns-story-gear-step ${i === 0 ? 'is-active' : ''}`} data-step={i} aria-label={step.title}>
              <span>{i + 1}</span>
              <small>{step.title}</small>
            </button>
          ))}
        </div>
      </div>

      <div class="ns-story-content">
        {c.milestones.map((step, i) => (
          <article class={`ns-story-step ${i === 0 ? 'is-active' : ''}`} data-step={i}>
            <div class="ns-story-step-card">
              <div class="ns-story-step-meta">
                <span>{step.year}</span>
              </div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
              {step.icon === 'cloud' ? (
                <div class="ns-story-step-badge">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" fill="#1D4ED8"/>
                  </svg>
                  <span>Cloud platform</span>
                </div>
              ) : null}
              <div class="ns-story-step-image">
                <img src={step.image} alt={step.title} loading="lazy" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <script>
    (() => {
      const section = document.querySelector<HTMLElement>('.ns-story');
      if (!section) return;

      const buttons = Array.from(section.querySelectorAll<HTMLElement>('.ns-story-gear-step'));
      const steps = Array.from(section.querySelectorAll<HTMLElement>('.ns-story-step'));
      const gear = section.querySelector<HTMLElement>('.ns-story-gear');
      const launch = section.querySelector<HTMLElement>('.ns-story-gear-launch');
      let currentIndex = 0;

      const revealStory = () => {
        section.classList.add('has-revealed');
        if (launch) launch.style.opacity = '0';
      };

      const revealObserver = new IntersectionObserver((entries, observer) => {
        if (!entries[0]?.isIntersecting) return;
        revealStory();
        observer.unobserve(section);
      }, { threshold: 0.65, rootMargin: '0px 0px 0px 0px' });

      revealObserver.observe(section);

      const setActiveStep = (index: number) => {
        const nextIndex = Math.min(Math.max(index, 0), buttons.length - 1);
        if (nextIndex === currentIndex) return;
        currentIndex = nextIndex;

        buttons.forEach((button, buttonIndex) => {
          button.classList.toggle('is-active', buttonIndex === nextIndex);
        });

        steps.forEach((step, stepIndex) => {
          step.classList.toggle('is-active', stepIndex === nextIndex);
        });

        if (gear) {
          gear.style.setProperty('--gear-rotation', `${nextIndex * 90}deg`);
        }
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const index = Number(button.dataset.step);
          setActiveStep(index);
        });
      });

      setActiveStep(0);
    })();
  </script>
</section>

<style>
  .ns-story {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }

  .ns-story-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .ns-story-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }

  .ns-story-header .ns-story-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .ns-story-body {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 40px;
    align-items: center;
  }

  .ns-story-gear-panel {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ns-story-gear {
    position: relative;
    width: min(360px, 100%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.98), rgba(239, 246, 255, 0.95));
    box-shadow: 0 24px 60px rgba(16, 52, 102, 0.12);
    overflow: visible;
    transform: rotate(var(--gear-rotation, 0deg));
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ns-story-gear-ring {
    position: absolute;
    inset: 16%;
    border: 12px solid rgba(33, 105, 255, 0.14);
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.5);
  }

  .ns-story-gear-axis {
    position: absolute;
    left: 50%;
    top: 62%;
    width: 32px;
    height: 32px;
    transform: translate(-50%, -50%);
    background: var(--color-electric-blue);
    border-radius: 50%;
    box-shadow: 0 0 0 10px rgba(0, 113, 255, 0.1);
  }

  .ns-story-gear-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 120px;
    height: 120px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: var(--color-white);
    border: 1px solid rgba(33, 105, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    text-align: center;
    padding: 1rem;
    box-shadow: inset 0 0 0 1px rgba(33, 105, 255, 0.05);
  }

  .ns-story-gear-step {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 94px;
    height: 94px;
    border-radius: 50%;
    border: 1px solid rgba(30, 78, 160, 0.12);
    background: var(--color-white);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-align: center;
    padding: 14px 12px;
    cursor: pointer;
    transition: left 1.2s ease, top 1.2s ease, transform 1.2s ease, opacity 1.2s ease, box-shadow 0.3s ease, background 0.3s ease;
    box-shadow: 0 12px 24px rgba(14, 40, 88, 0.08);
    transform-origin: center;
    opacity: 0;
    pointer-events: none;
    --step-scale: 0.65;
    transform: translate(-50%, -50%) rotate(calc(var(--gear-rotation, 0deg) * -1)) scale(var(--step-scale));
  }

  .ns-story .ns-story-gear-launch {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.4s ease;
  }

  .ns-story .ns-story-gear-launch button {
    border: none;
    background: var(--color-electric-blue);
    color: #fff;
    padding: 1rem 1.6rem;
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    box-shadow: 0 20px 40px rgba(33, 105, 255, 0.22);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ns-story .ns-story-gear-launch button:hover {
    transform: translateY(-2px);
  }

  .ns-story.has-revealed .ns-story-gear-launch {
    opacity: 0;
    pointer-events: none;
  }

  .ns-story.has-revealed .ns-story-gear-step {
    opacity: 1;
    pointer-events: auto;
    --step-scale: 1;
  }

  .ns-story-gear-step span {
    font-size: 1.05rem;
    font-weight: 900;
    color: var(--color-electric-blue);
  }

  .ns-story-gear-step small {
    font-size: 0.65rem;
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gray-600);
  }

  .ns-story-gear-step.is-active {
    background: var(--color-electric-blue);
    color: var(--color-white);
    box-shadow: 0 20px 40px rgba(33, 105, 255, 0.24);
  }

  .ns-story-gear-step.is-active span,
  .ns-story-gear-step.is-active small {
    color: var(--color-white);
  }

  .ns-story-gear-step:nth-of-type(1) {
    transition-delay: 0.05s;
  }

  .ns-story-gear-step:nth-of-type(2) {
    transition-delay: 0.1s;
  }

  .ns-story-gear-step:nth-of-type(3) {
    transition-delay: 0.15s;
  }

  .ns-story-gear-step:nth-of-type(4) {
    transition-delay: 0.2s;
  }

  .ns-story.has-revealed .ns-story-gear-step:nth-of-type(1) {
    left: 50%;
    top: 12%;
  }

  .ns-story.has-revealed .ns-story-gear-step:nth-of-type(2) {
    left: auto;
    right: 12%;
    top: 50%;
    transform: translate(50%, -50%) rotate(calc(var(--gear-rotation, 0deg) * -1)) scale(1);
  }

  .ns-story.has-revealed .ns-story-gear-step:nth-of-type(3) {
    left: 50%;
    bottom: 12%;
    transform: translate(-50%, 50%) rotate(calc(var(--gear-rotation, 0deg) * -1)) scale(1);
  }

  .ns-story.has-revealed .ns-story-gear-step:nth-of-type(4) {
    left: 12%;
    top: 50%;
  }

  .ns-story-content {
    display: grid;
    gap: 24px;
  }

  .ns-story-step {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .ns-story-step.is-active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .ns-story-step-card {
    background: var(--color-white);
    border: 1px solid rgba(33, 105, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: 32px;
    box-shadow: 0 30px 60px rgba(16, 52, 102, 0.08);
  }

  .ns-story-step-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: var(--color-electric-blue);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .ns-story-step-badge svg {
    display: block;
    flex-shrink: 0;
  }

  .ns-story-step-meta span {
    display: inline-block;
    padding: 10px 16px;
    border-radius: var(--radius-full);
    background: var(--color-electric-blue-light);
    color: var(--color-electric-blue);
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .ns-story-step-card h3 {
    margin: 20px 0 14px;
    font-size: clamp(1.4rem, 2vw, 2rem);
    color: var(--color-deep-blue);
  }

  .ns-story-step-card p {
    margin: 0 0 24px;
    line-height: 1.9;
    color: var(--color-gray-600);
  }

  .ns-story-step-image {
    border-radius: 22px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.5);
  }

  .ns-story-step-image img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .ns-story {
      padding: 48px 0;
    }

    .ns-story-body {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ns-story-gear {
      width: min(420px, 100%);
    }

    .ns-story-step-card {
      padding: 26px;
    }

    .ns-story-step-image img {
      height: 260px;
    }
  }

  @media (max-width: 600px) {
    .ns-story-header {
      margin-bottom: 28px;
    }

    .ns-story-gear-step {
      width: 84px;
      height: 84px;
      padding: 12px 10px;
    }

    .ns-story-gear-step small {
      font-size: 0.62rem;
    }

    .ns-story-step-card {
      padding: 24px;
    }

    .ns-story-step-image img {
      height: 220px;
    }
  }
</style>
