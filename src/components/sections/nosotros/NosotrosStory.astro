---
// ============================================
// SABERO Consulting - Nosotros Story (Timeline)
// ============================================
const milestones = [
  { year: '2018', title: 'Fundación', desc: 'Nacimos en Lima con la convicción de que el talento latinoamericano puede competir al más alto nivel global.' },
  { year: '2020', title: 'Crecimiento', desc: 'Proyectos más complejos, clientes en toda América. Plataformas que procesan pagos, conectan personas y automatizan operaciones.' },
  { year: '2022', title: 'Expansión global', desc: 'Llegamos a Europa, consolidando presencia en 3 continentes. Cada proyecto es una relación de largo plazo.' },
  { year: '2024', title: 'Presente', desc: '+40 profesionales, +30 proyectos, 3 continentes. Seguimos creciendo con la misma convicción.' },
];
---

<section class="ns-story" id="historia" data-reveal>
  <div class="container">
    <div class="ns-story-header">
      <div class="ns-story-tag">Nuestra historia</div>
      <h2 class="ns-story-title">De Lima para el mundo</h2>
    </div>
    <div class="ns-story-body">
      <div class="ns-story-timeline">
        <div class="ns-story-line"></div>
        {milestones.map((m, i) => (
          <div class="ns-story-milestone" data-img={i}>
            <div class="ns-story-milestone-dot"></div>
            <div class="ns-story-milestone-year">{m.year}</div>
            <h3 class="ns-story-milestone-title">{m.title}</h3>
            <p class="ns-story-milestone-desc">{m.desc}</p>
          </div>
        ))}
        <div class="ns-story-quote">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p>El talento latinoamericano puede competir al más alto nivel global.</p>
        </div>
      </div>
      <div class="ns-story-visual">
        <div class="ns-story-img-frame">
          <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
          <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=800&q=80" alt="" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ns-story {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }
  .ns-story-header {
    text-align: center;
    margin-bottom: 36px;
  }
  .ns-story-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }
  .ns-story-header .ns-story-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .ns-story-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .ns-story-timeline {
    position: relative;
    padding-left: 40px;
  }
  .ns-story-line {
    position: absolute;
    left: 15px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, var(--color-electric-blue), var(--color-electric-blue-light) 60%, transparent);
    border-radius: 1px;
  }
  .ns-story-milestone {
    position: relative;
    padding-bottom: 20px;
  }
  .ns-story-milestone:last-of-type {
    padding-bottom: 0;
  }
  .ns-story-milestone-dot {
    position: absolute;
    left: -40px;
    top: 4px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-white);
    border: 2.5px solid var(--color-electric-blue);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
    box-shadow: 0 0 0 0 rgba(0, 102, 255, 0.15);
  }
  .ns-story-milestone-dot::after {
    content: '';
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-electric-blue);
  }
  .ns-story-milestone:hover .ns-story-milestone-dot {
    box-shadow: 0 0 0 6px rgba(0, 102, 255, 0.15);
    transform: scale(1.08);
  }
  .ns-story-milestone-year {
    font-size: var(--text-xs);
    font-weight: 800;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 2px;
  }
  .ns-story-milestone-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-deep-blue);
    margin: 0 0 6px;
  }
  .ns-story-milestone-desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: 1.7;
    margin: 0;
  }
  .ns-story-quote {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-electric-blue-light);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-electric-blue);
  }
  .ns-story-quote svg {
    color: var(--color-electric-blue);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .ns-story-quote p {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-deep-blue);
    margin: 0;
    font-style: italic;
  }
  .ns-story-visual {
    position: relative;
    top: 8px;
    display: flex;
    justify-content: center;
  }
  .ns-story-img-frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    aspect-ratio: 4 / 5;
    max-width: 360px;
  }
  .ns-story-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.45s ease, transform 0.5s ease;
  }
  .ns-story-img-frame img:first-child {
    position: relative;
    opacity: 1;
  }
  .ns-story-img-frame:hover img {
    transform: scale(1.04);
  }
  .ns-story-body:not(:has(.ns-story-milestone:hover)) .ns-story-img-frame img:nth-child(1),
  .ns-story-body:has([data-img="0"]:hover) .ns-story-img-frame img:nth-child(1) { opacity: 1; }
  .ns-story-body:has([data-img="1"]:hover) .ns-story-img-frame img:nth-child(2) { opacity: 1; }
  .ns-story-body:has([data-img="2"]:hover) .ns-story-img-frame img:nth-child(3) { opacity: 1; }
  .ns-story-body:has([data-img="3"]:hover) .ns-story-img-frame img:nth-child(4) { opacity: 1; }
  .ns-story-body:has([data-img="0"]:hover) .ns-story-img-frame img:not(:nth-child(1)),
  .ns-story-body:has([data-img="1"]:hover) .ns-story-img-frame img:not(:nth-child(2)),
  .ns-story-body:has([data-img="2"]:hover) .ns-story-img-frame img:not(:nth-child(3)),
  .ns-story-body:has([data-img="3"]:hover) .ns-story-img-frame img:not(:nth-child(4)) { opacity: 0; }
  .ns-story-img-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(10, 22, 40, 0.08) 0%, transparent 50%);
  }
  @media (max-width: 900px) {
    .ns-story { padding: 48px 0; }
    .ns-story-body { grid-template-columns: 1fr; gap: 32px; }
    .ns-story-img-frame { aspect-ratio: 5 / 6; max-width: 480px; margin: 0 auto; }
  }
  @media (max-width: 640px) {
    .ns-story { padding: 36px 0; }
    .ns-story-body { gap: 24px; }
    .ns-story-quote { padding: 10px 14px; }
  }
</style>
