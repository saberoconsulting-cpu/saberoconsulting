---
// ============================================
// SABERO Consulting - Nosotros Mission & Vision
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const content: Record<string, { tag: string; title: string; mission: string; vision: string }> = {
  es: {
    tag: 'Nuestra esencia',
    title: 'Misión y Visión',
    mission: 'Construir productos digitales que transformen industrias, combinando ingeniería de clase mundial con el talento y la creatividad de Latinoamérica.',
    vision: 'Ser el partner tecnológico de referencia para organizaciones que buscan crecer con tecnología robusta, escalable y centrada en el usuario.',
  },
  en: {
    tag: 'Our essence',
    title: 'Mission & Vision',
    mission: 'Build digital products that transform industries, combining world-class engineering with the talent and creativity of Latin America.',
    vision: 'To be the reference technology partner for organizations seeking to grow with robust, scalable and user-centered technology.',
  },
  pt: {
    tag: 'Nossa essência',
    title: 'Missão e Visão',
    mission: 'Construir produtos digitais que transformem indústrias, combinando engenharia de classe mundial com o talento e a criatividade da América Latina.',
    vision: 'Ser o parceiro tecnológico de referência para organizações que buscam crescer com tecnologia robusta, escalável e centrada no usuário.',
  },
  fr: {
    tag: 'Notre essence',
    title: 'Mission & Vision',
    mission: 'Construire des produits numériques qui transforment les industries, en combinant une ingénierie de classe mondiale avec le talent et la créativité de l\'Amérique latine.',
    vision: 'Être le partenaire technologique de référence pour les organisations qui cherchent à se développer avec une technologie robuste, évolutive et centrée sur l\'utilisateur.',
  },
};

const c = content[locale] || content.es;
---

<section class="ns-mv" id="mision-vision" data-reveal>
  <div class="container">
    <div class="ns-mv-header">
      <div class="ns-mv-tag">{c.tag}</div>
      <h2 class="ns-mv-title">{c.title}</h2>
    </div>
    <div class="ns-mv-grid">
      <div class="ns-mv-card">
        <div class="ns-mv-accent"></div>
        <div class="ns-mv-body">
          <h3 class="ns-mv-cardtitle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            {locale === 'es' ? 'Misión' : locale === 'en' ? 'Mission' : locale === 'pt' ? 'Missão' : 'Mission'}
          </h3>
          <p>{c.mission}</p>
        </div>
      </div>
      <div class="ns-mv-card">
        <div class="ns-mv-accent"></div>
        <div class="ns-mv-body">
          <h3 class="ns-mv-cardtitle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            {locale === 'es' ? 'Visión' : locale === 'en' ? 'Vision' : locale === 'pt' ? 'Visão' : 'Vision'}
          </h3>
          <p>{c.vision}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ns-mv {
    padding: 60px 0;
    background: var(--color-off-white);
    position: relative;
  }

  .ns-mv-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .ns-mv-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }

  .ns-mv-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .ns-mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .ns-mv-card {
    position: relative;
    background: var(--color-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(16, 52, 102, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ns-mv-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 60px rgba(16, 52, 102, 0.1);
  }

  .ns-mv-accent {
    height: 4px;
    background: linear-gradient(90deg, var(--color-electric-blue), var(--color-accent-blue));
  }

  .ns-mv-body {
    padding: 32px;
  }

  .ns-mv-cardtitle {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-deep-blue);
    margin: 0 0 16px;
  }

  .ns-mv-cardtitle svg {
    color: var(--color-electric-blue);
    flex-shrink: 0;
  }

  .ns-mv-body p {
    margin: 0;
    line-height: 1.8;
    color: var(--color-gray-600);
  }

  @media (max-width: 700px) {
    .ns-mv-grid {
      grid-template-columns: 1fr;
    }

    .ns-mv-body {
      padding: 24px;
    }
  }
</style>
