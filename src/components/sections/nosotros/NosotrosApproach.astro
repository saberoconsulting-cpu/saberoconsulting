---
// ============================================
// SABERO Consulting - Nosotros Approach
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const content: Record<string, { tag: string; title: string; steps: string[] }> = {
  es: {
    tag: 'Nuestro enfoque',
    title: 'Cómo construimos',
    steps: [
      'Descubrimiento y estrategia: Entendemos tu industria, tu negocio y tus usuarios para definir el alcance, la hoja de ruta y las métricas de éxito.',
      'Arquitectura y diseño: Definimos la arquitectura técnica, el diseño de producto y la experiencia de usuario, asegurando escalabilidad y usabilidad.',
      'Construcción ágil: Desarrollamos en ciclos iterativos con integración continua, desplegando valor de forma incremental y con total transparencia.',
      'Evolución continua: Monitoreamos, optimizamos y escalamos tu producto, acompañándote en cada etapa del crecimiento.',
    ],
  },
  en: {
    tag: 'Our approach',
    title: 'How we build',
    steps: [
      'Discovery and strategy: We understand your industry, your business and your users to define the scope, roadmap and success metrics.',
      'Architecture and design: We define the technical architecture, product design and user experience, ensuring scalability and usability.',
      'Agile construction: We develop in iterative cycles with continuous integration, deploying value incrementally with full transparency.',
      'Continuous evolution: We monitor, optimize and scale your product, accompanying you at every stage of growth.',
    ],
  },
  pt: {
    tag: 'Nossa abordagem',
    title: 'Como construímos',
    steps: [
      'Descoberta e estratégia: Entendemos sua indústria, seu negócio e seus usuários para definir o escopo, o roteiro e as métricas de sucesso.',
      'Arquitetura e design: Definimos a arquitetura técnica, o design do produto e a experiência do usuário, garantindo escalabilidade e usabilidade.',
      'Construção ágil: Desenvolvemos em ciclos iterativos com integração contínua, entregando valor de forma incremental e com total transparência.',
      'Evolução contínua: Monitoramos, otimizamos e escalamos seu produto, acompanhando você em cada etapa do crescimento.',
    ],
  },
  fr: {
    tag: 'Notre approche',
    title: 'Comment nous construisons',
    steps: [
      'Découverte et stratégie : Nous comprenons votre secteur, votre entreprise et vos utilisateurs pour définir la portée, la feuille de route et les indicateurs de succès.',
      'Architecture et conception : Nous définissons l\'architecture technique, la conception du produit et l\'expérience utilisateur, garantissant évolutivité et convivialité.',
      'Construction agile : Nous développons en cycles itératifs avec intégration continue, déployant de la valeur de manière incrémentale et en toute transparence.',
      'Évolution continue : Nous surveillons, optimisons et faisons évoluer votre produit, en vous accompagnant à chaque étape de la croissance.',
    ],
  },
};

const c = content[locale] || content.es;
---

<section class="ns-app" id="enfoque" data-reveal>
  <div class="container">
    <div class="ns-app-header">
      <div class="ns-app-tag">{c.tag}</div>
      <h2 class="ns-app-title">{c.title}</h2>
    </div>
    <div class="ns-app-steps">
      {c.steps.map((step, i) => (
        <div class="ns-app-step" data-idx={i + 1}>
          <div class="ns-app-step-top">
            <div class="ns-app-circle">{i + 1}</div>
            <div class="ns-app-line"></div>
          </div>
          <p class="ns-app-text">{step}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ns-app {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }

  .ns-app-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .ns-app-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }

  .ns-app-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .ns-app-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ns-app-step {
    position: relative;
  }

  .ns-app-step-top {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 20px;
  }

  .ns-app-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-electric-blue);
    color: var(--color-white);
    font-weight: 800;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 8px 16px rgba(33, 105, 255, 0.18);
  }

  .ns-app-line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, var(--color-electric-blue), var(--color-accent-blue));
    opacity: 0.3;
  }

  .ns-app-step:last-child .ns-app-line {
    display: none;
  }

  .ns-app-text {
    margin: 0;
    line-height: 1.7;
    color: var(--color-gray-600);
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .ns-app-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .ns-app-steps {
      grid-template-columns: 1fr;
    }

    .ns-app-step-top {
      margin-bottom: 12px;
    }
  }
</style>
