---
// ============================================
// SABERO Consulting - Nosotros Approach
// ============================================
const approach = [
  'Descubrimiento y estrategia: entendemos el negocio, el usuario y el contexto antes de escribir una línea de código.',
  'Arquitectura y diseño: definimos la columna vertebral técnica del producto para que sea escalable, mantenible y segura.',
  'Desarrollo ágil: trabajamos en ciclos cortos con equipos integrados, transparencia total y entregas continuas.',
  'Evolución y mejora continua: medimos, aprendemos y evolucionamos el producto con cada iteración.',
];
---

<section class="ns-app" id="enfoque" data-reveal>
  <div class="container">
    <div class="ns-app-header">
      <div class="ns-app-tag">Nuestra metodología</div>
      <h2 class="ns-app-title">Cómo trabajamos</h2>
    </div>
    <div class="ns-app-steps">
      {approach.map((step, i) => (
        <div class="ns-app-step" data-idx={i + 1}>
          <div class="ns-app-step-top">
            <div class="ns-app-circle">{i + 1}</div>
            {i < approach.length - 1 && <div class="ns-app-connector"></div>}
          </div>
          <p class="ns-app-text">{step}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ns-app {
    padding: 60px 0;
    background: var(--color-white);
    position: relative;
  }
  .ns-app::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric-blue-light), transparent);
  }
  .ns-app-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .ns-app-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-electric-blue);
    background: var(--color-electric-blue-light);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
  }
  .ns-app-title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--color-deep-blue);
    letter-spacing: -0.02em;
  }
  .ns-app-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    counter-reset: step;
  }
  .ns-app-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: default;
  }
  .ns-app-step-top {
    display: flex;
    align-items: center;
    width: 100%;
    margin-bottom: 28px;
  }
  .ns-app-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-gray-300);
    background: var(--color-gray-50);
    border: 2px solid var(--color-gray-100);
    flex-shrink: 0;
    transition: all var(--transition-base);
    position: relative;
    z-index: 1;
  }
  .ns-app-connector {
    flex: 1;
    height: 3px;
    background: var(--color-gray-100);
    transition: background var(--transition-base);
    margin: 0 -1px;
    position: relative;
    z-index: 0;
  }
  .ns-app-text {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    line-height: 1.7;
    margin: 0;
    max-width: 240px;
    text-align: center;
    transition: color var(--transition-base);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(1):hover) .ns-app-step:nth-child(1) .ns-app-circle {
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
    box-shadow: 0 0 0 6px var(--color-electric-blue-light);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(1):hover) .ns-app-step:nth-child(1) .ns-app-text {
    color: var(--color-gray-700);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(2):hover) .ns-app-step:nth-child(1) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(2):hover) .ns-app-step:nth-child(2) .ns-app-circle {
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
    box-shadow: 0 0 0 6px var(--color-electric-blue-light);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(2):hover) .ns-app-step:nth-child(1) .ns-app-connector {
    background: var(--color-electric-blue);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(2):hover) .ns-app-step:nth-child(1) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(2):hover) .ns-app-step:nth-child(2) .ns-app-text {
    color: var(--color-gray-700);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(1) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(2) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(3) .ns-app-circle {
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
    box-shadow: 0 0 0 6px var(--color-electric-blue-light);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(1) .ns-app-connector,
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(2) .ns-app-connector {
    background: var(--color-electric-blue);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(1) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(2) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(3):hover) .ns-app-step:nth-child(3) .ns-app-text {
    color: var(--color-gray-700);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(1) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(2) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(3) .ns-app-circle,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(4) .ns-app-circle {
    color: var(--color-white);
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
    box-shadow: 0 0 0 6px var(--color-electric-blue-light);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(1) .ns-app-connector,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(2) .ns-app-connector,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(3) .ns-app-connector {
    background: var(--color-electric-blue);
  }
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(1) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(2) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(3) .ns-app-text,
  .ns-app-steps:has(.ns-app-step:nth-child(4):hover) .ns-app-step:nth-child(4) .ns-app-text {
    color: var(--color-gray-700);
  }
  @media (max-width: 900px) {
    .ns-app-steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 0;
    }
    .ns-app-step:nth-child(2) .ns-app-connector { display: none; }
  }
  @media (max-width: 640px) {
    .ns-app { padding: 64px 0; }
    .ns-app-steps {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .ns-app-connector { display: none; }
    .ns-app-step-top { justify-content: center; }
    .ns-app-text { max-width: 100%; }
  }
</style>
