---
// ============================================
// SABERO Consulting - Oferta Intro
// Bloque 1: Mensaje principal premium
// ============================================
import { getOfertaData } from '../../../data/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = getOfertaData(locale as any);
const { intro } = content;
---

<section class="oferta-intro" id="oferta-intro">
  <div class="container">
    <div class="oferta-intro-grid">
      <div class="oferta-intro-left">
        <h2 class="oferta-title">
          {intro.title}
          <span class="oferta-title-accent">{intro.titleAccent}</span>
        </h2>
      </div>
      <div class="oferta-intro-right">
        <p class="oferta-description">{intro.description}</p>
        <div class="oferta-divider"></div>
        <p class="oferta-microcopy">{intro.microcopy}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .oferta-intro {
    padding: 150px 0 120px;
    min-height: auto;
    background: 
      url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRdk7Z3x-6KZSUbGnQVd87Pxo_FUvjd4m3yZA&s') center / cover no-repeat;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center 20%;
  }

  .oferta-intro::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  .oferta-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 40px;
    align-items: start;
  }

  .oferta-title {
    font-size: 2.8rem;
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .oferta-title-accent {
    display: block;
    background: linear-gradient(135deg, #4FC3F7, #81D4FA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .oferta-description {
    font-size: 1.15rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.65;
    margin: 0 0 20px;
    max-width: 620px;
  }

  .oferta-divider {
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, #4FC3F7, #81D4FA);
    border-radius: 2px;
    margin-bottom: 20px;
  }

  .oferta-microcopy {
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.7);
    margin: 0;
    max-width: 560px;
    font-style: italic;
  }

  @media (max-width: 1024px) {
    .oferta-intro { padding: 60px 0 40px; }
    .oferta-intro-grid { grid-template-columns: 1fr; gap: 24px; }
    .oferta-title { font-size: 2.4rem; }
    .oferta-description { font-size: 1.05rem; }
  }

  @media (max-width: 640px) {
    .oferta-intro { padding: 72px 0 40px; }
    .oferta-title { font-size: 2rem; }
    .oferta-description { font-size: 0.95rem; }
    .oferta-microcopy { font-size: 0.85rem; }
  }
</style>
