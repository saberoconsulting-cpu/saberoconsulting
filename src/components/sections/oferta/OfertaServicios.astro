 ---
// ============================================
// SABERO Consulting - Servicios y Soluciones
// Bloque 2: Servicios + Soluciones con imágenes
// Servicios: imagen derecha, texto izquierda
// Soluciones: imagen izquierda, texto derecha
// ============================================
import { getOfertaData } from '../../../data/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = getOfertaData(locale as any);
const { capacidades } = content;

// Only first 2 items: Servicios, Soluciones
const items = capacidades.items.slice(0, 2);

const images = [
  'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80',
  'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80',
];
---

<section class="servicios-section" id="servicios">
  <div class="container">
    <div class="servicios-header">
      <h3 class="servicios-title">
        <span class="title-blue">Servicios</span>
        <span class="title-sep">y</span>
        <span class="title-red">soluciones</span>
      </h3>
    </div>

    <div class="servicios-list">
      {items.map((item, i) => {
        const isReversed = i === 1; // Soluciones: image left, text right
        const blockId = item.id === 'soluciones' ? 'soluciones' : item.id;
        return (
          <article class={`serv-block ${isReversed ? 'serv-block--reversed' : ''}`} id={blockId}>
            {isReversed ? (
              <>
                <div class="serv-block-image-wrap">
                  <img class="serv-block-image" src={images[i]} alt={item.title} loading="lazy" />
                </div>
                <div class="serv-block-text">
                  <h4 class="serv-block-title">{item.title}</h4>
                  <p class="serv-block-summary">{item.summary}</p>
                  <div class="serv-block-resolves">
                    <span class="serv-block-resolves-label">Qué resuelve</span>
                    <p class="serv-block-resolves-text">{item.resolves}</p>
                  </div>
                  <ul class="serv-block-list">
                    {item.items.map((sub) => (
                      <li class="serv-block-item">{sub}</li>
                    ))}
                  </ul>
                </div>
              </>
            ) : (
              <>
                <div class="serv-block-text">
                  <h4 class="serv-block-title">{item.title}</h4>
                  <p class="serv-block-summary">{item.summary}</p>
                  <div class="serv-block-resolves">
                    <span class="serv-block-resolves-label">Qué resuelve</span>
                    <p class="serv-block-resolves-text">{item.resolves}</p>
                  </div>
                  <ul class="serv-block-list">
                    {item.items.map((sub) => (
                      <li class="serv-block-item">{sub}</li>
                    ))}
                  </ul>
                </div>
                <div class="serv-block-image-wrap">
                  <img class="serv-block-image" src={images[i]} alt={item.title} loading="lazy" />
                </div>
              </>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ============================================
     Section
     ============================================ */
  .servicios-section {
    padding: 60px 0 60px;
    background: #FFFFFF;
    position: relative;
  }

  .servicios-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  /* ============================================
     Header with mixed colors
     ============================================ */
  .servicios-header {
    text-align: center;
    margin-bottom: 56px;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8ECF2;
  }

  .servicios-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .title-blue {
    color: #2F80FF;
  }

  .title-sep {
    color: #5E6472;
    font-weight: 400;
    font-size: 1.4rem;
  }

  .title-red {
    color: #E53935;
  }

  /* ============================================
     Service blocks
     ============================================ */
  .servicios-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .serv-block {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 32px;
    align-items: center;
    border: 1px solid #E8ECF2;
    border-radius: 16px;
    padding: 28px;
    background: #FFFFFF;
    transition: all 350ms ease;
  }

  .serv-block:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 28px rgba(0,0,0,0.05);
  }

  /* Reversed: image left, text right */
  .serv-block--reversed {
    grid-template-columns: 0.8fr 1.2fr;
  }

  .serv-block--reversed .serv-block-text {
    padding-left: 8px;
  }

  .serv-block--reversed .serv-block-image-wrap {
    justify-self: start;
  }

  /* ============================================
     Text side
     ============================================ */
  .serv-block-text {
    display: flex;
    flex-direction: column;
    padding-right: 8px;
  }

  .serv-block-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .serv-block-summary {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #5E6472;
    margin: 0 0 16px;
  }

  .serv-block-resolves {
    background: #F8F9FB;
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 14px;
    border-left: 3px solid #2F80FF;
  }

  .serv-block-resolves-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    margin-bottom: 4px;
  }

  .serv-block-resolves-text {
    font-size: 0.78rem;
    line-height: 1.5;
    color: #3A4050;
    margin: 0;
  }

  .serv-block-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .serv-block-item {
    font-size: 0.78rem;
    color: #3A4050;
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }

  .serv-block-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.4;
  }

  /* ============================================
     Image side
     ============================================ */
  .serv-block-image-wrap {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    max-height: 220px;
    background: #F0F5FF;
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    width: 100%;
  }

  .serv-block-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }

  .serv-block:hover .serv-block-image {
    transform: scale(1.05);
  }

  /* ============================================
     Responsive
     ============================================ */
  @media (max-width: 768px) {
    .serv-block {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 20px;
    }

    .serv-block-image-wrap {
      order: -1;
      aspect-ratio: 16 / 9;
    }

    .servicios-title {
      font-size: 1.4rem;
    }

    .serv-block-title {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 640px) {
    .servicios-section {
      padding: 40px 0 40px;
    }
  }
</style>
