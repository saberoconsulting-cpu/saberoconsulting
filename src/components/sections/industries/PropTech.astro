---
// ============================================
// SABERO Consulting - PropTech Sector
// ============================================
import type { IndustrySector } from '../../../data/industries/types';
import '../../../styles/components/proptech.css';

interface Props {
  sector: IndustrySector;
  index: number;
  isLast: boolean;
}

const { sector, index, isLast } = Astro.props;
---

<article class="industry-block" id={sector.id}>
  <div class="container">

    <!-- Carrusel automático con iconos reales -->
    <div class="industry-block-carousel">
      <div class="industry-block-carousel-track">
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/1055/1055666.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Plataformas web</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/2285/2285611.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Arquitectura de producto</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/10308/10308682.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Integraciones</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/1903/1903162.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">QA y evolución continua</span>
        </div>
        <!-- Duplicados para efecto infinito -->
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/1055/1055666.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Plataformas web</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/2285/2285611.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Arquitectura de producto</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/10308/10308682.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">Integraciones</span>
        </div>
        <div class="industry-block-carousel-item">
          <img src="https://cdn-icons-png.flaticon.com/128/1903/1903162.png" alt="" class="industry-block-carousel-icon" width="32" height="32" loading="lazy" />
          <span class="industry-block-carousel-label">QA y evolución continua</span>
        </div>
      </div>
    </div>

    <!-- Sección Soluciones internas empresariales (imagen izq + texto der) -->
    <div class="industry-block-internas">
      <div class="industry-block-internas-image">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRfQJTkVkZFcP4zpHSwb0Da0ipAzuCQYhAI2Fft3q4W5w&s=10" alt="Soluciones internas empresariales" width="380" height="400" loading="lazy" />
      </div>
      <div class="industry-block-internas-content">
        <div class="industry-block-internas-header">
          <h3 class="industry-block-internas-title">Soluciones internas empresariales</h3>
        </div>
        <p class="industry-block-internas-context">La digitalización interna es uno de los mayores generadores de eficiencia en las organizaciones. Sistemas desconectados, procesos manuales y poca visibilidad operativa frenan la capacidad de crecimiento y respuesta del negocio.</p>

        <div class="industry-block-internas-grid">
          <div class="industry-block-internas-col">
            <h4 class="industry-block-internas-col-title">Retos del sector</h4>
            <ul class="industry-block-internas-list">
              <li>Procesos manuales que consumen tiempo y recursos</li>
              <li>Sistemas desconectados que generan silos de información</li>
              <li>Poca visibilidad de métricas y resultados operativos</li>
              <li>Dificultad para escalar procesos con herramientas genéricas</li>
            </ul>
          </div>
          <div class="industry-block-internas-col">
            <h4 class="industry-block-internas-col-title">Soluciones SABERO</h4>
            <ul class="industry-block-internas-list">
              <li>Automatización de procesos y flujos de trabajo internos</li>
              <li>Portales internos y herramientas operativas a medida</li>
              <li>Dashboards de gestión y reporting ejecutivo</li>
              <li>Sistemas de integración entre herramientas existentes</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>

  {!isLast && (
    <div class="industry-block-divider">
      <div class="container">
        <div class="industry-block-divider-line"></div>
      </div>
    </div>
  )}
</article>


