---
// ============================================
// SABERO Consulting - Industries Section
// Orquestador: Hero + 7 sectores individuales
// ============================================
import { getIndustriesData } from '../../../data/industries';
import type { SupportedLocale } from '../../../i18n/utils/types';
import IndustriesHero from './IndustriesHero.astro';
import PropTech from './PropTech.astro';
import IndustriesCards from './IndustriesCards.astro';

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const content = getIndustriesData(locale);
const { sectors } = content;

const isEs = locale === 'es';

const ui: Record<string, { ctaTitle: string; ctaText: string; ctaPrimary: string; ctaSecondary: string }> = {
  es: { ctaTitle: 'Construyamos algo grande juntos', ctaText: 'Conversa con nuestro equipo y descubre cómo podemos impulsar tu próximo proyecto.', ctaPrimary: 'Conversemos', ctaSecondary: 'Ver capacidades' },
  en: { ctaTitle: "Let's build something great together", ctaText: 'Talk to our team and discover how we can power your next project.', ctaPrimary: "Let's talk", ctaSecondary: 'View capabilities' },
  pt: { ctaTitle: 'Vamos construir algo grande juntos', ctaText: 'Converse com nossa equipe e descubra como podemos impulsionar seu próximo projeto.', ctaPrimary: 'Vamos conversar', ctaSecondary: 'Ver capacidades' },
  fr: { ctaTitle: 'Construisons quelque chose de grand ensemble', ctaText: 'Parlez à notre équipe et découvrez comment nous pouvons propulser votre prochain projet.', ctaPrimary: 'Parlons-en', ctaSecondary: 'Voir nos capacités' },
};
const labels = ui[locale as string] || ui.es;
---

<section class="industries-section" aria-label={content.title}>
  <IndustriesHero content={content} />

  <PropTech sector={sectors[0]} index={0} isLast={false} />

  <!-- ============================================
       Soluciones por industria - Carrusel automático
       ============================================ -->
  <section class="solutions-cards-section" id="soluciones-industria">
    <div class="container">
      <div class="carousel-wrapper">
        <div class="carousel-track" id="industries-carousel-track">
          {sectors.slice(1).map((sector, i) => (
            <article class="solution-card" id={sector.id}>
              <div class="solution-card-accent"></div>
              <div class="solution-card-body">
                <span class="solution-card-number">{String(i + 2).padStart(2, '0')}</span>
                <h3 class="solution-card-title">{sector.title}</h3>
                <p class="solution-card-text">{sector.context}</p>
                <a href={`#${sector.id}`} class="solution-card-link">
                  {locale === 'es' ? 'Ver detalle del sector' : locale === 'en' ? 'View sector details' : locale === 'pt' ? 'Ver detalhes do setor' : 'Voir les détails du secteur'} &rarr;
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <IndustriesCards />

  <!-- ============================================
       CTA Final - Construyamos algo grande juntos
       ============================================ -->
  <section class="industries-cta-final">
    <div class="industries-cta-final-bg">
      <img src="/images/industries-cta-bg.jpg" alt="" class="industries-cta-final-img" loading="lazy" />
    </div>
    <div class="industries-cta-final-overlay"></div>
    <div class="container">
      <div class="industries-cta-final-content">
        <h2 class="industries-cta-final-title">{labels.ctaTitle}</h2>
        <p class="industries-cta-final-text">{labels.ctaText}</p>
        <div class="industries-cta-final-buttons">
          <a href={isEs ? '/contacto/' : `/${locale}/contacto/`} class="industries-cta-final-btn industries-cta-final-btn-primary">{labels.ctaPrimary}</a>
          <a href={isEs ? '/#oferta' : `/${locale}/#oferta`} class="industries-cta-final-btn industries-cta-final-btn-secondary">{labels.ctaSecondary}</a>
        </div>
      </div>
    </div>
  </section>
</section>

<script>
  (function() {
    const track = document.getElementById('industries-carousel-track');
    if (!track) return;

    const cards = track.querySelectorAll('.solution-card');
    const totalCards = cards.length;
    if (totalCards === 0) return;

    let currentIndex = 0;
    let cardsPerView = getCardsPerView();
    let autoScrollInterval: number | undefined;

    function getCardsPerView() {
      const w = window.innerWidth;
      if (w >= 1200) return 5;
      if (w >= 768) return 3;
      if (w >= 480) return 2;
      return 1;
    }

    function getMaxIndex() {
      return Math.max(0, totalCards - cardsPerView);
    }

    function update() {
      const firstCard = cards[0] as HTMLElement;
      const cardWidth = firstCard.offsetWidth + 16;
      const maxIndex = getMaxIndex();
      if (currentIndex > maxIndex) currentIndex = maxIndex;
      (track as HTMLElement).style.transform = 'translateX(-' + (currentIndex * cardWidth) + 'px)';
    }

    function next() {
      const maxIndex = getMaxIndex();
      currentIndex = (currentIndex >= maxIndex) ? 0 : currentIndex + 1;
      update();
    }

    function startAutoScroll() {
      stopAutoScroll();
      autoScrollInterval = window.setInterval(next, 4000);
    }

    function stopAutoScroll() {
      if (autoScrollInterval !== undefined) {
        window.clearInterval(autoScrollInterval);
        autoScrollInterval = undefined;
      }
    }

    function onResize() {
      const newCardsPerView = getCardsPerView();
      if (newCardsPerView !== cardsPerView) {
        cardsPerView = newCardsPerView;
        if (currentIndex > getMaxIndex()) currentIndex = 0;
        update();
      } else {
        update();
      }
    }

    // Pause on hover/touch
    track.addEventListener('mouseenter', stopAutoScroll);
    track.addEventListener('mouseleave', startAutoScroll);
    track.addEventListener('touchstart', stopAutoScroll, { passive: true });
    track.addEventListener('touchend', startAutoScroll);

    // Init
    update();
    startAutoScroll();

    // Debounced resize
    let resizeTimer: number | undefined;
    window.addEventListener('resize', function() {
      if (resizeTimer !== undefined) window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(onResize, 150);
    });
  })();
</script>

<style>
  .solutions-cards-section {
    padding: 40px 0 60px;
    background: #FFFFFF;
  }

  .carousel-wrapper {
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    transition: transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .solution-card {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: #FFFFFF;
    border: 1px solid #E8ECF2;
    transition: all 400ms ease;
    display: flex;
    flex-direction: column;
    scroll-margin-top: 100px;
    flex: 0 0 calc((100% - 64px) / 5);
    min-width: 0;
  }

  .solution-card:hover {
    border-color: transparent;
    box-shadow: 0 8px 32px rgba(230, 35, 37, 0.12), 0 0 0 2px #E62325;
    transform: translateY(-4px);
  }

  .solution-card-accent {
    height: 4px;
    background: linear-gradient(90deg, #E62325 0%, #1D5BF1 100%);
    flex-shrink: 0;
  }

  .solution-card-body {
    padding: 20px 16px 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .solution-card-number {
    font-size: 0.6rem;
    font-weight: 700;
    color: #FFFFFF;
    background: linear-gradient(135deg, #E62325 0%, #1D5BF1 100%);
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: 1px;
    display: inline-block;
    width: fit-content;
    margin-bottom: 12px;
  }

  .solution-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 10px 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .solution-card-text {
    font-size: 0.72rem;
    line-height: 1.6;
    color: #3A4050;
    margin: 0 0 16px 0;
    flex: 1;
  }

  .solution-card-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.65rem;
    font-weight: 600;
    color: #1D5BF1;
    text-decoration: none;
    transition: all 300ms ease;
    align-self: flex-start;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
  }

  .solution-card-link:hover {
    color: #E62325;
    border-bottom-color: #E62325;
  }

  @media (max-width: 1200px) {
    .solution-card {
      flex: 0 0 calc((100% - 32px) / 3);
    }
  }

  @media (max-width: 768px) {
    .solution-card {
      flex: 0 0 calc((100% - 16px) / 2);
    }
  }

  @media (max-width: 480px) {
    .solution-card {
      flex: 0 0 100%;
    }
  }
</style>

<style>
  .industries-section {
    background: #FFFFFF;
    padding: 0;
  }

  /* === CTA Final - Construyamos algo grande juntos === */
  .industries-cta-final {
    position: relative;
    padding: 60px 0;
    overflow: hidden;
  }

  .industries-cta-final-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .industries-cta-final-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .industries-cta-final-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(135deg, rgba(10, 22, 40, 0.85) 0%, rgba(230, 35, 37, 0.4) 100%);
  }

  .industries-cta-final-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .industries-cta-final-title {
    font-size: 2.6rem;
    font-weight: 800;
    color: #FFFFFF;
    margin: 0 0 16px 0;
    letter-spacing: -0.03em;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .industries-cta-final-text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.85);
    margin: 0 0 36px 0;
  }

  .industries-cta-final-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .industries-cta-final-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: 8px;
    transition: all 300ms ease;
  }

  .industries-cta-final-btn-primary {
    background: #E62325;
    color: #FFFFFF;
    border: 2px solid #E62325;
  }

  .industries-cta-final-btn-primary:hover {
    background: #C41E20;
    border-color: #C41E20;
    box-shadow: 0 6px 24px rgba(230, 35, 37, 0.35);
    transform: translateY(-2px);
  }

  .industries-cta-final-btn-secondary {
    background: transparent;
    color: #FFFFFF;
    border: 2px solid rgba(255,255,255,0.5);
  }

  .industries-cta-final-btn-secondary:hover {
    border-color: #FFFFFF;
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .industries-cta-final { padding: 60px 0; }
    .industries-cta-final-title { font-size: 1.8rem; }
    .industries-cta-final-buttons { flex-direction: column; }
    .industries-cta-final-btn { width: 100%; justify-content: center; }
  }
</style>
