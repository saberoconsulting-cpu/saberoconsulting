---
import { searchData } from '../../../data/search/index';

interface Props {
  locale: string;
  query: string;
}

const { locale, query } = Astro.props;

interface SearchItem {
  label: string;
  labelEn: string;
  labelFr: string;
  labelPt: string;
  href: string;
  category: string;
  categoryEn: string;
  categoryFr: string;
  categoryPt: string;
}

function getLabel(item: SearchItem): string {
  const key = ('label' + locale.charAt(0).toUpperCase() + locale.slice(1)) as keyof SearchItem;
  return (item[key] as string) || item.label;
}

function getCategory(item: SearchItem): string {
  const key = ('category' + locale.charAt(0).toUpperCase() + locale.slice(1)) as keyof SearchItem;
  return (item[key] as string) || item.category;
}

function normalize(text: string): string {
  return text.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s]/g, '');
}

const q = normalize(query);
const results = query
  ? searchData.filter((item) => {
      const label = normalize(getLabel(item));
      const category = normalize(getCategory(item));
      return label.includes(q) || category.includes(q);
    })
  : [];

const mainSections = searchData.filter((item) => {
  const cat = getCategory(item);
  return cat === 'Sección principal' || cat === 'Main section' || cat === 'Section principale' || cat === 'Seção principal';
});

const pageTitle = query
  ? `${locale === 'es' ? 'Resultados de búsqueda' : locale === 'fr' ? 'Résultats de recherche' : locale === 'pt' ? 'Resultados da pesquisa' : 'Search results'} - ${query}`
  : locale === 'es' ? 'Buscar' : locale === 'fr' ? 'Rechercher' : locale === 'pt' ? 'Pesquisar' : 'Search';

const noResultsText = locale === 'es' ? 'No encontramos resultados para' : locale === 'fr' ? 'Aucun résultat trouvé pour' : locale === 'pt' ? 'Nenhum resultado encontrado para' : 'No results found for';
const tryText = locale === 'es' ? 'Prueba con estas secciones principales:' : locale === 'fr' ? 'Essayez ces sections principales:' : locale === 'pt' ? 'Tente estas seções principais:' : 'Try these main sections:';
const resultsText = locale === 'es' ? 'resultados' : locale === 'fr' ? 'résultats' : locale === 'pt' ? 'resultados' : 'results';
const searchAgainText = locale === 'es' ? 'Buscar de nuevo' : locale === 'fr' ? 'Rechercher à nouveau' : locale === 'pt' ? 'Pesquisar novamente' : 'Search again';
const allSectionsText = locale === 'es' ? 'Todas las secciones' : locale === 'fr' ? 'Toutes les sections' : locale === 'pt' ? 'Todas as seções' : 'All sections';
---

<div class="search-page">
  <div class="search-page-container">
    <!-- Hero de búsqueda -->
    <div class="search-hero">
      <h1 class="search-hero-title">{pageTitle}</h1>
      <div class="search-hero-form">
        <form action={locale === 'es' ? '/buscar' : `/${locale}/buscar`} method="GET" role="search">
          <div class="search-input-wrapper">
            <svg class="search-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              type="text"
              name="q"
              class="search-input"
              placeholder={searchAgainText}
              value={query}
              autocomplete="off"
              aria-label={searchAgainText}
            />
            <button type="submit" class="search-submit-btn">
              {locale === 'es' ? 'Buscar' : locale === 'fr' ? 'Rechercher' : locale === 'pt' ? 'Pesquisar' : 'Search'}
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Resultados -->
    <div class="search-results-section">
      {query ? (
        results.length > 0 ? (
          <>
            <p class="search-count">{results.length} {resultsText} "{query}"</p>
            <div class="search-results-grid">
              {results.map((item) => (
                <a href={item.href} class="search-result-card">
                  <div class="search-result-card-content">
                    <span class="search-result-card-label">{getLabel(item)}</span>
                    <span class="search-result-card-category">{getCategory(item)}</span>
                  </div>
                  <svg class="search-result-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              ))}
            </div>
          </>
        ) : (
          <div class="search-no-results">
            <div class="search-no-results-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                <line x1="8" y1="11" x2="14" y2="11"/>
              </svg>
            </div>
            <h2 class="search-no-results-title">{noResultsText} "{query}"</h2>
            <p class="search-no-results-text">{tryText}</p>
            <div class="search-suggestions">
              {mainSections.map((item) => (
                <a href={item.href} class="search-suggestion-chip">
                  {getLabel(item)}
                </a>
              ))}
            </div>
          </div>
        )
      ) : (
        <div class="search-all-sections">
          <h2 class="search-all-sections-title">{allSectionsText}</h2>
          <div class="search-all-sections-grid">
            {searchData.map((item) => (
              <a href={item.href} class="search-all-section-item">
                <span class="search-all-section-label">{getLabel(item)}</span>
                <span class="search-all-section-category">{getCategory(item)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .search-page {
    padding: 60px 0 100px;
    background: #f8fafc;
    min-height: calc(100vh - var(--header-height));
  }

  .search-page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ---- Hero ---- */
  .search-hero {
    text-align: center;
    margin-bottom: 48px;
  }

  .search-hero-title {
    font-size: 2rem;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 24px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .search-hero-form {
    max-width: 600px;
    margin: 0 auto;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    background: #ffffff;
    border: 1px solid #d0d5dd;
    border-radius: 12px;
    padding: 4px 4px 4px 16px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-input-wrapper:focus-within {
    border-color: #0066ff;
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
  }

  .search-input-icon {
    flex-shrink: 0;
    color: #98a2b3;
    margin-right: 8px;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 12px 0;
    font-size: 1rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #1a1a2e;
    background: transparent;
  }

  .search-input::placeholder {
    color: #98a2b3;
  }

  .search-submit-btn {
    padding: 10px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #ffffff;
    background: linear-gradient(135deg, #4da6ff 0%, #0066ff 50%, #0052cc 100%);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .search-submit-btn:hover {
    box-shadow: 0 4px 12px rgba(0, 102, 255, 0.3);
    transform: translateY(-1px);
  }

  /* ---- Results ---- */
  .search-results-section {
    margin-top: 8px;
  }

  .search-count {
    font-size: 0.9rem;
    color: #98a2b3;
    margin: 0 0 20px;
  }

  .search-results-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .search-result-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: #ffffff;
    border: 1px solid #e8ecf2;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .search-result-card:hover {
    border-color: #0066ff;
    box-shadow: 0 4px 12px rgba(0, 102, 255, 0.08);
    transform: translateX(4px);
  }

  .search-result-card-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .search-result-card-label {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
  }

  .search-result-card-category {
    font-size: 0.8rem;
    color: #98a2b3;
    font-weight: 500;
  }

  .search-result-card-arrow {
    color: #98a2b3;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .search-result-card:hover .search-result-card-arrow {
    transform: translateX(4px);
    color: #0066ff;
  }

  /* ---- No results ---- */
  .search-no-results {
    text-align: center;
    padding: 48px 0;
  }

  .search-no-results-icon {
    color: #d0d5dd;
    margin-bottom: 16px;
  }

  .search-no-results-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0 0 8px;
  }

  .search-no-results-text {
    font-size: 0.95rem;
    color: #98a2b3;
    margin: 0 0 24px;
  }

  .search-suggestions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .search-suggestion-chip {
    display: inline-flex;
    padding: 8px 18px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #0066ff;
    background: rgba(0, 102, 255, 0.06);
    border: 1px solid rgba(0, 102, 255, 0.15);
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .search-suggestion-chip:hover {
    background: rgba(0, 102, 255, 0.12);
    border-color: #0066ff;
    transform: translateY(-2px);
  }

  /* ---- All sections ---- */
  .search-all-sections-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0 0 20px;
  }

  .search-all-sections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 8px;
  }

  .search-all-section-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 18px;
    background: #ffffff;
    border: 1px solid #e8ecf2;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .search-all-section-item:hover {
    border-color: #0066ff;
    box-shadow: 0 4px 12px rgba(0, 102, 255, 0.08);
  }

  .search-all-section-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a2e;
  }

  .search-all-section-category {
    font-size: 0.75rem;
    color: #98a2b3;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .search-hero-title {
      font-size: 1.5rem;
    }

    .search-input-wrapper {
      flex-direction: column;
      padding: 8px;
      gap: 8px;
    }

    .search-input-icon {
      display: none;
    }

    .search-input {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid #d0d5dd;
      border-radius: 8px;
    }

    .search-submit-btn {
      width: 100%;
    }

    .search-all-sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
