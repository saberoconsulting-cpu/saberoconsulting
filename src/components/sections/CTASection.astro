---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  es: {
    title: 'Listo para construir tu proximo producto digital?',
    subtitle: 'Conversemos sin compromiso. Te responderemos en menos de 24 horas.',
    cta: 'Contactanos',
  },
  en: {
    title: 'Ready to build your next digital product?',
    subtitle: "Let's talk without commitment. We'll respond within 24 hours.",
    cta: 'Contact us',
  },
  pt: {
    title: 'Pronto para construir seu proximo produto digital?',
    subtitle: 'Vamos conversar sem compromisso. Responderemos em ate 24 horas.',
    cta: 'Fale conosco',
  },
  fr: {
    title: 'Pret a construire votre prochain produit numerique?',
    subtitle: 'Parlons-en sans engagement. Nous repondrons en moins de 24 heures.',
    cta: 'Contactez-nous',
  },
}[locale] || {
  title: 'Listo para construir tu proximo producto digital?',
  subtitle: 'Conversemos sin compromiso. Te responderemos en menos de 24 horas.',
  cta: 'Contactanos',
};
---

<section class="cta" aria-label="Call to action">
  <div class="cta-bg" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80"
      alt=""
      class="cta-bg-image"
      loading="lazy"
    />
  </div>
  <div class="cta-overlay"></div>
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">{content.title}</h2>
      <p class="cta-subtitle">{content.subtitle}</p>
      <a href={locale === 'es' ? '/contacto' : `/${locale}/contacto`} class="cta-button">
        <span class="cta-button-text">{content.cta}</span>
        <span class="cta-button-arrow">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M2 9h14M9 2l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding: var(--space-24) 0;
    text-align: center;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.6) contrast(1.1);
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(10, 22, 40, 0.92) 0%,
      rgba(10, 22, 40, 0.7) 50%,
      rgba(10, 22, 40, 0.88) 100%
    );
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 102, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 800;
    margin-bottom: var(--space-4);
    color: var(--color-white);
    letter-spacing: -0.02em;
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: var(--color-gray-300);
    margin-bottom: var(--space-10);
    line-height: 1.7;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-10);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    background: linear-gradient(135deg, var(--color-electric-blue) 0%, var(--color-electric-blue-hover) 100%);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 20px rgba(0, 102, 255, 0.3);
    position: relative;
    overflow: hidden;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-electric-blue-hover) 0%, var(--color-deep-blue-light) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    border-radius: inherit;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 102, 255, 0.4);
  }

  .cta-button:hover::before {
    opacity: 1;
  }

  .cta-button-text,
  .cta-button-arrow {
    position: relative;
    z-index: 1;
  }

  .cta-button-arrow {
    display: flex;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-button-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .cta {
      padding: var(--space-16) 0;
      min-height: 360px;
    }

    .cta-title {
      font-size: var(--text-2xl);
    }

    .cta-subtitle {
      font-size: var(--text-base);
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }

    .cta-glow {
      width: 400px;
      height: 400px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>
