---
interface Props {
  data: {
    title: string;
    subtitle: string;
    ctaPrimary: string;
    ctaSecondary: string;
  };
  locale: string;
}

const { data, locale } = Astro.props;
import '../../../styles/components/insights-cta.css';
const contactHref = locale === 'es' ? '/contacto/' : `/${locale}/contacto/`;
const offerHref = locale === 'es' ? '/#servicios' : `/${locale}/#servicios`;
---

<section class="cta-section section" aria-label="Contacto">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">{data.title}</h2>
      <p class="cta-subtitle">{data.subtitle}</p>
      <div class="cta-actions">
        <a href={contactHref} class="btn btn-primary btn-lg">{data.ctaPrimary}</a>
        <a href={offerHref} class="btn btn-outline cta-btn-outline btn-lg">{data.ctaSecondary}</a>
      </div>
    </div>
  </div>
</section>


