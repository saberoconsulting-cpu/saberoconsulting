---
interface Props {
  data: {
    title: string;
    subtitle: string;
    ctaPrimary: string;
    ctaSecondary: string;
  };
  locale: string;
}

const { data, locale } = Astro.props;
const contactHref = locale === 'es' ? '/contacto/' : `/${locale}/contacto/`;
const offerHref = locale === 'es' ? '/#servicios' : `/${locale}/#servicios`;
---

<section class="cta-section section" aria-label="Contacto">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">{data.title}</h2>
      <p class="cta-subtitle">{data.subtitle}</p>
      <div class="cta-actions">
        <a href={contactHref} class="btn btn-primary btn-lg">{data.ctaPrimary}</a>
        <a href={offerHref} class="btn btn-outline cta-btn-outline btn-lg">{data.ctaSecondary}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: #faf8f5;
    padding: var(--space-20) 0;
    text-align: center;
  }

  .cta-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-deep-blue);
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn-outline {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  .cta-btn-outline:hover {
    border-color: var(--color-electric-blue);
    color: var(--color-electric-blue);
    background: transparent;
  }

  @media (max-width: 600px) {
    .cta-section {
      padding: var(--space-12) 0;
    }

    .cta-title {
      font-size: var(--text-2xl);
    }
  }
</style>
