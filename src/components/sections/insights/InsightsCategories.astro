---
import type { InsightType } from '../../../data/insights/types';

interface Props {
  categories: { id: InsightType; label: string }[];
  activeCategory: InsightType | 'all';
}

const { categories, activeCategory } = Astro.props;
---

<nav class="categories-nav" aria-label="Categorias de contenido">
  <div class="container">
    <div class="categories-row">
      <button type="button" class="category-chip" data-category="all" class:list={{ active: activeCategory === 'all' }}>
        Todos
      </button>
      {categories.map((cat) => (
        <button type="button"
          class="category-chip"
          data-category={cat.id}
          class:list={{ active: activeCategory === cat.id }}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </div>
</nav>

<style>
  .categories-nav {
    padding: 24px 0;
    background: var(--color-white);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: var(--header-height);
    z-index: 10;
  }

  .categories-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .category-chip {
    padding: 8px 20px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-color);
    background: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .category-chip:hover {
    border-color: var(--color-electric-blue);
    color: var(--color-electric-blue);
  }

  .category-chip.active {
    background: var(--color-electric-blue);
    border-color: var(--color-electric-blue);
    color: var(--color-white);
  }

  @media (max-width: 600px) {
    .categories-nav {
      top: var(--header-height-mobile);
      padding: 16px 0;
    }

    .categories-row {
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
    }

    .category-chip {
      flex-shrink: 0;
    }
  }
</style>
