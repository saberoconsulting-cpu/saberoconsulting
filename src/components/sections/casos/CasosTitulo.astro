---
// ============================================
// SABERO Consulting - Sección de título
// "Disfrutamos trabajar contigo"
// ============================================

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const content: Record<string, { title: string; sub: string }> = {
  es: {
    title: 'Disfrutamos trabajar contigo',
    sub: 'Cada industria tiene procesos, métricas y retos distintos. SABERO adapta producto, arquitectura y experiencia según ese contexto.',
  },
  en: {
    title: 'We enjoy working with you',
    sub: 'Each industry has different processes, metrics and challenges. SABERO adapts product, architecture and experience according to that context.',
  },
  pt: {
    title: 'Gostamos de trabalhar com você',
    sub: 'Cada indústria tem processos, métricas e desafios diferentes. A SABERO adapta produto, arquitetura e experiência de acordo com esse contexto.',
  },
  fr: {
    title: 'Nous aimons travailler avec vous',
    sub: 'Chaque secteur a des processus, des métriques et des défis différents. SABERO adapte le produit, l\'architecture et l\'expérience en fonction de ce contexte.',
  },
};

const c = content[locale] || content.es;
---

<section class="casos-titulo-section">
  <div class="container">
    <div class="casos-titulo-content">
      <div class="casos-titulo-accent"></div>
      <h2 class="casos-titulo-title">{c.title}</h2>
      <p class="casos-titulo-sub">{c.sub}</p>
    </div>
  </div>
</section>

<style>
  .casos-titulo-section {
    padding: var(--space-10) 0 var(--space-6);
    background-color: var(--bg-secondary);
    text-align: center;
  }

  .casos-titulo-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .casos-titulo-accent {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, #E62325 0%, #1D5BF1 100%);
    border-radius: 2px;
    margin: 0 auto var(--space-6);
  }

  .casos-titulo-title {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-3);
    background: linear-gradient(135deg, #E62325 0%, #1D5BF1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .casos-titulo-sub {
    font-size: clamp(var(--text-sm), 1vw, var(--text-base));
    color: var(--color-gray-400);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .casos-titulo-section { padding: var(--space-6) 0 var(--space-4); }
  }
</style>
