---
import { Image } from 'astro:assets';
import type { SupportedLocale } from '../../i18n/utils/types';
import { getHeroSlides, type HeroSlide } from '../../data/home/hero-slides';
import { localizeNavHref } from '../../i18n/routes/map';
import heroImg from '../../assets/images/imagen.png';
import heroImg1 from '../../assets/images/imagen1.png';
import heroImg2 from '../../assets/images/imagen2.png';
import heroImg3 from '../../assets/images/imagen3.png';
import heroImg4 from '../../assets/images/imagen4.png';

const heroImages: Record<string, ImageMetadata> = {
  '/images/imagen.png': heroImg,
  '/images/imagen1.png': heroImg1,
  '/images/imagen2.png': heroImg2,
  '/images/imagen3.png': heroImg3,
  '/images/imagen4.png': heroImg4,
};

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const slides: HeroSlide[] = getHeroSlides(locale);
const slidesCount = slides.length;
const extended = [slides[slidesCount - 1], ...slides, slides[0]];
---

<section class="hero-carousel" aria-label="Hero carousel" data-carousel data-total={slidesCount}>
  <div class="carousel-viewport">
    <div class="carousel-track" data-track style="transform: translateX(-100%)">
      {extended.map((slide, index) => {
        const realIndex = index - 1;
        const isClone = index === 0 || index === extended.length - 1;
        const isActive = index === 1;
        const imgSrc = heroImages[slide.image];
        return (
          <article
            class="carousel-slide"
            data-slide={realIndex}
            aria-roledescription="slide"
            aria-label={isClone ? '' : `Slide ${realIndex + 1} of ${slidesCount}`}
            aria-hidden={!isActive || isClone}
          >
            <Image
              src={imgSrc || slide.image}
              alt={isClone ? '' : slide.alt}
              class="carousel-image"
              loading={index === 1 ? 'eager' : 'lazy'}
              decoding="async"
              width={1920}
              height={900}
              format="webp"
              fetchpriority={index === 1 ? 'high' : 'auto'}
            />
            <div class="carousel-overlay" aria-hidden="true"></div>
            <div class="carousel-content">
              <div class="carousel-text">
                {slide.eyebrow && <span class="carousel-eyebrow">{slide.eyebrow}</span>}
                <h1 class="carousel-title">{slide.title}</h1>
                <p class="carousel-description">{slide.description}</p>
                <div class="carousel-actions">
                  <a
                    href={localizeNavHref(slide.primaryCtaHref, locale)}
                    class="btn btn-primary carousel-cta"
                  >
                    {slide.primaryCtaLabel}
                  </a>
                  {slide.secondaryCtaLabel && slide.secondaryCtaHref && (
                    <a
                      href={localizeNavHref(slide.secondaryCtaHref, locale)}
                      class="btn btn-outline carousel-cta-secondary"
                    >
                      {slide.secondaryCtaLabel}
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  <!-- Navigation arrows -->
  <button class="carousel-arrow carousel-arrow-prev" data-prev aria-label="Previous slide" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <button class="carousel-arrow carousel-arrow-next" data-next aria-label="Next slide" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <!-- Dots -->
  <div class="carousel-dots" role="tablist" aria-label="Slide navigation">
    {slides.map((_, index) => (
      <button
        class="carousel-dot"
        data-dot={index}
        role="tab"
        aria-selected={index === 0}
        aria-label={`Go to slide ${index + 1}`}
        type="button"
      ></button>
    ))}
  </div>
</section>

<script>
  // @ts-nocheck
  (function () {
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var AUTOPLAY_INTERVAL = 3000;
    var TRANSITION_DURATION = 600;

    var carousel = document.querySelector('[data-carousel]');
    if (!carousel) return;

    var track = carousel.querySelector('[data-track]');
    if (!track) return;

    var slideEls = Array.from(carousel.querySelectorAll('[data-slide]'));
    var dots = Array.from(carousel.querySelectorAll('[data-dot]'));
    var prevBtn = carousel.querySelector('[data-prev]');
    var nextBtn = carousel.querySelector('[data-next]');

    var totalReal = parseInt(carousel.getAttribute('data-total') || '0', 10);
    if (totalReal < 2) return;

    var currentIndex = 1; // starts at first real slide
    var autoplayTimer = null;
    var isAnimating = false;

    function jumpTo(index) {
      track.style.transition = 'none';
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      // force reflow
      void track.offsetHeight;
      track.style.transition = '';
      currentIndex = index;
    }

    function updateSlidesAndDots(realIndex) {
      slideEls.forEach(function (el) {
        var ri = parseInt(el.getAttribute('data-slide'), 10);
        el.setAttribute('aria-hidden', ri !== realIndex ? 'true' : 'false');
      });
      dots.forEach(function (dot, i) {
        dot.setAttribute('aria-selected', i === realIndex ? 'true' : 'false');
      });
    }

    function goToSlide(target, animate) {
      if (animate === undefined) animate = true;
      if (isAnimating && animate) return;
      if (target === currentIndex) return;

      if (!animate) {
        jumpTo(target);
        var real = target - 1;
        if (real < 0) real = totalReal - 1;
        if (real >= totalReal) real = 0;
        updateSlidesAndDots(real);
        return;
      }

      isAnimating = true;
      track.style.transform = 'translateX(-' + (target * 100) + '%)';
      currentIndex = target;

      var realIndex = target - 1;
      if (realIndex < 0) realIndex = totalReal - 1;
      if (realIndex >= totalReal) realIndex = 0;
      updateSlidesAndDots(realIndex);

      setTimeout(function () {
        isAnimating = false;
        if (currentIndex === 0) {
          jumpTo(totalReal);
        } else if (currentIndex === totalReal + 1) {
          jumpTo(1);
        }
      }, TRANSITION_DURATION);
    }

    function nextSlide() {
      goToSlide(currentIndex + 1, true);
    }

    function prevSlide() {
      goToSlide(currentIndex - 1, true);
    }

    function goToReal(index) {
      var offset = index + 1;
      goToSlide(offset, true);
    }

    function startAutoplay() {
      if (prefersReducedMotion) return;
      stopAutoplay();
      autoplayTimer = setInterval(nextSlide, AUTOPLAY_INTERVAL);
    }

    function stopAutoplay() {
      if (autoplayTimer !== null) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function resetAutoplay() {
      stopAutoplay();
      startAutoplay();
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        nextSlide();
        resetAutoplay();
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        prevSlide();
        resetAutoplay();
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var index = parseInt(dot.getAttribute('data-dot') || '0', 10);
        goToReal(index);
        resetAutoplay();
      });
    });

    carousel.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') {
        prevSlide();
        resetAutoplay();
      } else if (e.key === 'ArrowRight') {
        nextSlide();
        resetAutoplay();
      }
    });

    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);
    carousel.addEventListener('focusin', stopAutoplay);
    carousel.addEventListener('focusout', startAutoplay);

    var touchStartX = 0;
    var touchEndX = 0;

    carousel.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    carousel.addEventListener('touchend', function (e) {
      touchEndX = e.changedTouches[0].screenX;
      var diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
        resetAutoplay();
      }
    }, { passive: true });

    startAutoplay();
  })();
</script>

<style>
  /* ============================================
     SABERO Consulting - Hero Carousel
     Premium, corporativo, alto impacto
     ============================================ */

  .hero-carousel {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 500px;
    max-height: 900px;
    overflow: hidden;
    background-color: var(--color-deep-blue);
  }

  .carousel-viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .carousel-slide {
    position: relative;
    min-width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .carousel-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .carousel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 22, 40, 0.92) 0%,
      rgba(10, 22, 40, 0.7) 40%,
      rgba(10, 22, 40, 0.3) 100%
    );
    z-index: 1;
  }

  .carousel-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    padding-top: var(--header-height);
    padding-bottom: var(--space-16);
  }

  .carousel-text {
    max-width: 640px;
    animation: fadeInUp 0.8s ease forwards;
  }

  .carousel-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-color);
    margin-bottom: var(--space-4);
    padding: var(--space-1) var(--space-3);
    border: 1px solid rgba(0, 102, 255, 0.3);
    border-radius: var(--radius-full);
    background-color: rgba(0, 102, 255, 0.08);
  }

  .carousel-title {
    font-size: var(--text-6xl);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    margin-bottom: var(--space-5);
    letter-spacing: -0.02em;
  }

  .carousel-description {
    font-size: var(--text-lg);
    color: var(--color-gray-300);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 520px;
  }

  .carousel-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .carousel-cta {
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
  }

  .carousel-cta-secondary {
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-base);
    font-weight: 600;
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-white);
  }

  .carousel-cta-secondary:hover {
    border-color: var(--color-white);
    color: var(--color-white);
    background-color: rgba(255, 255, 255, 0.05);
  }

  /* ---- Arrows ---- */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.06);
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
    opacity: 0;
    pointer-events: none;
  }

  .hero-carousel:hover .carousel-arrow {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel-arrow:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .carousel-arrow:focus-visible {
    opacity: 1;
    pointer-events: auto;
    outline: 2px solid var(--accent-color);
    outline-offset: 2px;
  }

  .carousel-arrow-prev {
    left: var(--space-6);
  }

  .carousel-arrow-next {
    right: var(--space-6);
  }

  /* ---- Dots ---- */
  .carousel-dots {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background-color: rgba(255, 255, 255, 0.25);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    padding: 0;
  }

  .carousel-dot[aria-selected='true'] {
    background-color: var(--accent-color);
    width: 28px;
    border-radius: 5px;
  }

  .carousel-dot:hover {
    background-color: rgba(255, 255, 255, 0.5);
  }

  .carousel-dot:focus-visible {
    outline: 2px solid var(--accent-color);
    outline-offset: 2px;
  }

  /* ---- Animation ---- */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      transition: none;
    }

    .carousel-text {
      animation: none;
    }

    .carousel-arrow {
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* ---- Responsive ---- */

  /* Tablet landscape */
  @media (max-width: 1100px) {
    .hero-carousel {
      height: 70vh;
      min-height: 450px;
    }

    .carousel-title {
      font-size: var(--text-5xl);
    }

    .carousel-description {
      font-size: var(--text-base);
    }
  }

  /* Tablet portrait */
  @media (max-width: 768px) {
    .hero-carousel {
      height: 65vh;
      min-height: 400px;
    }

    .carousel-title {
      font-size: var(--text-3xl);
    }

    .carousel-description {
      font-size: var(--text-sm);
      max-width: 100%;
    }

    .carousel-text {
      max-width: 100%;
    }

    .carousel-content {
      padding-bottom: var(--space-12);
    }

    .carousel-arrow {
      width: 40px;
      height: 40px;
    }

    .carousel-arrow-prev {
      left: var(--space-3);
    }

    .carousel-arrow-next {
      right: var(--space-3);
    }

    .carousel-dots {
      bottom: var(--space-6);
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .hero-carousel {
      height: 60vh;
      min-height: 380px;
    }

    .carousel-title {
      font-size: var(--text-2xl);
    }

    .carousel-actions {
      flex-direction: column;
      width: 100%;
    }

    .carousel-cta,
    .carousel-cta-secondary {
      width: 100%;
      text-align: center;
    }

    .carousel-arrow {
      display: none;
    }

    .carousel-dots {
      bottom: var(--space-4);
    }
  }
</style>
