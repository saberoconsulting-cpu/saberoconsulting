---
import type { SupportedLocale } from '../../i18n/utils/types';
import { getNavigation } from '../../data/navigation/index';
import { siteSettings } from '../../data/settings/site';
import { t } from '../../i18n/ui/index';
import { localizeNavHref } from '../../i18n/routes/map';
import LanguageSwitcher from '../navigation/LanguageSwitcher.astro';
import MegaMenu from '../navigation/MegaMenu.astro';
import MobileMenu from '../navigation/MobileMenu.astro';
import SearchBar from '../navigation/SearchBar.astro';

interface Props {
  currentLocale: SupportedLocale;
  path: string;
}

const { currentLocale, path } = Astro.props;
const navigation = getNavigation(currentLocale);
const megaMenuKeys = Object.keys(navigation.megaMenus);
---

<header class="site-header" role="banner">
  <div class="header-container">
    <!-- Logo -->
    <a href={currentLocale === 'es' ? '/' : `/${currentLocale}/`} class="header-logo" aria-label={siteSettings.name}>
      <img src="/images/saberologo.png" alt={siteSettings.name} class="header-logo-img" width="320" height="89" loading="eager" decoding="async" />
    </a>

    <!-- Navigation Desktop -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navigation.main.map((item, index) => {
          const menuKey = megaMenuKeys[index];
          const megaSection = menuKey ? navigation.megaMenus[menuKey] : null;
          const localizedHref = localizeNavHref(item.href, currentLocale);

          return (
            <li class="nav-item" data-mega={menuKey || ''}>
              <a
                href={localizedHref}
                class="nav-link"
                aria-haspopup={megaSection ? 'true' : undefined}
                aria-expanded={megaSection ? 'false' : undefined}
              >
                {item.label}
              </a>
              {megaSection && (
                <MegaMenu section={megaSection} isOpen={false} id={menuKey} locale={currentLocale} />
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <SearchBar currentLocale={currentLocale} />
      <LanguageSwitcher currentLocale={currentLocale} path={path} variant="desktop" />
      <a href={localizeNavHref('/contacto', currentLocale)} class="header-cta-btn">
        {t(currentLocale, 'header.cta')}
      </a>
      <button class="hamburger" aria-label={t(currentLocale, 'header.menu')} data-toggle-mobile>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<MobileMenu
  navigation={navigation}
  currentLocale={currentLocale}
  path={path}
  isOpen={false}
/>

<script>
  // Mega menus
  let activeMega: string | null = null;

  document.querySelectorAll('.nav-item[data-mega]').forEach((item) => {
    const megaId = item.getAttribute('data-mega');
    if (!megaId) return;

    const trigger = item.querySelector('.nav-link') as HTMLElement;
    const menu = item.querySelector('.mega-menu') as HTMLElement;

    if (!trigger || !menu) return;

    function openMega() {
      if (activeMega && activeMega !== megaId) {
        const prev = document.querySelector(`.nav-item[data-mega="${activeMega}"]`);
        prev?.querySelector('.nav-link')?.setAttribute('aria-expanded', 'false');
        prev?.querySelector('.mega-menu')?.classList.remove('open');
      }
      activeMega = megaId;
      trigger.setAttribute('aria-expanded', 'true');
      menu.classList.add('open');
    }

    function closeMega() {
      activeMega = null;
      trigger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('open');
    }

    item.addEventListener('mouseenter', openMega);
    item.addEventListener('mouseleave', (e) => {
      const related = (e as MouseEvent).relatedTarget as HTMLElement;
      if (related && item.contains(related)) return;
      setTimeout(() => {
        if (!item.matches(':hover')) closeMega();
      }, 100);
    });

    trigger.addEventListener('focus', openMega);
    trigger.addEventListener('blur', (e) => {
      const related = (e as FocusEvent).relatedTarget as HTMLElement;
      if (related && item.contains(related)) return;
      closeMega();
    });
  });

  // Header hide/show on scroll
  const headerElement = document.querySelector('.site-header');
  let lastScrollPosition = window.scrollY;
  const updateHeaderVisibility = () => {
    const currentScroll = window.scrollY;
    if (!headerElement) return;

    if (currentScroll > lastScrollPosition && currentScroll > 120) {
      headerElement.classList.add('header-hidden');
    } else {
      headerElement.classList.remove('header-hidden');
    }

    lastScrollPosition = Math.max(currentScroll, 0);
  };

  window.addEventListener('scroll', updateHeaderVisibility, { passive: true });

  // Close mega menus on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.mega-menu.open').forEach((m) => m.classList.remove('open'));
      document.querySelectorAll('.nav-link[aria-expanded="true"]').forEach((l) => l.setAttribute('aria-expanded', 'false'));
      activeMega = null;
    }
  });

  // Close mega menus on click outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (activeMega && !target.closest('.nav-item')) {
      const prev = document.querySelector(`.nav-item[data-mega="${activeMega}"]`);
      prev?.querySelector('.nav-link')?.setAttribute('aria-expanded', 'false');
      prev?.querySelector('.mega-menu')?.classList.remove('open');
      activeMega = null;
    }
  });
</script>

<style>
  /* ============================================
     SABERO Consulting - Header
     ============================================ */

  :root {
    --header-height: 80px;
    --header-height-mobile: 64px;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background-color: #ffffff;
    border-bottom: 1px solid #eaeef2;
    z-index: 1000;
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.28s ease, opacity 0.28s ease;
    will-change: transform, opacity;
  }

  .site-header.header-hidden {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }

  .header-container {
    display: flex;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: 0 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ---- Logo ---- */
  .header-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 32px;
  }

  .header-logo-img {
    display: block;
    height: 56px;
    width: auto;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease;
    will-change: transform;
  }

  .header-logo:hover .header-logo-img {
    transform: scale(1.08);
    filter: drop-shadow(0 0 10px rgba(0, 102, 255, 0.25));
  }

  /* ---- Navigation ---- */
  .header-nav {
    display: flex;
    align-items: center;
    flex: 1;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: static;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #1a1a2e;
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.1px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    width: 0;
    height: 2px;
    background: #0066ff;
    border-radius: 2px;
    transform: translateX(-50%);
    transition: width 0.25s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    width: calc(100% - 28px);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: #0066ff;
  }

  /* ---- Actions ---- */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* ---- CTA Button ---- */
  .header-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 22px;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #ffffff;
    text-decoration: none;
    border: none;
    border-radius: 9999px;
    background: linear-gradient(135deg, #4da6ff 0%, #0066ff 50%, #0052cc 100%);
    background-size: 200% 200%;
    transition: all 0.3s ease;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 102, 255, 0.2);
  }

  .header-cta-btn:hover {
    background-position: right center;
    box-shadow: 0 4px 16px rgba(0, 102, 255, 0.35);
    transform: translateY(-1px);
  }

  .header-cta-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(0, 102, 255, 0.2);
  }

  /* ---- Hamburger ---- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: 1px solid #d0d5dd;
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .hamburger:hover {
    border-color: #98a2b3;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #1a1a2e;
    border-radius: 2px;
  }

  /* ---- Responsive ---- */

  @media (max-width: 1200px) {
    .nav-link {
      padding: 8px 10px;
      font-size: 0.85rem;
    }

    .header-cta-btn {
      padding: 7px 18px;
      font-size: 0.8rem;
    }

    .header-logo-img {
      height: 48px;
    }
  }

  @media (max-width: 1024px) {
    .site-header {
      height: var(--header-height-mobile);
    }

    .header-container {
      padding: 0 16px;
    }

    .header-logo-img {
      height: 40px;
    }

    .header-nav {
      display: none;
    }

    .header-actions .lang-switcher,
    .header-actions .header-cta-btn {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .header-logo-img {
      height: 34px;
    }

    .header-container {
      padding: 0 12px;
    }
  }
</style>
