---
import type { SupportedLocale } from '../i18n/utils/types';
import { siteSettings } from '../data/settings/site';
import { generateSEO, generateOrganizationSchema, generateWebSiteSchema, generateProfessionalServiceSchema } from '../lib/seo/index';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  locale: SupportedLocale;
  path: string;
  ogImage?: string;
  noIndex?: boolean;
  canonicalPath?: string;
}

const {
  title,
  description,
  locale,
  path,
  ogImage,
  noIndex,
  canonicalPath,
} = Astro.props;

const seo = generateSEO({
  title,
  description,
  canonical: canonicalPath || path,
  locale,
  path,
  ogImage,
  noIndex,
});

const organizationSchema = generateOrganizationSchema();
const websiteSchema = generateWebSiteSchema();
const professionalServiceSchema = generateProfessionalServiceSchema();
---

<!DOCTYPE html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seo.description} />
    <meta name="theme-color" content="#0A1628" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{seo.title}</title>
    <link rel="canonical" href={seo.canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://i.ibb.co" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://i.ibb.co" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn-icons-png.flaticon.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn-icons-png.flaticon.com" />
    <link rel="preconnect" href="https://encrypted-tbn0.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://encrypted-tbn0.gstatic.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" /></noscript>

    {seo.hreflang.map((link) => (
      <link rel={link.rel} hreflang={link.hreflang} href={link.href} />
    ))}

    <link rel="alternate" hreflang="x-default" href={`${siteSettings.url}/`} />

    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:locale" content={locale === 'es' ? 'es_PE' : locale === 'en' ? 'en_US' : locale === 'pt' ? 'pt_BR' : 'fr_FR'} />
    <meta property="og:site_name" content={siteSettings.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script type="application/ld+json" is:inline>{JSON.stringify(organizationSchema)}</script>
    <script type="application/ld+json" is:inline>{JSON.stringify(websiteSchema)}</script>
    <script type="application/ld+json" is:inline>{JSON.stringify(professionalServiceSchema)}</script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">
      {locale === 'es' ? 'Saltar al contenido principal' : locale === 'fr' ? 'Aller au contenu principal' : locale === 'pt' ? 'Pular para o conteúdo principal' : 'Skip to main content'}
    </a>

    <Header currentLocale={locale} path={path} />

    <main id="main-content" role="main" tabindex="-1">
      <slot />
    </main>

    <Footer currentLocale={locale} />
  </body>
</html>

<style is:global>
  .skip-link {
    position: fixed;
    top: -100%;
    left: 16px;
    z-index: 9999;
    padding: 12px 24px;
    background: var(--color-deep-blue);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0 0 8px 8px;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 0;
  }
</style>

<style>
  main {
    padding-top: var(--header-height);
    min-height: 100vh;
  }

  @media (max-width: 1024px) {
    main {
      padding-top: var(--header-height-mobile);
    }
  }
</style>
