# SABERO Consulting - Environment Variables
# Copy this file to .env and adjust values for your environment

# Site URL (sin trailing slash)
# Local: http://localhost:4321
# Production: https://saberoconsulting.com
PUBLIC_SITE_URL=http://localhost:4321

# Site name
PUBLIC_SITE_NAME=SABERO Consulting

# Default locale
PUBLIC_DEFAULT_LOCALE=es

# Contact email
PUBLIC_CONTACT_EMAIL=saberoconsulting@gmail.com

# WhatsApp number (formato internacional sin +)
PUBLIC_WHATSAPP=51999999999

# Google Analytics ID (opcional, dejar vacio si no se usa)
PUBLIC_GA_ID=

# Environment
PUBLIC_ENV=development
